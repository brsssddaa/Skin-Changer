    -- Unified animation loop - combines all periodic animations into one
    -- This eliminates the 6-second lag caused by separate loops
    local navState = 0  -- 0 = fading out, 1 = fading in
    local glowState = 0  -- 0 = shrinking, 1 = growing
    local cursorState = 0  -- 0 = shrinking, 1 = growing
    task.spawn(function()
        local lastNavUpdate = 0
        local lastGlowUpdate = 0
        local lastCursorUpdate = 0
        local lastClockUpdate = 0
        
        while true do
            local now = tick()
            local shouldContinue = false
            
            -- Check if any UI element is still active
            if screenGui and screenGui.Parent then shouldContinue = true end
            if headIconGui and headIconGui.Parent then shouldContinue = true end
            if cursorGui and cursorGui.Parent then shouldContinue = true end
            if clock and clock.Parent then shouldContinue = true end
            
            if not shouldContinue then break end
            
            -- Nav indicator animation (every 1.4 seconds)
            if now - lastNavUpdate >= 1.4 and screenGui and screenGui.Parent then
                if mainContainer.Visible then
                    if navState == 0 then
                        tween(navIndicator, 1.4, {BackgroundTransparency = 0.05},
                              Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                        navState = 1
                    else
                        tween(navIndicator, 1.4, {BackgroundTransparency = 0.25},
                              Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                        navState = 0
                    end
                end
                lastNavUpdate = now
            end
            
            -- Head icon glow animation (every 1.6 seconds)
            if now - lastGlowUpdate >= 1.6 and headIconGui and headIconGui.Parent then
                if glowState == 0 then
                    tween(headIconGlow, 1.6, {Size = UDim2.fromOffset(58, 58)},
                          Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    tween(glowStroke,   1.6, {Transparency = 0.85},
                          Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    glowState = 1
                else
                    tween(headIconGlow, 1.6, {Size = UDim2.fromOffset(50, 50)},
                          Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    tween(glowStroke,   1.6, {Transparency = 0.55},
                          Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    glowState = 0
                end
                lastGlowUpdate = now
            end
            
            -- Cursor glow animation (every 1.6 seconds)
            if now - lastCursorUpdate >= 1.6 and cursorGui and cursorGui.Parent then
                if cursorState == 0 then
                    tween(glowRing, 1.6, {Size = UDim2.fromOffset(44, 44)},
                          Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    tween(cursorGlowStroke, 1.6, {Transparency = 0.75},
                          Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    cursorState = 1
                else
                    tween(glowRing, 1.6, {Size = UDim2.fromOffset(36, 36)},
                          Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    tween(cursorGlowStroke, 1.6, {Transparency = 0.45},
                          Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    cursorState = 0
                end
                lastCursorUpdate = now
            end
            
            -- Clock and ping update (every 1 second)
            if now - lastClockUpdate >= 1 then
                if clock and clock.Parent then
                    clock.Text = os.date("%H:%M:%S")
                end
                -- Ping update
                local pingMs = "—"
                pcall(function()
                    local stats = game:GetService("Stats")
                    local net = stats and stats.Network
                    local item = net and net.ServerStatsItem and net.ServerStatsItem["Data Ping"]
                    if item then
                        pingMs = tostring(math.floor(item:GetValue())) .. " ms"
                    else
                        pingMs = tostring(math.floor(player:GetNetworkPing() * 1000)) .. " ms"
                    end
                end)
                if pingLabel and pingLabel.Parent then
                    pingLabel.Text = pingMs
                end
                lastClockUpdate = now
            end
            
            task.wait(0.1)  -- Small delay for the unified loop
        end
    end)

    -- Executor label (below ping)
