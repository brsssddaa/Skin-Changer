    "trigon/autoexec",
    "wave/autoexec",
    "scriptware/autoexec",
    "synapse/autoexec",
    "xeno/autoexec",
}

-- Detect current executor name from environment
function detectCurrentExecutor()
    -- Try common executor detection functions
    local success, result = pcall(function()
        if identifyexecutor then
            return identifyexecutor()
        end
        if getexecutorname then
            return getexecutorname()
        end
        return nil
    end)
    
    if success and result then
        return tostring(result):lower()
    end
    
    -- Try to detect from global variables
    local globals = {
        syn = "Synapse",
        krnl = "KRNL",
        fluxus = "Fluxus",
        delta = "Delta",
        codex = "Codex",
        arceus = "Arceus",
        hydrogen = "Hydrogen",
        electron = "Electron",
        scriptware = "Script-Ware",
    }
    
    for globalName, execName in pairs(globals) do
        if _G[globalName] or getfenv()[globalName] then
            return execName:lower()
        end
    end
    
    return nil
end

-- Find all available autoexec folders (with try-write fallback)
function findAutoexecFolders()
    local found = {}
    
    -- Method 1: Check with isfolder
    if isfolder then
        for _, path in ipairs(AUTOEXEC_CANDIDATES) do
            if isfolder(path) then
                table.insert(found, path)
            end
        end
    end
    
    -- Method 2: Try writing to known paths and verify with isfile
    if writefile and isfile and #found == 0 then
        local testContent = "-- test"
        for _, path in ipairs(AUTOEXEC_CANDIDATES) do
            local testPath = path .. "/.skinchangetest"
            pcall(function()
                writefile(testPath, testContent)
                if isfile(testPath) then
                    table.insert(found, path)
                    -- Clean up test file
                    if delfile then
                        pcall(function() delfile(testPath) end)
                    end
                end
            end)
        end
    end
    
    -- Method 3: Detect executor and use known path
    if #found == 0 then
        local detectedExec = detectCurrentExecutor()
        if detectedExec then
            local execPaths = {
                ["xeno"] = "autoexec",
                ["velocity"] = "autoexec",
                ["ronix"] = "autoexec",
                ["synapse"] = "autoexec",
                ["krnl"] = "autoexec",
                ["fluxus"] = "autoexec",
                ["delta"] = "autoexec",
                ["codex"] = "autoexec",
                ["arceus"] = "autoexec",
                ["hydrogen"] = "autoexec",
                ["electron"] = "autoexec",
                ["scriptware"] = "autoexec",
                ["trigon"] = "autoexec",
                ["wave"] = "autoexec",
            }
            
            local knownPath = execPaths[detectedExec]
            if knownPath then
                -- Try to write to verify
                if writefile and isfile then
                    local testPath = knownPath .. "/.skinchangetest"
                    pcall(function()
                        writefile(testPath, "-- test")
                        if isfile(testPath) then
                            table.insert(found, knownPath)
                            if delfile then
                                pcall(function() delfile(testPath) end)
                            end
                        end
                    end)
                end
            end
        end
    end
    
    -- Method 4: Check saved manual path
    if #found == 0 then
        local savedPath = loadManualAutoexecPath()
        if savedPath and savedPath ~= "" then
            if isfolder and isfolder(savedPath) then
                table.insert(found, savedPath)
            elseif writefile and isfile then
                -- Try to verify by writing
                local testPath = savedPath .. "/.skinchangetest"
                pcall(function()
                    writefile(testPath, "-- test")
                    if isfile(testPath) then
                        table.insert(found, savedPath)
                        if delfile then
                            pcall(function() delfile(testPath) end)
                        end
                    end
                end)
            end
        end
    end
    
    return found
end

