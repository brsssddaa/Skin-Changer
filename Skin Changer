-- Helper function to create a card with ViewportFrame for SurfaceGui
local function wmCreateViewportCard(parent, targetPlayerOrSkin, isSkin, index, onClick)
    do -- block to limit locals scope
    local card = Instance.new("Frame")
    card.Name = isSkin and ("SkinCard_" .. tostring(index)) or (targetPlayerOrSkin.Name .. "Card")
    card.Size = UDim2.fromOffset(180, 200)  -- Как в createSavedCard
    card.LayoutOrder = index
    card.BackgroundColor3 = C.BG_CARD
    card.BackgroundTransparency = 0.05
    card.BorderSizePixel = 0
    card.ZIndex = 2
    card.ClipsDescendants = true
    card.Parent = parent
    wmCorner(card, 12)
    local cardStroke = wmStroke(card, Theme.dark, 1, 0.45)

    -- Gradient (как в createPlayerCard)
    local gr = Instance.new("UIGradient")
    gr.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0.0, C.BG_CARD_H),
        ColorSequenceKeypoint.new(1.0, C.BG_CARD),
    }
    gr.Rotation = 135
    gr.Parent = card

    -- ArtDeco corners (как в createPlayerCard)
    applyArtDecoCorners(card, 12, 1, nil, 4)

    -- Avatar/Viewport (копия структуры из createSavedCard)
    local userId = isSkin and (targetPlayerOrSkin.userId or 0) or targetPlayerOrSkin.UserId

    local avatarBuilt = false
    if isSkin then
        -- Render frozen snapshot of the saved skin so icons don't change when the source player updates their avatar
        local viewport = Instance.new("ViewportFrame")
        viewport.Name = "Avatar"
        viewport.Size = UDim2.new(1, -16, 0, 150)
        viewport.Position = UDim2.new(0, 8, 0, 8)
        viewport.BackgroundColor3 = C.BLACK
        viewport.BackgroundTransparency = 0.05
        viewport.BorderSizePixel = 0
        viewport.ClipsDescendants = true
        viewport.ZIndex = 2
        viewport.Ambient = Color3.fromRGB(200, 200, 220)
        viewport.LightColor = Color3.fromRGB(255, 255, 255)
        viewport.LightDirection = Vector3.new(-0.5, -1, -0.5)
        viewport.Parent = card
        wmCorner(viewport, 8)
        wmStroke(viewport, Theme.dark, 1, 0.6)

        local cam = Instance.new("Camera")
        cam.Parent = viewport
        viewport.CurrentCamera = cam

        -- Try frozen skin-model first, then session character clone
        local ok1, builtModel = pcall(buildSkinModel, targetPlayerOrSkin)
        if ok1 and builtModel then
            local ok2 = buildViewportFromSkinModel(viewport, builtModel)
            if ok2 then
                avatarBuilt = true
            else
                pcall(function() builtModel:Destroy() end)
            end
        end
        if not avatarBuilt and targetPlayerOrSkin.characterClone then
            avatarBuilt = buildViewportFromCharacter(viewport, targetPlayerOrSkin.characterClone)
        end
        if not avatarBuilt then
            viewport:Destroy()
        end
    end

    if not avatarBuilt then
        if isSkin then
            -- Frozen fallback for saved skins: colored silhouette with initial (never changes)
            local frozen = Instance.new("Frame")
            frozen.Name = "Avatar"
            frozen.Size = UDim2.new(1, -16, 0, 150)
            frozen.Position = UDim2.new(0, 8, 0, 8)
            frozen.BorderSizePixel = 0
            frozen.ZIndex = 2
            local torsoCol = (targetPlayerOrSkin.bodyColors and targetPlayerOrSkin.bodyColors.TorsoColor3) or Color3.fromRGB(60, 60, 80)
            frozen.BackgroundColor3 = torsoCol
            frozen.Parent = card
            wmCorner(frozen, 8)
            wmStroke(frozen, Theme.dark, 1, 0.6)
            local initial = Instance.new("TextLabel")
            initial.BackgroundTransparency = 1
            initial.Size = UDim2.fromScale(1, 1)
            initial.Text = string.upper(string.sub(targetPlayerOrSkin.playerName or "?", 1, 1))
            initial.TextColor3 = C.WHITE
            initial.TextSize = 72
            initial.Font = FONT_BOLD
            initial.ZIndex = 3
            initial.Parent = frozen
        else
            -- Live thumbnail for players tab (always up-to-date)
            local avatar = Instance.new("ImageLabel")
            avatar.Name = "Avatar"
            avatar.Size = UDim2.new(1, -16, 0, 150)
            avatar.Position = UDim2.new(0, 8, 0, 8)
            avatar.BackgroundColor3 = C.BLACK
            avatar.BackgroundTransparency = 0.05
            avatar.BorderSizePixel = 0
            avatar.ClipsDescendants = true
            avatar.ZIndex = 2
            avatar.ScaleType = Enum.ScaleType.Fit
            avatar.Parent = card
            wmCorner(avatar, 8)
            wmStroke(avatar, Theme.dark, 1, 0.6)
            avatar.Image = "rbxthumb://type=AvatarHeadShot&id=" .. tostring(userId) .. "&w=420&h=420"
        end
    end

    -- Luxury delete X для сохранённых скинов (как в createSavedCard)
    if isSkin then
        local deleteBtn = makeLuxuryX(card, {size = 24, lineLen = 10, thick = 1.6})
        deleteBtn.Name = "DeleteButton"
        deleteBtn.Position = UDim2.new(1, -32, 0, 14)
        deleteBtn.ZIndex = 5
    end

    -- Name label
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -16, 0, 18)
    nameLabel.Position = UDim2.new(0, 8, 0, 166)  -- Как в createSavedCard
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = isSkin and (targetPlayerOrSkin.customLabel or targetPlayerOrSkin.playerName or "Unknown") or ((targetPlayerOrSkin.DisplayName ~= "" and targetPlayerOrSkin.DisplayName) or targetPlayerOrSkin.Name)
    nameLabel.TextColor3 = C.TEXT
    nameLabel.TextSize = 13
    nameLabel.Font = FONT_BOLD
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.ZIndex = 2
    nameLabel.Parent = card

    -- Meta label для сохранённых скинов (как в createSavedCard)
    if isSkin then
        local meta = Instance.new("TextLabel")
        meta.Size = UDim2.new(1, -16, 0, 14)
        meta.Position = UDim2.new(0, 8, 0, 184)  -- Как в createSavedCard
        meta.BackgroundTransparency = 1
        meta.Text = "@" .. (targetPlayerOrSkin.playerName or "Unknown") .. "  ·  Slot " .. string.format("%02d", index)
        meta.TextColor3 = C.TEXT_MUTE
        meta.TextSize = 11
        meta.Font = FONT_REG
        meta.TextTruncate = Enum.TextTruncate.AtEnd
        meta.TextXAlignment = Enum.TextXAlignment.Left
        meta.ZIndex = 2
        meta.Parent = card
    else
        -- User label для игроков
        local userLabel = Instance.new("TextLabel")
        userLabel.Size = UDim2.new(1, -16, 0, 14)
        userLabel.Position = UDim2.new(0, 8, 0, 184)
        userLabel.BackgroundTransparency = 1
        userLabel.Text = (targetPlayerOrSkin == player) and ("@" .. targetPlayerOrSkin.Name .. "  ·  YOU") or ("@" .. targetPlayerOrSkin.Name)
        userLabel.TextColor3 = C.TEXT_MUTE
        userLabel.TextSize = 11
        userLabel.Font = FONT_REG
        userLabel.TextTruncate = Enum.TextTruncate.AtEnd
        userLabel.TextXAlignment = Enum.TextXAlignment.Left
        userLabel.ZIndex = 2
        userLabel.Parent = card
    end

    -- Click overlay поверх карточки (не родитель — чтобы ViewportFrame корректно рендерил)
    local clicker = Instance.new("TextButton")
    clicker.Name = "Clicker"
    clicker.Size = UDim2.fromScale(1, 1)
    clicker.BackgroundTransparency = 1
    clicker.Text = ""
    clicker.AutoButtonColor = false
    clicker.ZIndex = 10
    clicker.Parent = card
    if onClick then
        clicker.MouseButton1Click:Connect(onClick)
    end

    return card, cardStroke
    end -- close do block
end

-- ============= SKINS PANEL (model + tabbed list) =============
function buildSkinsContent(sg, onDragStart, onDragInput, onDragEnd)
    do -- block to limit locals scope
    local root = wmPanelRoot(sg, onDragStart, onDragInput, onDragEnd)

    -- ===== TITLE =====
