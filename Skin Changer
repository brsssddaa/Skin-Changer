local preservedFlipRotation = 0  -- Preserve flip rotation state when rebuilding panels
local flipAnimationConnection = nil  -- Track active flip animation to cancel it

-- Shared flip animation helper (used by Swap button and Back button)
local function runFlipAnim(sg, worldPanelsRef)
    if flipAnimationConnection then
        flipAnimationConnection:Disconnect()
        flipAnimationConnection = nil
    end
    local part = sg.Adornee
    if not part then return end
    for _, p in ipairs(worldPanelsRef) do
        if p.part == part then
            local startRotation = p.flipRotation or 0
            local targetRotation = startRotation + math.pi
            local startTime = tick()
            flipAnimationConnection = RunService.RenderStepped:Connect(function()
                local progress = math.min((tick() - startTime) / 0.6, 1)
                local overshoot = 1.70158
                local eased
                if progress < 0.5 then
                    eased = 0.5 * ((2 * progress) ^ 2 * ((overshoot + 1) * 2 * progress - overshoot))
                else
                    eased = 0.5 * ((2 * progress - 2) ^ 2 * ((overshoot + 1) * (2 * progress - 2) + overshoot) + 2)
                end
                p.flipRotation = startRotation + (targetRotation - startRotation) * eased
                preservedFlipRotation = p.flipRotation
                if progress >= 1 then
                    if flipAnimationConnection then flipAnimationConnection:Disconnect(); flipAnimationConnection = nil end
                    p.flipRotation = targetRotation
                    preservedFlipRotation = targetRotation
                end
            end)
            return
        end
    end
end
