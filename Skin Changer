-- Immediate teardown without tweens (used for preset swapping)
function removeShaderImmediate()
    if not shaderActive then return end
    shaderActive = false
    activeShaderPreset = nil

    for key, conn in pairs(shaderConnections) do
        pcall(function() conn:Disconnect() end)
        shaderConnections[key] = nil
    end

    -- Destroy effects synchronously
    for _, name in ipairs({"SkinChanger_Atmosphere", "SkinChanger_SunRays", "SkinChanger_Bloom", "SkinChanger_ColorCorrection"}) do
        local eff = Lighting:FindFirstChild(name)
        if eff then pcall(function() eff:Destroy() end) end
    end
    shaderEffects = {}

    if shaderGodRaysFolder then
        pcall(function() shaderGodRaysFolder:Destroy() end)
        shaderGodRaysFolder = nil
    end
    -- NOTE: we intentionally do NOT restore lighting originals here,
    -- because a new preset will overwrite them right after.
end

local function removeShader()
    if not shaderActive then return end
    shaderActive = false
    activeShaderPreset = nil
    
    for key, conn in pairs(shaderConnections) do
        pcall(function() conn:Disconnect() end)
        shaderConnections[key] = nil
    end
    
    local d = 1.0
    
    if shaderOriginals then
        for prop, value in pairs(shaderOriginals) do
            if prop ~= "GlobalShadows" then
                tweenLightingProp(prop, value, d)
            else
                pcall(function() Lighting.GlobalShadows = value end)
            end
        end
    end
    
    task.delay(d + 0.1, function()
        for _, name in ipairs({"SkinChanger_Atmosphere", "SkinChanger_SunRays", "SkinChanger_Bloom", "SkinChanger_ColorCorrection"}) do
            local eff = Lighting:FindFirstChild(name)
            if eff then pcall(function() eff:Destroy() end) end
        end
        shaderEffects = {}
    end)
    
    if shaderEffects.sunRays then
        pcall(function() TweenService:Create(shaderEffects.sunRays, TweenInfo.new(d), {Intensity = 0}):Play() end)
    end
    if shaderEffects.bloom then
        pcall(function() TweenService:Create(shaderEffects.bloom, TweenInfo.new(d), {Intensity = 0}):Play() end)
    end
    if shaderEffects.cc then
        pcall(function() TweenService:Create(shaderEffects.cc, TweenInfo.new(d), {
            TintColor = Color3.fromRGB(255, 255, 255),
            Saturation = 0,
            Contrast = 0,
        }):Play() end)
    end
    if shaderEffects.atmosphere then
        pcall(function() TweenService:Create(shaderEffects.atmosphere, TweenInfo.new(d), {Density = 0, Glare = 0, Haze = 0}):Play() end)
    end
    
    if shaderGodRaysFolder then
        pcall(function() shaderGodRaysFolder:Destroy() end)
        shaderGodRaysFolder = nil
    end

    -- Clear originals so next apply captures fresh Lighting (user may have changed game state)
    shaderOriginals = nil

    -- Persist: no shader
    pcall(function() scUpdateSetting("shaderPreset", nil) end)
end

