        ColorSequenceKeypoint.new(1.0, C.BG_CARD),
    }, 135)
    applyArtDecoCorners(card, 12, 1, nil, 4)

    local viewport = Instance.new("ViewportFrame")
    viewport.Size = UDim2.new(1, -16, 0, 150)
    viewport.Position = UDim2.new(0, 8, 0, 8)
    viewport.BackgroundColor3 = C.BLACK
    viewport.BackgroundTransparency = 0.05
    viewport.BorderSizePixel = 0
    viewport.ClipsDescendants = true
    viewport.ZIndex = 2
    viewport.Ambient = Color3.fromRGB(200, 200, 220)
    viewport.LightColor = Color3.fromRGB(255, 255, 255)
    viewport.LightDirection = Vector3.new(-0.5, -1, -0.5)
    viewport.Parent = card
    corner(viewport, 8)
    local vpStroke = stroke(viewport, Theme.dark, 1, 0.6)
    themeStrokeC(vpStroke, "dark")

    local cam = Instance.new("Camera")
    cam.Parent = viewport
    viewport.CurrentCamera = cam

    local light = Instance.new("PointLight")
    light.Brightness = 2; light.Range = 20; light.Parent = cam

    -- Рендерим через buildViewportFromCharacter для сохранения аксессуаров
    local viewportOk = false
    local charSource
    if targetPlayer == player then
        charSource = originalPlayerCharacter or player.Character
    else
        charSource = targetPlayer.Character
    end
    if charSource then
        viewportOk = buildViewportFromCharacter(viewport, charSource)
    end
    -- Fallback: live-клон если buildSkinModel не сработал
    if not viewportOk then
        local charSource
        if targetPlayer == player then
            charSource = originalPlayerCharacter or player.Character
        else
            charSource = targetPlayer.Character
        end
        if charSource then
            viewportOk = buildViewportFromCharacter(viewport, charSource)
        end
    end
    if not viewportOk then
        viewport:Destroy()
        makeAvatarFallback(card, targetPlayer.UserId)
    end

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -16, 0, 18)
    nameLabel.Position = UDim2.new(0, 8, 0, 166)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = targetPlayer.DisplayName ~= "" and targetPlayer.DisplayName or targetPlayer.Name
    nameLabel.TextColor3 = C.TEXT
    nameLabel.TextSize = 13
    nameLabel.Font = FONT_BOLD
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.ZIndex = 2
    nameLabel.Parent = card

    local userLabel = Instance.new("TextLabel")
    userLabel.Size = UDim2.new(1, -16, 0, 14)
    userLabel.Position = UDim2.new(0, 8, 0, 184)
    userLabel.BackgroundTransparency = 1
    userLabel.Text = (targetPlayer == player) and ("@" .. targetPlayer.Name .. "  ·  YOU") or ("@" .. targetPlayer.Name)
    userLabel.TextColor3 = C.TEXT_MUTE
    userLabel.TextSize = 11
    userLabel.Font = FONT_REG
    userLabel.TextTruncate = Enum.TextTruncate.AtEnd
    userLabel.TextXAlignment = Enum.TextXAlignment.Left
    userLabel.ZIndex = 2
    userLabel.Parent = card

    local applyBtn = Instance.new("TextButton")
    applyBtn.Name = "ApplyButton"
    applyBtn.Size = UDim2.new(1, -16, 0, 32)
    applyBtn.Position = UDim2.new(0, 8, 1, -40)
    applyBtn.Text = (targetPlayer == player) and "RESTORE" or "APPLY"
    applyBtn.TextSize = 11
    applyBtn.Font = FONT_BOLD
    applyBtn.BorderSizePixel = 0
    applyBtn.ZIndex = 2
    applyBtn.Parent = card
    styleApplyButton(applyBtn)

    applyBtn.MouseButton1Click:Connect(function()
        local prev = applyBtn.Text
        applyBtn.Text = "..."
        applyBtn.AutoButtonColor = false
        task.spawn(function()
            if targetPlayer == player then
                local ok = pcall(restoreOriginalSkin)
                applyBtn.Text = ok and "✓  RESTORED" or "✕  FAIL"
            else
                local ok = pcall(function() applySkin(targetPlayer) end)
                applyBtn.Text = ok and "✓  APPLIED" or "✕  FAIL"
            end
            task.wait(1)
            if applyBtn and applyBtn.Parent then applyBtn.Text = prev end
        end)
    end)

    -- SAVE-кнопка для чужих игроков (+ → ✓)
    if targetPlayer ~= player then
        local alreadySaved = findSavedIndexByName(targetPlayer.Name) ~= nil
        local saveBtn, setSavedState = makeSaveStarButton(card, alreadySaved)

        saveBtn.MouseButton1Click:Connect(function()
            local existing = findSavedIndexByName(targetPlayer.Name)
            if existing then
                table.remove(savedSkins, existing)
            end
            local snapshot = captureSkinSnapshot(targetPlayer)
            if snapshot then
                table.insert(savedSkins, snapshot)
                setSavedState("saved")
                pcall(saveSavedSkinsToFile)
                if currentPage == "saved" and updateSavedSkinsList then
                    updateSavedSkinsList()
                end
            end
        end)
    end

    applyHoverGlow(card, cardStroke)
    return card
    end -- close do block
end

