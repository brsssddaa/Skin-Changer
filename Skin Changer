function applyHoverGlow(card, cardStroke)
    card:SetAttribute("Hovered", false)
    onTheme(function(t)
        if not card:GetAttribute("Hovered") then cardStroke.Color = t.dark end
    end)
    card.MouseEnter:Connect(function()
        card:SetAttribute("Hovered", true)
        tween(card,       0.25, {BackgroundColor3 = C.BG_CARD_H})
        tween(cardStroke, 0.25, {Color = Theme.primary, Transparency = 0.05})
    end)
    card.MouseLeave:Connect(function()
        card:SetAttribute("Hovered", false)
        tween(card,       0.25, {BackgroundColor3 = C.BG_CARD})
        tween(cardStroke, 0.25, {Color = Theme.dark, Transparency = 0.45})
    end)
end

function styleApplyButton(btn)
    btn.BackgroundColor3 = Theme.primary
    btn.TextColor3 = C.BLACK
    btn.AutoButtonColor = false
    corner(btn, 8)
    local s = stroke(btn, Theme.primary, 1.4, 0)
    gradient(btn, ColorSequence.new{
        ColorSequenceKeypoint.new(0.0, Color3.fromRGB(195, 195, 195)),
        ColorSequenceKeypoint.new(0.55, Color3.fromRGB(160, 160, 160)),
        ColorSequenceKeypoint.new(1.0, Color3.fromRGB(120, 120, 120)),
    }, 90)

    btn:SetAttribute("Hovered", false)
    onTheme(function(t)
        if not btn:GetAttribute("Hovered") then
            btn.BackgroundColor3 = t.primary
            s.Color = t.primary
        end
    end)
    btn.MouseEnter:Connect(function()
        btn:SetAttribute("Hovered", true)
        tween(btn, 0.2, {TextColor3 = C.BLACK})
        tween(s,   0.2, {Color = C.WHITE, Transparency = 0, Thickness = 2})
    end)
    btn.MouseLeave:Connect(function()
        btn:SetAttribute("Hovered", false)
        tween(btn, 0.2, {BackgroundColor3 = Theme.primary, TextColor3 = C.BLACK})
        tween(s,   0.2, {Color = Theme.primary, Transparency = 0, Thickness = 1.4})
