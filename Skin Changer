-- Функция применения сохранённого скина
local function applySavedSkin(skinData)
    if not player.Character then return end


    -- Удаляем старое
    for _, item in ipairs(player.Character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            item:Destroy()
        end
        if item:IsA("BasePart") and item.Name:sub(1, 4) == "ACC_" then
            item:Destroy()
        end
    end

    for _, part in ipairs(player.Character:GetChildren()) do
        if part:IsA("BasePart") then
            for _, child in ipairs(part:GetChildren()) do
                if (child:IsA("Weld") or child:IsA("Motor6D")) and child.Name:find("Accessory") then
                    child:Destroy()
                end
            end
        end
    end

    wait(1.5)

    -- Применяем размеры частей тела НАПРЯМУЮ (приоритет)
    if skinData.bodyPartSizes then
        for partName, sizeData in pairs(skinData.bodyPartSizes) do
            local part = player.Character:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                local newSize = Vector3.new(unpack(sizeData))
                part.Size = newSize
            end
        end

        -- Применяем повторно через задержки (на случай если игра сбрасывает)
        task.spawn(function()
            task.wait(0.5)
            for partName, sizeData in pairs(skinData.bodyPartSizes) do
                local part = player.Character:FindFirstChild(partName)
                if part and part:IsA("BasePart") then
                    part.Size = Vector3.new(unpack(sizeData))
                end
            end
        end)

        task.spawn(function()
            task.wait(1.5)
            for partName, sizeData in pairs(skinData.bodyPartSizes) do
                local part = player.Character:FindFirstChild(partName)
                if part and part:IsA("BasePart") then
                    part.Size = Vector3.new(unpack(sizeData))
                end
            end
        end)
    end

    -- Применяем Humanoid scales (если есть)
    local myHumanoid = player.Character:FindFirstChild("Humanoid")
    if myHumanoid and skinData.bodyScales then
        pcall(function()
            if skinData.bodyScales.BodyDepthScale and myHumanoid:FindFirstChild("BodyDepthScale") then
                myHumanoid.BodyDepthScale.Value = skinData.bodyScales.BodyDepthScale
            end
            if skinData.bodyScales.BodyWidthScale and myHumanoid:FindFirstChild("BodyWidthScale") then
                myHumanoid.BodyWidthScale.Value = skinData.bodyScales.BodyWidthScale
            end
            if skinData.bodyScales.BodyHeightScale and myHumanoid:FindFirstChild("BodyHeightScale") then
                myHumanoid.BodyHeightScale.Value = skinData.bodyScales.BodyHeightScale
            end
            if skinData.bodyScales.HeadScale and myHumanoid:FindFirstChild("HeadScale") then
                myHumanoid.HeadScale.Value = skinData.bodyScales.HeadScale
            end
        end)
    end

    -- Применяем одежду
    for _, clothItem in ipairs(skinData.clothes) do
        local clone = clothItem:Clone()
        clone.Parent = player.Character
    end

    -- Применяем Body Colors
    if skinData.bodyColors then
        local myBodyColors = player.Character:FindFirstChild("Body Colors")
        if not myBodyColors then
            myBodyColors = Instance.new("BodyColors")
            myBodyColors.Parent = player.Character
        end
        myBodyColors.HeadColor3 = skinData.bodyColors.HeadColor3
        myBodyColors.LeftArmColor3 = skinData.bodyColors.LeftArmColor3
        myBodyColors.LeftLegColor3 = skinData.bodyColors.LeftLegColor3
        myBodyColors.RightArmColor3 = skinData.bodyColors.RightArmColor3
        myBodyColors.RightLegColor3 = skinData.bodyColors.RightLegColor3
        myBodyColors.TorsoColor3 = skinData.bodyColors.TorsoColor3

        -- Применяем цвета напрямую к частям тела (для игр где BodyColors не работает)
        local bodyParts = {
            {name = "Head", color = skinData.bodyColors.HeadColor3},
            {name = "LeftUpperArm", color = skinData.bodyColors.LeftArmColor3},
            {name = "LeftLowerArm", color = skinData.bodyColors.LeftArmColor3},
            {name = "LeftHand", color = skinData.bodyColors.LeftArmColor3},
            {name = "RightUpperArm", color = skinData.bodyColors.RightArmColor3},
            {name = "RightLowerArm", color = skinData.bodyColors.RightArmColor3},
            {name = "RightHand", color = skinData.bodyColors.RightArmColor3},
            {name = "LeftUpperLeg", color = skinData.bodyColors.LeftLegColor3},
            {name = "LeftLowerLeg", color = skinData.bodyColors.LeftLegColor3},
            {name = "LeftFoot", color = skinData.bodyColors.LeftLegColor3},
            {name = "RightUpperLeg", color = skinData.bodyColors.RightLegColor3},
            {name = "RightLowerLeg", color = skinData.bodyColors.RightLegColor3},
            {name = "RightFoot", color = skinData.bodyColors.RightLegColor3},
            {name = "UpperTorso", color = skinData.bodyColors.TorsoColor3},
            {name = "LowerTorso", color = skinData.bodyColors.TorsoColor3},
            {name = "Torso", color = skinData.bodyColors.TorsoColor3},
            {name = "Left Arm", color = skinData.bodyColors.LeftArmColor3},
            {name = "Right Arm", color = skinData.bodyColors.RightArmColor3},
            {name = "Left Leg", color = skinData.bodyColors.LeftLegColor3},
            {name = "Right Leg", color = skinData.bodyColors.RightLegColor3}
        }

        for _, partData in ipairs(bodyParts) do
            local part = player.Character:FindFirstChild(partData.name)
            if part and part:IsA("BasePart") then
                part.Color = partData.color
            end
        end
    end

    -- Применяем лицо
    local myHead = player.Character:FindFirstChild("Head")
    if myHead then
        -- Удаляем старое лицо
        local oldFace = myHead:FindFirstChild("face")
        if oldFace then
            oldFace:Destroy()
        end

        -- Применяем новое лицо если есть
        if skinData.face then
            local myFace = Instance.new("Decal")
            myFace.Name = "face"
            myFace.Face = Enum.NormalId.Front
            myFace.Texture = skinData.face
            myFace.Parent = myHead
        end
    end

    -- Применяем Head Mesh
    if skinData.headMesh then
        local myHead = player.Character:FindFirstChild("Head")
        if myHead then
            local oldMesh = myHead:FindFirstChildOfClass("SpecialMesh")
            if oldMesh then oldMesh:Destroy() end
            local newMesh = skinData.headMesh:Clone()
            newMesh.Parent = myHead
        end
    end

    -- Применяем CharacterMesh
    for _, item in ipairs(player.Character:GetChildren()) do
        if item:IsA("CharacterMesh") then
            item:Destroy()
        end
    end
    for _, meshItem in ipairs(skinData.characterMeshes) do
        local clone = meshItem:Clone()
        clone.Parent = player.Character
    end

    -- Применяем меши частей тела (НОВЫЙ МЕТОД - самый важный!)
    if skinData.bodyPartMeshes then
        for partName, meshData in pairs(skinData.bodyPartMeshes) do
            local part = player.Character:FindFirstChild(partName)
            if part then
                if meshData.Type == "MeshPart" and part:IsA("MeshPart") then
                    -- Применяем MeshId к MeshPart
                    part.MeshId = meshData.MeshId
                    if meshData.TextureID then
                        part.TextureID = meshData.TextureID
                    end
                    if meshData.Size then
                        part.Size = Vector3.new(unpack(meshData.Size))
                    end
                elseif meshData.Type == "SpecialMesh" and part:IsA("BasePart") then
                    -- Удаляем старый меш и создаём новый
                    local oldMesh = part:FindFirstChildOfClass("SpecialMesh")
                    if oldMesh then oldMesh:Destroy() end

                    local newMesh = Instance.new("SpecialMesh")
                    newMesh.MeshType = Enum.MeshType.FileMesh
                    newMesh.MeshId = meshData.MeshId
                    newMesh.TextureId = meshData.TextureId or ""
                    if meshData.Scale then
                        newMesh.Scale = Vector3.new(unpack(meshData.Scale))
                    end
                    newMesh.Parent = part

                    if meshData.Size then
                        part.Size = Vector3.new(unpack(meshData.Size))
                    end
                end
            end
        end
    end

    -- Применяем аксессуары
    local accessoryCount = 0

    for i, accessory in ipairs(skinData.accessories) do
        local success, errorMsg = pcall(function()
            -- Проверяем тип: объект или таблица данных
            if type(accessory) == "table" then
                -- Это данные из файла (таблица)
                if not accessory.MeshId or accessory.MeshId == "" then
                    return
                end

                if not accessory.AttachmentName or accessory.AttachmentName == "" then
                    return
                end

                -- ВСЕГДА создаём Part с SpecialMesh (безопаснее чем MeshPart)
                local visualHandle = Instance.new("Part")
                visualHandle.Name = "ACC_" .. (accessory.Name or "Accessory")

                -- Для MeshPart используем маленький размер Part, размер контролируется мешем
                if accessory.IsMeshPart then
                    visualHandle.Size = Vector3.new(0.2, 0.2, 0.2)
                else
                    visualHandle.Size = Vector3.new(unpack(accessory.HandleSize or {1, 1, 1}))
                end

                visualHandle.Transparency = accessory.HandleTransparency or 0
                visualHandle.CanCollide = false
                visualHandle.Massless = true
                visualHandle.Anchored = true

                -- Создаём SpecialMesh
                local mesh = Instance.new("SpecialMesh")
                mesh.MeshType = Enum.MeshType.FileMesh
                mesh.MeshId = accessory.MeshId
                mesh.TextureId = accessory.TextureId or ""
                mesh.Scale = Vector3.new(unpack(accessory.MeshScale or {1, 1, 1}))
                mesh.Parent = visualHandle

                -- Ищем соответствующий Attachment на персонаже
                local myAttachment = nil
                local myPart = nil

                for _, part in ipairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        local att = part:FindFirstChild(accessory.AttachmentName)
                        if att then
                            myAttachment = att
                            myPart = part
                            break
                        end
                    end
                end

                if not myAttachment then
                    return
                end

                visualHandle.Parent = player.Character

                -- Восстанавливаем CFrame из сохранённых данных
                local offset = CFrame.new(0, 0, 0)
                if accessory.AttachmentCFrame and #accessory.AttachmentCFrame == 12 then
                    offset = CFrame.new(unpack(accessory.AttachmentCFrame))
                end

                -- Обновляем позицию каждый кадр
                RunService.RenderStepped:Connect(function()
                    if not visualHandle.Parent or not myPart.Parent then return end

                    local currentAtt = myPart:FindFirstChild(myAttachment.Name)
                    if currentAtt then
                        visualHandle.CFrame = currentAtt.WorldCFrame * offset:Inverse()
                    end
                end)

                accessoryCount = accessoryCount + 1

            else
                -- Это объект Accessory (из памяти)
                local handle = accessory:FindFirstChild("Handle", true)

                if not handle then
                    return
                end

                local handleAttachment = handle:FindFirstChildOfClass("Attachment")
                if not handleAttachment then
                    return
                end

                -- Ищем соответствующий Attachment на персонаже
                local myAttachment = nil
                local myPart = nil

                for _, part in ipairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        local att = part:FindFirstChild(handleAttachment.Name)
                        if att then
                            myAttachment = att
                            myPart = part
                            break
                        end
                    end
                end

                if not myAttachment then
                    return
                end

                -- Клонируем Handle
                local visualHandle = handle:Clone()
                visualHandle.Name = "ACC_" .. accessory.Name
                visualHandle.CanCollide = false
                visualHandle.Massless = true
                visualHandle.Anchored = true

                -- Удаляем всё лишнее
                for _, child in ipairs(visualHandle:GetChildren()) do
                    if not child:IsA("SpecialMesh") and not child:IsA("Decal") and not child:IsA("Texture") and not child:IsA("SurfaceAppearance") then
                        child:Destroy()
                    end
                end

                visualHandle.Parent = player.Character

                -- Сохраняем offset
                local offset = handleAttachment.CFrame

                -- Обновляем позицию каждый кадр
                RunService.RenderStepped:Connect(function()
                    if not visualHandle.Parent or not myPart.Parent then return end

                    local currentAtt = myPart:FindFirstChild(myAttachment.Name)
                    if currentAtt then
                        visualHandle.CFrame = currentAtt.WorldCFrame * offset:Inverse()
                    end
                end)

                accessoryCount = accessoryCount + 1
            end
        end)

        if not success then
        end
    end

    -- Меняем иконку
    avatarImage.Image = "rbxthumb://type=AvatarHeadShot&id=" .. skinData.userId .. "&w=150&h=150"

end

-- ФУНКЦИЯ ПРИМЕНЕНИЯ СКИНА (С ПРАВИЛЬНЫМ КОПИРОВАНИЕМ АКСЕССУАРОВ)
local function applySkin(targetPlayer)
    if not player.Character then return end

    local targetChar = targetPlayer.Character
    if not targetChar then
        return
    end

    -- Проверка что персонаж цели полностью загружен
    if not targetChar:FindFirstChild("Humanoid") or not targetChar:FindFirstChild("Head") then
        return
    end

    -- Сохраняем выбранного игрока для переприменения после смерти
    lastAppliedPlayer = targetPlayer

    -- Сохраняем данные скина для применения даже если игрок выйдет
    savedSkinData = {
        playerName = targetPlayer.Name,
        userId = targetPlayer.UserId,
        clothes = {},
        bodyColors = nil,
        face = nil,
        headMesh = nil,
        characterMeshes = {},
        accessories = {}
    }

    -- Сохраняем одежду
    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            table.insert(savedSkinData.clothes, item:Clone())
        end
    end

    -- Сохраняем Body Colors
    local targetBodyColors = targetChar:FindFirstChild("Body Colors")
    if targetBodyColors then
        savedSkinData.bodyColors = {
            HeadColor3 = targetBodyColors.HeadColor3,
            LeftArmColor3 = targetBodyColors.LeftArmColor3,
            LeftLegColor3 = targetBodyColors.LeftLegColor3,
            RightArmColor3 = targetBodyColors.RightArmColor3,
            RightLegColor3 = targetBodyColors.RightLegColor3,
            TorsoColor3 = targetBodyColors.TorsoColor3
        }
    end

    -- Сохраняем лицо
    local targetHead = targetChar:FindFirstChild("Head")
    if targetHead then
        local targetFace = targetHead:FindFirstChild("face")
        if targetFace then
            savedSkinData.face = targetFace.Texture
        end

        local targetMesh = targetHead:FindFirstChildOfClass("SpecialMesh")
        if targetMesh then
            savedSkinData.headMesh = targetMesh:Clone()
        end
    end

    -- Сохраняем CharacterMesh
    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("CharacterMesh") then
            table.insert(savedSkinData.characterMeshes, item:Clone())
        end
    end

    -- Сохраняем аксессуары
    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("Accessory") then
            table.insert(savedSkinData.accessories, item:Clone())
        end
    end


    -- Удаляем ВСЕ старые аксессуары и соединения полностью
    for _, item in ipairs(player.Character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            item:Destroy()
        end
        -- Удаляем старые визуальные аксессуары
        if item:IsA("BasePart") and item.Name:sub(1, 4) == "ACC_" then
            item:Destroy()
        end
    end

    -- Удаляем все старые Weld и Motor6D которые могут быть от аксессуаров
    for _, part in ipairs(player.Character:GetChildren()) do
        if part:IsA("BasePart") then
            for _, child in ipairs(part:GetChildren()) do
                if (child:IsA("Weld") or child:IsA("Motor6D")) and child.Name:find("Accessory") then
                    child:Destroy()
                end
            end
        end
    end

    wait(1.5)

    -- 1. Одежда
    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            local clone = item:Clone()
            clone.Parent = player.Character
        end
    end

    -- 2. Body Colors
    local targetBodyColors = targetChar:FindFirstChild("Body Colors")
    if targetBodyColors then
        local myBodyColors = player.Character:FindFirstChild("Body Colors")
        if not myBodyColors then
            myBodyColors = Instance.new("BodyColors")
            myBodyColors.Parent = player.Character
        end

        myBodyColors.HeadColor3 = targetBodyColors.HeadColor3
        myBodyColors.LeftArmColor3 = targetBodyColors.LeftArmColor3
        myBodyColors.LeftLegColor3 = targetBodyColors.LeftLegColor3
        myBodyColors.RightArmColor3 = targetBodyColors.RightArmColor3
        myBodyColors.RightLegColor3 = targetBodyColors.RightLegColor3
        myBodyColors.TorsoColor3 = targetBodyColors.TorsoColor3

        -- Применяем цвета напрямую к частям тела (для игр где BodyColors не работает)
        local bodyParts = {
            {name = "Head", color = targetBodyColors.HeadColor3},
            {name = "LeftUpperArm", color = targetBodyColors.LeftArmColor3},
            {name = "LeftLowerArm", color = targetBodyColors.LeftArmColor3},
            {name = "LeftHand", color = targetBodyColors.LeftArmColor3},
            {name = "RightUpperArm", color = targetBodyColors.RightArmColor3},
            {name = "RightLowerArm", color = targetBodyColors.RightArmColor3},
            {name = "RightHand", color = targetBodyColors.RightArmColor3},
            {name = "LeftUpperLeg", color = targetBodyColors.LeftLegColor3},
            {name = "LeftLowerLeg", color = targetBodyColors.LeftLegColor3},
            {name = "LeftFoot", color = targetBodyColors.LeftLegColor3},
            {name = "RightUpperLeg", color = targetBodyColors.RightLegColor3},
            {name = "RightLowerLeg", color = targetBodyColors.RightLegColor3},
            {name = "RightFoot", color = targetBodyColors.RightLegColor3},
            {name = "UpperTorso", color = targetBodyColors.TorsoColor3},
            {name = "LowerTorso", color = targetBodyColors.TorsoColor3},
            {name = "Torso", color = targetBodyColors.TorsoColor3},
            {name = "Left Arm", color = targetBodyColors.LeftArmColor3},
            {name = "Right Arm", color = targetBodyColors.RightArmColor3},
            {name = "Left Leg", color = targetBodyColors.LeftLegColor3},
            {name = "Right Leg", color = targetBodyColors.RightLegColor3}
        }

        for _, partData in ipairs(bodyParts) do
            local part = player.Character:FindFirstChild(partData.name)
            if part and part:IsA("BasePart") then
                part.Color = partData.color
            end
        end
    end

    -- 3. Лицо
    local myHead = player.Character:FindFirstChild("Head")
    local targetHead = targetChar:FindFirstChild("Head")

    if myHead and targetHead then
        -- Удаляем старое лицо
        local oldFace = myHead:FindFirstChild("face")
        if oldFace then
            oldFace:Destroy()
        end

        -- Применяем новое лицо
        local targetFace = targetHead:FindFirstChild("face")
        if targetFace then
            local myFace = Instance.new("Decal")
            myFace.Name = "face"
            myFace.Face = Enum.NormalId.Front
            myFace.Texture = targetFace.Texture
            myFace.Parent = myHead
        end

        -- Mesh головы
        local targetMesh = targetHead:FindFirstChildOfClass("SpecialMesh")
        if targetMesh then
            local myMesh = myHead:FindFirstChildOfClass("SpecialMesh")
            if myMesh then
                myMesh:Destroy()
            end
            local cloneMesh = targetMesh:Clone()
            cloneMesh.Parent = myHead
        end
    end

    -- 4. CharacterMesh
    for _, item in ipairs(player.Character:GetChildren()) do
        if item:IsA("CharacterMesh") then
            item:Destroy()
        end
    end

    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("CharacterMesh") then
            local clone = item:Clone()
            clone.Parent = player.Character
        end
    end

    -- 5. АКСЕССУАРЫ (применяем из сохранённых клонов)
    local accessoryCount = 0

    if player.Character and savedSkinData and savedSkinData.accessories then
        for _, accessory in ipairs(savedSkinData.accessories) do
            pcall(function()
                -- accessory это клонированный Accessory объект
                local handle = accessory:FindFirstChild("Handle", true)

                if not handle then
                    return
                end

                -- Ищем Attachment в Handle
                local handleAttachment = handle:FindFirstChildOfClass("Attachment")
                if not handleAttachment then
                    return
                end

                -- Ищем соответствующий Attachment на МОЁМ персонаже
                local myAttachment = nil
                local myPart = nil

                for _, part in ipairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        local att = part:FindFirstChild(handleAttachment.Name)
                        if att then
                            myAttachment = att
                            myPart = part
                            break
                        end
                    end
                end

                if not myAttachment then
                    return
                end

                -- Клонируем Handle
                local visualHandle = handle:Clone()
                visualHandle.Name = "ACC_" .. accessory.Name
                visualHandle.CanCollide = false
                visualHandle.Massless = true
                visualHandle.Anchored = true

                -- Удаляем всё лишнее
                for _, child in ipairs(visualHandle:GetChildren()) do
                    if not child:IsA("SpecialMesh") and not child:IsA("Decal") and not child:IsA("Texture") and not child:IsA("SurfaceAppearance") then
                        child:Destroy()
                    end
                end

                visualHandle.Parent = player.Character

                -- Сохраняем offset для этого аксессуара
                local offset = handleAttachment.CFrame

                -- Обновляем позицию каждый кадр относительно МОЕЙ части тела
                RunService.RenderStepped:Connect(function()
                    if not visualHandle.Parent or not myPart.Parent then return end

                    local currentAtt = myPart:FindFirstChild(myAttachment.Name)
                    if currentAtt then
                        visualHandle.CFrame = currentAtt.WorldCFrame * offset:Inverse()
                    end
                end)

                accessoryCount = accessoryCount + 1
            end)
        end
    end

    -- Сохраняем размеры тела оригинального игрока
    local targetHumanoid = targetChar:FindFirstChild("Humanoid")
    local myHumanoid = player.Character:FindFirstChild("Humanoid")
    if myHumanoid and targetHumanoid then
        pcall(function()
            if targetHumanoid:FindFirstChild("BodyDepthScale") and myHumanoid:FindFirstChild("BodyDepthScale") then
                myHumanoid.BodyDepthScale.Value = targetHumanoid.BodyDepthScale.Value
            end
            if targetHumanoid:FindFirstChild("BodyWidthScale") and myHumanoid:FindFirstChild("BodyWidthScale") then
                myHumanoid.BodyWidthScale.Value = targetHumanoid.BodyWidthScale.Value
            end
            if targetHumanoid:FindFirstChild("BodyHeightScale") and myHumanoid:FindFirstChild("BodyHeightScale") then
                myHumanoid.BodyHeightScale.Value = targetHumanoid.BodyHeightScale.Value
            end
            if targetHumanoid:FindFirstChild("HeadScale") and myHumanoid:FindFirstChild("HeadScale") then
                myHumanoid.HeadScale.Value = targetHumanoid.HeadScale.Value
            end
        end)
    end

    -- Меняем иконку
    avatarImage.Image = "rbxthumb://type=AvatarHeadShot&id=" .. targetPlayer.UserId .. "&w=150&h=150"

end

-- Функция создания карточки игрока с 3D моделью
local function createPlayerButton(targetPlayer)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 1, 0)
    card.BackgroundColor3 = Color3.fromRGB(28, 28, 35)
    card.BackgroundTransparency = 0.2
    card.BorderSizePixel = 0
    card.Parent = playersList

    local cardCorner = Instance.new("UICorner")
    cardCorner.CornerRadius = UDim.new(0, 10)
    cardCorner.Parent = card

    -- ViewportFrame для 3D модели
    local viewport = Instance.new("ViewportFrame")
    viewport.Size = UDim2.new(1, 0, 0, 130)
    viewport.BackgroundTransparency = 1
    viewport.Parent = card

    -- Камера для viewport
    local camera = Instance.new("Camera")
    camera.Parent = viewport
    viewport.CurrentCamera = camera

    -- Освещение
    local light = Instance.new("PointLight")
    light.Brightness = 2
    light.Range = 20
    light.Parent = camera

    -- Клонируем персонажа игрока
    local charToClone = nil

    if targetPlayer == player then
        -- Для локального игрока используем оригинальный персонаж если он есть
        if originalPlayerCharacter then
            charToClone = originalPlayerCharacter
        else
            charToClone = player.Character
        end
    else
        charToClone = targetPlayer.Character
    end

    if charToClone then
        local success, err = pcall(function()
            local charClone = charToClone:Clone()

            if not charClone then
                -- Если клонирование не удалось, показываем аватарку
                local avatarImg = Instance.new("ImageLabel")
                avatarImg.Size = UDim2.new(1, 0, 0, 130)
                avatarImg.BackgroundTransparency = 1
                avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id=" .. targetPlayer.UserId .. "&w=150&h=150"
                avatarImg.Parent = card

                local avatarCorner = Instance.new("UICorner")
                avatarCorner.CornerRadius = UDim.new(0, 10)
                avatarCorner.Parent = avatarImg
                return
            end

            -- Удаляем скрипты
            for _, item in ipairs(charClone:GetDescendants()) do
                if item:IsA("Script") or item:IsA("LocalScript") then
                    item:Destroy()
                end
            end

            charClone.Parent = viewport

            -- Вычисляем размер персонажа
            local humanoidRootPart = charClone:FindFirstChild("HumanoidRootPart")
            if humanoidRootPart then
                local cf, size = charClone:GetBoundingBox()
                local distance = size.Y * 1.5
                camera.CFrame = CFrame.new(cf.Position + Vector3.new(2, size.Y * 0.3, distance), cf.Position + Vector3.new(0, size.Y * 0.2, 0))
                camera.FieldOfView = 30
                humanoidRootPart.CFrame = CFrame.new(cf.Position) * CFrame.Angles(0, math.rad(-20), 0)
            end
        end)

        if not success then
            -- При ошибке показываем аватарку
            local avatarImg = Instance.new("ImageLabel")
            avatarImg.Size = UDim2.new(1, 0, 0, 130)
            avatarImg.BackgroundTransparency = 1
            avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id=" .. targetPlayer.UserId .. "&w=150&h=150"
            avatarImg.Parent = card

            local avatarCorner = Instance.new("UICorner")
            avatarCorner.CornerRadius = UDim.new(0, 10)
            avatarCorner.Parent = avatarImg
        end
    else
        -- Если нет персонажа, показываем аватарку
        local avatarImg = Instance.new("ImageLabel")
        avatarImg.Size = UDim2.new(1, 0, 0, 130)
        avatarImg.BackgroundTransparency = 1
        avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id=" .. targetPlayer.UserId .. "&w=150&h=150"
        avatarImg.Parent = card

        local avatarCorner = Instance.new("UICorner")
        avatarCorner.CornerRadius = UDim.new(0, 10)
        avatarCorner.Parent = avatarImg
    end

    -- Имя игрока
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0, 40)
    nameLabel.Position = UDim2.new(0, 0, 1, -40)
    nameLabel.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    nameLabel.BackgroundTransparency = 0.3
    nameLabel.Text = targetPlayer.Name
    nameLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 12
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    nameLabel.Parent = card

    local nameCorner = Instance.new("UICorner")
    nameCorner.CornerRadius = UDim.new(0, 8)
    nameCorner.Parent = nameLabel

    -- Кнопка для клика
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 1, 0)
    button.BackgroundTransparency = 1
    button.Text = ""
    button.Parent = card

    button.MouseEnter:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(35, 35, 42),
            BackgroundTransparency = 0.1
        }):Play()
    end)

    button.MouseLeave:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(28, 28, 35),
            BackgroundTransparency = 0.2
        }):Play()
    end)

    button.MouseButton1Click:Connect(function()
        -- Если это локальный игрок, восстанавливаем оригинальный скин
        if targetPlayer == player then
            if originalPlayerCharacter then

                -- Удаляем все применённые скины
                for _, item in ipairs(player.Character:GetChildren()) do
                    if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
                        item:Destroy()
                    end
                    if item:IsA("BasePart") and item.Name:sub(1, 4) == "ACC_" then
                        item:Destroy()
                    end
                    if item:IsA("CharacterMesh") then
                        item:Destroy()
                    end
                end

                -- Удаляем старые Weld и Motor6D от аксессуаров
                for _, part in ipairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        for _, child in ipairs(part:GetChildren()) do
                            if (child:IsA("Weld") or child:IsA("Motor6D")) and child.Name:find("Accessory") then
                                child:Destroy()
                            end
                        end
                    end
                end

                wait(0.5)

                -- Восстанавливаем одежду
                for _, item in ipairs(originalPlayerCharacter:GetChildren()) do
                    if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
                        local clone = item:Clone()
                        clone.Parent = player.Character
                    end
                end

                -- Восстанавливаем аксессуары (используем визуальный метод как в applySkin)
                local accessoryCount = 0
                for _, accessory in ipairs(originalPlayerCharacter:GetChildren()) do
                    if accessory:IsA("Accessory") then
                        pcall(function()
                            local handle = accessory:FindFirstChild("Handle", true)
                            if not handle then return end

                            local handleAttachment = handle:FindFirstChildOfClass("Attachment")
                            if not handleAttachment then return end

                            -- Ищем соответствующий Attachment на персонаже
                            local myAttachment = nil
                            local myPart = nil

                            for _, part in ipairs(player.Character:GetChildren()) do
                                if part:IsA("BasePart") then
                                    local att = part:FindFirstChild(handleAttachment.Name)
                                    if att then
                                        myAttachment = att
                                        myPart = part
                                        break
                                    end
                                end
                            end

                            if not myAttachment then return end

                            -- Клонируем Handle
                            local visualHandle = handle:Clone()
                            visualHandle.Name = "ACC_" .. accessory.Name
                            visualHandle.CanCollide = false
                            visualHandle.Massless = true
                            visualHandle.Anchored = true

                            -- Удаляем всё лишнее
                            for _, child in ipairs(visualHandle:GetChildren()) do
                                if not child:IsA("SpecialMesh") and not child:IsA("Decal") and not child:IsA("Texture") and not child:IsA("SurfaceAppearance") then
                                    child:Destroy()
                                end
                            end

                            visualHandle.Parent = player.Character

                            -- Сохраняем offset
                            local offset = handleAttachment.CFrame

                            -- Обновляем позицию каждый кадр
                            RunService.RenderStepped:Connect(function()
                                if not visualHandle.Parent or not myPart.Parent then return end

                                local currentAtt = myPart:FindFirstChild(myAttachment.Name)
                                if currentAtt then
                                    visualHandle.CFrame = currentAtt.WorldCFrame * offset:Inverse()
                                end
                            end)

                            accessoryCount = accessoryCount + 1
                        end)
                    end
                end

                -- Восстанавливаем Body Colors
                local origBodyColors = originalPlayerCharacter:FindFirstChild("Body Colors")
                if origBodyColors then
                    local myBodyColors = player.Character:FindFirstChild("Body Colors")
                    if not myBodyColors then
                        myBodyColors = Instance.new("BodyColors")
                        myBodyColors.Parent = player.Character
                    end
                    myBodyColors.HeadColor3 = origBodyColors.HeadColor3
                    myBodyColors.LeftArmColor3 = origBodyColors.LeftArmColor3
                    myBodyColors.LeftLegColor3 = origBodyColors.LeftLegColor3
                    myBodyColors.RightArmColor3 = origBodyColors.RightArmColor3
                    myBodyColors.RightLegColor3 = origBodyColors.RightLegColor3
                    myBodyColors.TorsoColor3 = origBodyColors.TorsoColor3
                end

                -- Восстанавливаем лицо
                local origHead = originalPlayerCharacter:FindFirstChild("Head")
                local myHead = player.Character:FindFirstChild("Head")
                if origHead and myHead then
                    -- Удаляем старое лицо
                    local oldFace = myHead:FindFirstChild("face")
                    if oldFace then oldFace:Destroy() end

                    local origFace = origHead:FindFirstChild("face")
                    if origFace then
                        local myFace = Instance.new("Decal")
                        myFace.Name = "face"
                        myFace.Face = Enum.NormalId.Front
                        myFace.Texture = origFace.Texture
                        myFace.Parent = myHead
                    end

                    -- Восстанавливаем Head Mesh
                    local origMesh = origHead:FindFirstChildOfClass("SpecialMesh")
                    if origMesh then
                        local myMesh = myHead:FindFirstChildOfClass("SpecialMesh")
                        if myMesh then myMesh:Destroy() end
                        local cloneMesh = origMesh:Clone()
                        cloneMesh.Parent = myHead
                    end
                end

                -- Восстанавливаем CharacterMesh
                for _, item in ipairs(originalPlayerCharacter:GetChildren()) do
                    if item:IsA("CharacterMesh") then
                        local clone = item:Clone()
                        clone.Parent = player.Character
                    end
                end

                -- Сбрасываем сохранённые данные
                savedSkinData = nil
                lastAppliedPlayer = nil

                -- Возвращаем иконку на оригинальный аватар
                avatarImage.Image = "rbxthumb://type=AvatarHeadShot&id=" .. player.UserId .. "&w=150&h=150"

            else
            end
        else
            applySkin(targetPlayer)
        end
        skinMenu.Visible = false
    end)

    -- Кнопка "Save" (только если это не локальный игрок)
    if targetPlayer ~= player then
        local saveButton = Instance.new("TextButton")
        saveButton.Size = UDim2.new(0, 50, 0, 25)
        saveButton.Position = UDim2.new(1, -55, 0, 5)
        saveButton.BackgroundColor3 = Color3.fromRGB(50, 200, 100)
        saveButton.BackgroundTransparency = 0.3
        saveButton.Text = "SAVE"
        saveButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        saveButton.Font = Enum.Font.GothamBold
        saveButton.TextSize = 10
        saveButton.ZIndex = 2
        saveButton.Parent = card

        local saveCorner = Instance.new("UICorner")
        saveCorner.CornerRadius = UDim.new(0, 6)
        saveCorner.Parent = saveButton

        -- Проверяем, сохранён ли уже этот скин
        local alreadySaved = false
        for _, savedSkin in ipairs(savedSkins) do
            if savedSkin.playerName == targetPlayer.Name then
                alreadySaved = true
                break
            end
        end

        if alreadySaved then
            saveButton.Text = "SAVED!"
            saveButton.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        end

        saveButton.MouseButton1Click:Connect(function()
            -- Проверяем существует ли уже скин этого игрока
            local existingIndex = nil
            for i, savedSkin in ipairs(savedSkins) do
                if savedSkin.playerName == targetPlayer.Name then
                    existingIndex = i
                    break
                end
            end

            if existingIndex then
                table.remove(savedSkins, existingIndex)
            end

            -- Сохраняем скин в список
            local skinData = {
                playerName = targetPlayer.Name,
                userId = targetPlayer.UserId,
                clothes = {},
                bodyColors = nil,
                face = nil,
                headMesh = nil,
                characterMeshes = {},
                accessories = {},
                characterClone = nil -- Клон персонажа для отображения
            }

            local targetChar = targetPlayer.Character
            if targetChar then
                -- Пытаемся сохранить клон персонажа для отображения
                local cloneSuccess, cloneResult = pcall(function()
                    return targetChar:Clone()
                end)

                if cloneSuccess and cloneResult then
                    skinData.characterClone = cloneResult
                else
                    skinData.characterClone = nil
                end

                -- Сохраняем одежду
                for _, item in ipairs(targetChar:GetChildren()) do
                    if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
                        table.insert(skinData.clothes, item:Clone())
                    end
                end

                -- Сохраняем Body Colors
                local targetBodyColors = targetChar:FindFirstChild("Body Colors")
                if targetBodyColors then
                    skinData.bodyColors = {
                        HeadColor3 = targetBodyColors.HeadColor3,
                        LeftArmColor3 = targetBodyColors.LeftArmColor3,
                        LeftLegColor3 = targetBodyColors.LeftLegColor3,
                        RightArmColor3 = targetBodyColors.RightArmColor3,
                        RightLegColor3 = targetBodyColors.RightLegColor3,
                        TorsoColor3 = targetBodyColors.TorsoColor3
                    }
                end

                -- Сохраняем CharacterMesh (форма частей тела)
                for _, item in ipairs(targetChar:GetChildren()) do
                    if item:IsA("CharacterMesh") then
                        table.insert(skinData.characterMeshes, item:Clone())
                    end
                end

                -- Сохраняем MeshId из самих частей тела (если есть)
                skinData.bodyPartMeshes = {}
                local bodyParts = {"Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg",
                                   "LeftUpperArm", "LeftLowerArm", "LeftHand", "RightUpperArm", "RightLowerArm", "RightHand",
                                   "LeftUpperLeg", "LeftLowerLeg", "LeftFoot", "RightUpperLeg", "RightLowerLeg", "RightFoot",
                                   "UpperTorso", "LowerTorso"}

                for _, partName in ipairs(bodyParts) do
                    local part = targetChar:FindFirstChild(partName)
                    if part then
                        -- Проверяем если это MeshPart
                        if part:IsA("MeshPart") then
                            skinData.bodyPartMeshes[partName] = {
                                Type = "MeshPart",
                                MeshId = part.MeshId,
                                TextureID = part.TextureID,
                                Size = {part.Size.X, part.Size.Y, part.Size.Z}
                            }
                        -- Проверяем если есть SpecialMesh внутри
                        elseif part:IsA("BasePart") then
                            local mesh = part:FindFirstChildOfClass("SpecialMesh")
                            if mesh then
                                skinData.bodyPartMeshes[partName] = {
                                    Type = "SpecialMesh",
                                    MeshId = mesh.MeshId,
                                    TextureId = mesh.TextureId,
                                    Scale = {mesh.Scale.X, mesh.Scale.Y, mesh.Scale.Z},
                                    Size = {part.Size.X, part.Size.Y, part.Size.Z}
                                }
                            end
                        end
                    end
                end

                -- Сохраняем размеры частей тела
                skinData.bodyPartSizes = {}
                for _, partName in ipairs(bodyParts) do
                    local part = targetChar:FindFirstChild(partName)
                    if part and part:IsA("BasePart") then
                        skinData.bodyPartSizes[partName] = {part.Size.X, part.Size.Y, part.Size.Z}
                    end
                end

                -- Также сохраняем Humanoid scales (на всякий случай)
                local targetHumanoid = targetChar:FindFirstChild("Humanoid")
                if targetHumanoid then
                    skinData.bodyScales = {}
                    if targetHumanoid:FindFirstChild("BodyDepthScale") then
                        skinData.bodyScales.BodyDepthScale = targetHumanoid.BodyDepthScale.Value
                    end
                    if targetHumanoid:FindFirstChild("BodyWidthScale") then
                        skinData.bodyScales.BodyWidthScale = targetHumanoid.BodyWidthScale.Value
                    end
                    if targetHumanoid:FindFirstChild("BodyHeightScale") then
                        skinData.bodyScales.BodyHeightScale = targetHumanoid.BodyHeightScale.Value
                    end
                    if targetHumanoid:FindFirstChild("HeadScale") then
                        skinData.bodyScales.HeadScale = targetHumanoid.HeadScale.Value
                    end
                end

                -- Сохраняем лицо
                local targetHead = targetChar:FindFirstChild("Head")
                if targetHead then
                    local targetFace = targetHead:FindFirstChild("face")
                    if targetFace then
                        skinData.face = targetFace.Texture
                    end

                    local targetMesh = targetHead:FindFirstChildOfClass("SpecialMesh")
                    if targetMesh then
                        skinData.headMesh = targetMesh:Clone()
                    end
                end

                -- Сохраняем CharacterMesh
                for _, item in ipairs(targetChar:GetChildren()) do
                    if item:IsA("CharacterMesh") then
                        table.insert(skinData.characterMeshes, item:Clone())
                    end
                end

                -- Сохраняем аксессуары
                for _, item in ipairs(targetChar:GetChildren()) do
                    if item:IsA("Accessory") then
                        table.insert(skinData.accessories, item:Clone())
                    end
                end

                table.insert(savedSkins, skinData)

                -- Визуальная обратная связь СРАЗУ
                saveButton.Text = "SAVED!"
                saveButton.BackgroundColor3 = Color3.fromRGB(100, 200, 100)

                -- Сохраняем в файл с обработкой ошибок
                local saveSuccess, saveErr = pcall(function()
                    saveSavedSkinsToFile()
                end)

                if not saveSuccess then
                    saveButton.Text = "ERROR!"
                    saveButton.BackgroundColor3 = Color3.fromRGB(200, 100, 50)
                end

                -- Обновляем список сохранённых скинов (если функция существует)
                if updateSavedSkinsList then
                    task.spawn(function()
                        task.wait(0.1)
                        updateSavedSkinsList()
                    end)
                end
            end
        end)
    end

    return card
end

-- Функция создания карточки сохранённого скина
local function createSavedSkinCard(skinData, index)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 1, 0)
    card.BackgroundColor3 = Color3.fromRGB(28, 28, 35)
    card.BackgroundTransparency = 0.2
    card.BorderSizePixel = 0
    card.Parent = savedSkinsList

    local cardCorner = Instance.new("UICorner")
    cardCorner.CornerRadius = UDim.new(0, 10)
    cardCorner.Parent = card

    -- ViewportFrame для 3D модели
    local viewport = Instance.new("ViewportFrame")
    viewport.Size = UDim2.new(1, 0, 0, 130)
    viewport.BackgroundTransparency = 1
    viewport.Parent = card

    -- Камера для viewport
    local camera = Instance.new("Camera")
    camera.Parent = viewport
    viewport.CurrentCamera = camera

    -- Освещение
    local light = Instance.new("PointLight")
    light.Brightness = 2
    light.Range = 20
    light.Parent = camera

    -- Используем сохранённый клон персонажа
    if skinData.characterClone then
        local success, err = pcall(function()
            local charClone = skinData.characterClone:Clone()

            if not charClone then
                return false
            end

            -- Удаляем скрипты
            for _, item in ipairs(charClone:GetDescendants()) do
                if item:IsA("Script") or item:IsA("LocalScript") then
                    item:Destroy()
                end
            end

            charClone.Parent = viewport

            -- Позиционируем камеру
            local humanoidRootPart = charClone:FindFirstChild("HumanoidRootPart")
            if humanoidRootPart then
                local cf, size = charClone:GetBoundingBox()
                local distance = size.Y * 1.5
                camera.CFrame = CFrame.new(cf.Position + Vector3.new(2, size.Y * 0.3, distance), cf.Position + Vector3.new(0, size.Y * 0.2, 0))
                camera.FieldOfView = 30
                humanoidRootPart.CFrame = CFrame.new(cf.Position) * CFrame.Angles(0, math.rad(-20), 0)
            end
            return true
        end)

        if not success or err == false then
            -- Показываем аватар как fallback
            local avatarImg = Instance.new("ImageLabel")
            avatarImg.Size = UDim2.new(1, 0, 0, 130)
            avatarImg.BackgroundTransparency = 1
            avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id=" .. skinData.userId .. "&w=150&h=150"
            avatarImg.Parent = card

            local avatarCorner = Instance.new("UICorner")
            avatarCorner.CornerRadius = UDim.new(0, 10)
            avatarCorner.Parent = avatarImg
        end
    else
        -- Если нет клона, показываем аватар
        local avatarImg = Instance.new("ImageLabel")
        avatarImg.Size = UDim2.new(1, 0, 0, 130)
        avatarImg.BackgroundTransparency = 1
        avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id=" .. skinData.userId .. "&w=150&h=150"
        avatarImg.Parent = card

        local avatarCorner = Instance.new("UICorner")
        avatarCorner.CornerRadius = UDim.new(0, 10)
        avatarCorner.Parent = avatarImg
    end

    -- Имя игрока
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0, 40)
    nameLabel.Position = UDim2.new(0, 0, 1, -40)
    nameLabel.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    nameLabel.BackgroundTransparency = 0.3
    nameLabel.Text = skinData.playerName
    nameLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 12
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    nameLabel.Parent = card

    local nameCorner = Instance.new("UICorner")
    nameCorner.CornerRadius = UDim.new(0, 8)
    nameCorner.Parent = nameLabel

    -- Кнопка применить
    local applyButton = Instance.new("TextButton")
    applyButton.Size = UDim2.new(1, 0, 1, 0)
    applyButton.BackgroundTransparency = 1
    applyButton.Text = ""
    applyButton.Parent = card

    applyButton.MouseEnter:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(35, 35, 42),
            BackgroundTransparency = 0.1
        }):Play()
    end)

    applyButton.MouseLeave:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(28, 28, 35),
            BackgroundTransparency = 0.2
        }):Play()
    end)

    applyButton.MouseButton1Click:Connect(function()
        -- Применяем сохранённый скин
        savedSkinData = skinData
        applySavedSkin(skinData)
        savedSkinsMenu.Visible = false
    end)

    -- Кнопка удалить
    local deleteButton = Instance.new("TextButton")
    deleteButton.Size = UDim2.new(0, 50, 0, 25)
    deleteButton.Position = UDim2.new(1, -55, 0, 5)
    deleteButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    deleteButton.BackgroundTransparency = 0.3
    deleteButton.Text = "DEL"
    deleteButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    deleteButton.Font = Enum.Font.GothamBold
    deleteButton.TextSize = 10
    deleteButton.ZIndex = 2
    deleteButton.Parent = card

    local deleteCorner = Instance.new("UICorner")
    deleteCorner.CornerRadius = UDim.new(0, 6)
    deleteCorner.Parent = deleteButton

    deleteButton.MouseButton1Click:Connect(function()
        table.remove(savedSkins, index)
        saveSavedSkinsToFile()
        updateSavedSkinsList()
    end)

    return card
end

-- Функция обновления списка сохранённых скинов
local function updateSavedSkinsList()
    for _, child in ipairs(savedSkinsList:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    for i, skinData in ipairs(savedSkins) do
        createSavedSkinCard(skinData, i)
    end

    savedSkinsList.CanvasSize = UDim2.new(0, 0, 0, savedListLayout.AbsoluteContentSize.Y + 10)
end

-- Функция обновления списка игроков
local function updatePlayersList()
    for _, child in ipairs(playersList:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    -- Добавляем себя первым в список
    createPlayerButton(player)

    -- Добавляем остальных игроков
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then -- Не добавляем себя дважды
            createPlayerButton(plr)
        end
    end

    playersList.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
end

