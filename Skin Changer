function updateHeadIconViewport()
    if not headIconAvatar or not headIconAvatar.Parent then return end

    -- Try to render saved skin in ViewportFrame (matches saved skin card exactly)
    if savedSkinData and headIconViewport and headIconCamera then
        local rendered = false

        -- 1) Try buildSkinModel (works for skins loaded from disk)
        local ok1, builtModel = pcall(buildSkinModel, savedSkinData)
        if ok1 and builtModel then
            local ok2 = pcall(function()
                -- Manually place in viewport without drag/rotate
                local worldModel = headIconViewport:FindFirstChildOfClass("WorldModel")
                if not worldModel then
                    worldModel = Instance.new("WorldModel")
                    worldModel.Parent = headIconViewport
                end
                for _, c in ipairs(worldModel:GetChildren()) do c:Destroy() end
                if builtModel.PrimaryPart then
                    builtModel:PivotTo(CFrame.new(0, 0, 0))
                end
                builtModel.Parent = worldModel
                return true
            end)
            if ok2 then rendered = true else pcall(function() builtModel:Destroy() end) end
        end

        -- 2) Fallback to in-session characterClone
        if not rendered and lastAppliedSkinClone then
            local ok = pcall(function()
                buildViewportFromCharacter(headIconViewport, lastAppliedSkinClone)
            end)
            if ok then rendered = true end
        end

        if rendered then
            -- Position camera on the head (mannequin head is at Y=4.5)
            task.defer(function()
                local worldModel = headIconViewport:FindFirstChildOfClass("WorldModel")
                if not worldModel then return end
                local model = worldModel:FindFirstChildOfClass("Model")
                if not model then return end

                -- Find head and ensure it's visible
                local head = model:FindFirstChild("Head")
                if head and head:IsA("BasePart") then
                    head.Transparency = 0
                    head.CanCollide = false
                    head.Anchored = true
                    headIconCamera.FieldOfView = 30
                    -- Camera at -Z side looking toward +Z (head face decal is on -Z front)
                    headIconCamera.CFrame = CFrame.new(head.Position + Vector3.new(0, 0, -4.5), head.Position)
                else
                    -- Fallback to fixed position (camera at -Z to see face)
                    headIconCamera.FieldOfView = 30
                    headIconCamera.CFrame = CFrame.new(Vector3.new(0, 4.5, -4.5), Vector3.new(0, 4.5, 0))
                end
            end)
            headIconViewport.Visible = true
            headIconAvatar.Visible = false
            return
        end
    end

    -- Fallback: live thumbnail
    headIconViewport.Visible = false
    headIconAvatar.Visible = true
    local targetUserId = lastAppliedSkinUserId or player.UserId
    local newImage = "rbxthumb://type=AvatarHeadShot&id=" .. tostring(targetUserId) .. "&w=150&h=150"
    if headIconAvatar.Image ~= newImage then
        headIconAvatar.Image = newImage
    end
end

