function applyArtDecoCorners(parent, size, thick, color, inset)
    size  = size  or 24; thick = thick or 2; inset = inset or 10
    local accentFrames = {}
    local fixedColor = color
    local cInit = fixedColor or Theme.primary
    local corners = {
        {x = inset,         y = inset,         dx = 1,  dy = 1},
        {x = -inset - size, y = inset,         dx = -1, dy = 1},
        {x = inset,         y = -inset - size, dx = 1,  dy = -1},
        {x = -inset - size, y = -inset - size, dx = -1, dy = -1},
    }
    for i, info in ipairs(corners) do
        local cont = Instance.new("Frame")
        cont.Name = "ArtDeco" .. i
        cont.Size = UDim2.fromOffset(size, size)
        if info.dx == 1 then cont.Position = UDim2.new(0, info.x, 0, 0) else cont.Position = UDim2.new(1, info.x, 0, 0) end
        if info.dy == 1 then cont.Position = UDim2.new(cont.Position.X.Scale, cont.Position.X.Offset, 0, info.y)
        else cont.Position = UDim2.new(cont.Position.X.Scale, cont.Position.X.Offset, 1, info.y) end
        cont.BackgroundTransparency = 1
        cont.Parent = parent

        local hPosY = info.dy == 1 and 0 or (size - thick)
        local vPosX = info.dx == 1 and 0 or (size - thick)

        local h = Instance.new("Frame")
        h.Size = UDim2.fromOffset(size, thick); h.Position = UDim2.fromOffset(0, hPosY)
        h.BackgroundColor3 = cInit; h.BorderSizePixel = 0; h.Parent = cont

        local v = Instance.new("Frame")
        v.Size = UDim2.fromOffset(thick, size); v.Position = UDim2.fromOffset(vPosX, 0)
        v.BackgroundColor3 = cInit; v.BorderSizePixel = 0; v.Parent = cont

        local dot = Instance.new("Frame")
        dot.AnchorPoint = Vector2.new(0.5, 0.5)
        dot.Size = UDim2.fromOffset(thick + 2, thick + 2)
        dot.Position = UDim2.fromOffset(
            info.dx == 1 and (size - thick) or thick,
            info.dy == 1 and (size - thick) or thick
        )
        dot.BackgroundColor3 = cInit; dot.BorderSizePixel = 0
        corner(dot, 100); dot.Parent = cont

        if not fixedColor then
            table.insert(accentFrames, h); table.insert(accentFrames, v); table.insert(accentFrames, dot)
        end
    end
    if #accentFrames > 0 then
        onTheme(function(t)
            for _, f in ipairs(accentFrames) do f.BackgroundColor3 = t.primary end
        end)
    end
end

----------------------------------------------------------------
-- LUXURY X (кастомный крестик из двух диагональных линий)
----------------------------------------------------------------
function makeLuxuryX(parent, opts)
    opts = opts or {}
    local size       = opts.size or 36
    local lineLen    = opts.lineLen or math.floor(size * 0.42)
    local thick      = opts.thick or 2
    local hoverBg    = opts.hoverBg or C.DANGER
    local hoverColor = opts.hoverColor or C.WHITE

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.fromOffset(size, size)
    btn.BackgroundColor3 = C.GLASS
    btn.BackgroundTransparency = 0.3
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.ZIndex = 5
    btn.Parent = parent
    corner(btn, math.floor(size * 0.28))

    local s = stroke(btn, Theme.dark, 1, 0.2)
    local hovered = false
    onTheme(function(t)
        if not hovered then s.Color = t.dark end
    end)

    local xCore = Instance.new("Frame")
    xCore.AnchorPoint = Vector2.new(0.5, 0.5)
    xCore.Position = UDim2.fromScale(0.5, 0.5)
    xCore.Size = UDim2.fromOffset(lineLen, lineLen)
    xCore.BackgroundTransparency = 1
    xCore.ZIndex = 6
    xCore.Parent = btn

    local function makeLine(rotation)
        local line = Instance.new("Frame")
        line.AnchorPoint = Vector2.new(0.5, 0.5)
        line.Position = UDim2.fromScale(0.5, 0.5)
        line.Size = UDim2.fromOffset(lineLen, thick)
        line.BackgroundColor3 = Theme.primary
        line.BorderSizePixel = 0
        line.Rotation = rotation
        line.ZIndex = 6
        line.Parent = xCore
        corner(line, math.floor(thick / 2) + 1)
        return line
    end

    local lineA = makeLine(45)
    local lineB = makeLine(-45)

    onTheme(function(t)
        if not hovered then
            lineA.BackgroundColor3 = t.primary
            lineB.BackgroundColor3 = t.primary
        end
    end)

    btn.MouseEnter:Connect(function()
        hovered = true
        tween(btn,   0.18, {BackgroundColor3 = hoverBg, BackgroundTransparency = 0.05})
        tween(s,     0.18, {Color = hoverBg, Transparency = 0})
        tween(lineA, 0.18, {BackgroundColor3 = hoverColor, Size = UDim2.fromOffset(lineLen + 2, thick)})
        tween(lineB, 0.18, {BackgroundColor3 = hoverColor, Size = UDim2.fromOffset(lineLen + 2, thick)})
        tween(xCore, 0.18, {Rotation = 90})
    end)
    btn.MouseLeave:Connect(function()
        hovered = false
        tween(btn,   0.18, {BackgroundColor3 = C.GLASS, BackgroundTransparency = 0.3})
        tween(s,     0.18, {Color = Theme.dark, Transparency = 0.2})
        tween(lineA, 0.18, {BackgroundColor3 = Theme.primary, Size = UDim2.fromOffset(lineLen, thick)})
        tween(lineB, 0.18, {BackgroundColor3 = Theme.primary, Size = UDim2.fromOffset(lineLen, thick)})
        tween(xCore, 0.18, {Rotation = 0})
    end)

    return btn
end

