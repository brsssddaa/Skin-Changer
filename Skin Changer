-- Autoexec: Check if enabled and auto-apply last skin with retry logic
-- IMPORTANT: if autoexec is DISABLED, do nothing at all — manual launch = clean UI
task.spawn(function()
    pcall(function()
        local ae = scReadAutoexec()
        if not ae.enabled then return end
        -- Save current script to local cache for autoexec
        pcall(saveScriptToLocalCache)
        -- Re-queue teleport loader (in case of next teleport)
        pcall(setupQueueOnTeleport)
        -- Re-write auto-inject file (in case executor was reinstalled/updated)
        pcall(createAutoInjectScripts)

        -- Wait for character to load (with timeout)
        local charLoaded = false
        local waitStart = tick()
        while tick() - waitStart < 15 do
            if player.Character and player.Character:FindFirstChild("Humanoid")
               and player.Character:FindFirstChild("Head") then
                charLoaded = true
                break
            end
            task.wait(0.5)
        end

        if not charLoaded then
            return
        end

        -- Additional wait for character to fully initialize
        task.wait(1)

        -- Resolve lastSkin from autoexec file (match by userId+playerName, fallback to index)
        local skinToApply = nil
        if type(ae.lastSkin) == "table" and savedSkins and #savedSkins > 0 then
            local wantUserId   = ae.lastSkin.userId
            local wantName     = ae.lastSkin.playerName
            local wantIndex    = ae.lastSkin.index
            -- Prefer identity match so index changes (after adding/removing other skins) don't break it
            if wantUserId or wantName then
                for i, s in ipairs(savedSkins) do
                    if (wantUserId and s.userId == wantUserId) or (wantName and s.playerName == wantName) then
                        skinToApply = s
                        break
                    end
                end
            end
            if not skinToApply and type(wantIndex) == "number" and savedSkins[wantIndex] then
                skinToApply = savedSkins[wantIndex]
            end
        end

        if skinToApply then
            for attempt = 1, 3 do
                local success, err = pcall(function()
                    applySavedSkin(skinToApply)
                end)
                if success then
                    break
                else
                    if attempt < 3 then task.wait(1) end
                end
            end
        end

        task.wait(1)

        -- Check glasses state and restore if they were open
        local glassesState = (scReadSkinsBundle().glassesState) or "closed"
        if glassesState == "open" then
            local glassesWaitStart = tick()
            while tick() - glassesWaitStart < 5 do
                if g_putOnGlasses and not g_glassesOpen then
                    pcall(g_putOnGlasses)
                    task.wait(0.5)
                    if not glassesMenuVisible then
                        pcall(showGlassesWorldMenus)
                    end
                    break
                end
                task.wait(0.2)
            end
        end
    end)
end)
