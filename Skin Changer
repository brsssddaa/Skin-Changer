            -- Clipping container для slide-анимации
            contentClip = Instance.new("Frame")
            contentClip.Size = UDim2.new(1, 0, 0, 0)
            contentClip.AutomaticSize = Enum.AutomaticSize.Y
            contentClip.Position = UDim2.new(0, 0, 0, 50)
            contentClip.BackgroundTransparency = 1
            contentClip.ClipsDescendants = true
            contentClip.Visible = false
            contentClip.Parent = section

            content = Instance.new("Frame")
            content.Size = UDim2.new(1, 0, 0, 0)
            content.AutomaticSize = Enum.AutomaticSize.Y
            content.Position = UDim2.new(1, 0, 0, 0)  -- Начинаем справа (за экраном)
            content.BackgroundTransparency = 1
            content.Parent = contentClip

            local pad = Instance.new("UIPadding")
            pad.PaddingTop = UDim.new(0, 4)
            pad.PaddingBottom = UDim.new(0, 8)
            pad.PaddingLeft = UDim.new(0, 8)
            pad.PaddingRight = UDim.new(0, 8)
            pad.Parent = content
        end

        return {
            section = section, header = header, label = lbl, arrow = nil,
            content = content, contentClip = contentClip, headerStroke = headerStroke, expanded = false,
        }
    end

    -- ===== 1. MENU COLOR =====
    local s1 = makeSection(1, "Menu color", true)
    do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 56)
        row.BackgroundTransparency = 1
        row.Parent = s1.content

        local hl = Instance.new("UIListLayout")
        hl.FillDirection = Enum.FillDirection.Horizontal
        hl.Padding = UDim.new(0, 8)
        hl.HorizontalAlignment = Enum.HorizontalAlignment.Left
        hl.VerticalAlignment = Enum.VerticalAlignment.Center
        hl.SortOrder = Enum.SortOrder.LayoutOrder
        hl.Parent = row

        local squares = {}
        local function refreshSquares()
            for _, c in ipairs(squares) do
                local active = c.themeData.name == Theme.name
                c.stroke.Thickness = active and 3 or 1
                c.stroke.Transparency = active and 0 or 0.4
            end
        end

        for i, t in ipairs(THEMES) do
            local btn = Instance.new("TextButton")
            btn.LayoutOrder = i
            btn.Size = UDim2.fromOffset(40, 40)
            btn.BackgroundColor3 = t.primary
            btn.Text = ""
            btn.AutoButtonColor = false
            btn.Parent = row
            wmCorner(btn, 6)   -- квадратики (не круги)
            local s = wmStroke(btn, C.WHITE, 1, 0.4)
            table.insert(squares, {btn = btn, themeData = t, stroke = s})
            btn.MouseButton1Click:Connect(function()
                applyTheme(t)  -- сразу обновит панели через rebuildWorldPanels
            end)
        end
        refreshSquares()
    end

    -- ===== 2. CLOSE SCRIPT =====
    local s2 = makeSection(2, "Close Script", false)
    s2.header.MouseButton1Click:Connect(function()
        -- Отключаем бинд на очки
        scriptDisabled = true
        -- Отключаем шейдеры
        pcall(function() removeSunsetShader() end)
        -- Отключаем все коннекшены персонажа
        if scriptConnections.charAdded1 then pcall(function() scriptConnections.charAdded1:Disconnect() end) end
        if scriptConnections.charAdded2 then pcall(function() scriptConnections.charAdded2:Disconnect() end) end
        if scriptConnections.charRemoving then pcall(function() scriptConnections.charRemoving:Disconnect() end) end
        -- Снимаем очки
        if g_takeOffGlasses then pcall(g_takeOffGlasses) end
        -- Скрываем все меню с взрывной анимацией
        glassesHidden = false
        if hideGlassesWorldMenus then hideGlassesWorldMenus(false, false) end
        -- Отключаем состояние очков
        g_glassesOpen = false
        g_shouldRestoreGlasses = false
        -- Отключаем всё связанное со скриптом
        task.wait(1.5) -- ждём окончания анимации взрыва
        script:Destroy()
    end)

    -- ===== 4. HIDE MENU =====
    local s4 = makeSection(4, "Hide Menu", false)
    do
        s4.header.MouseButton1Click:Connect(function()
            glassesHidden = true  -- Set flag before hiding
            if hideGlassesWorldMenus then hideGlassesWorldMenus(true) end  -- keepHiddenFlag = true

            -- Rotation explosion effect for HeadIcon
            if headIconAvatar and headIconAvatar.Parent then
                TweenService:Create(headIconAvatar, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                    Rotation = 360,
                    Size = UDim2.fromScale(0, 0),
                    ImageTransparency = 1
                }):Play()
            end

            -- Hide HeadIcon after animation
            task.delay(0.4, function()
                headIconUserHidden = true
            end)
        end)
    end


    -- REAL TIME section removed - duplicate clock

    -- Раскрытие/сворачивание секций с slide-анимацией
    local expandedSection = nil
    local function toggle(sec)
        if not sec.content then return end

        -- Collapse другой секции если открываем новую (аккордеон)
        if not sec.expanded and expandedSection and expandedSection ~= sec then
            toggle(expandedSection)
        end

        sec.expanded = not sec.expanded

        if sec.expanded then
            expandedSection = sec
            sec.contentClip.Visible = true
            -- Slide in с анимацией
            tween(sec.content, 0.35, {Position = UDim2.new(0, 0, 0, 0)}, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        else
            -- Slide out
            tween(sec.content, 0.25, {Position = UDim2.new(1, 0, 0, 0)}, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
            task.delay(0.25, function()
                if not sec.expanded then sec.contentClip.Visible = false end
            end)
            if expandedSection == sec then expandedSection = nil end
        end

        -- Arrow rotation removed - no arrows anymore
    end
    s1.header.MouseButton1Click:Connect(function() toggle(s1) end)
    s2.header.MouseButton1Click:Connect(function() toggle(s2) end)

    -- Footer
    local hint = Instance.new("TextLabel")
    hint.AnchorPoint = Vector2.new(0, 1)
    hint.Size = UDim2.new(1, -32, 0, 18)
    hint.Position = UDim2.new(0, 24, 1, -10)
    hint.BackgroundTransparency = 1
    hint.Text = ""  -- Removed "PRESS INSERT TO CLOSE"
    hint.TextColor3 = Theme.primary
    hint.Font = FONT_SEMI
    hint.TextSize = 11
    hint.TextXAlignment = Enum.TextXAlignment.Left
    hint.Parent = root
    end -- close do block
end

