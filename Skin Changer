local function spawnModelFromJSON(modelKey, modelName)
    local content = EMBEDDED_MODELS[modelKey]
    if not content then
        warn("Embedded model not found: " .. tostring(modelKey))
        return nil
    end

    local success, data = pcall(function() return HttpService:JSONDecode(content) end)
    if not success or not data then
        warn("Failed to parse embedded JSON for: " .. modelKey)
        return nil
    end

    -- Create model
    local model = Instance.new("Model")
    model.Name = modelName or data.Name or "SpawnedModel"

    -- Get player position for spawning in front
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local cam = Workspace.CurrentCamera
    local spawnPos = Vector3.new(0, 0, 0)

    if hrp and cam then
        local forward = cam.CFrame.LookVector
        spawnPos = hrp.Position + Vector3.new(forward.X, 0, forward.Z).Unit * 5
        -- Raycast down to find floor
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.FilterDescendantsInstances = {char, model}
        local rayResult = Workspace:Raycast(spawnPos + Vector3.new(0, 10, 0), Vector3.new(0, -50, 0), rayParams)
        if rayResult then
            spawnPos = rayResult.Position
        else
            spawnPos = hrp.Position + Vector3.new(forward.X, 0, forward.Z).Unit * 5
        end
    end

    -- Calculate model bounds to center it
    local minX, minY, minZ = math.huge, math.huge, math.huge
    local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge

    local function extractAssetId(meshIdStr)
        if not meshIdStr or meshIdStr == "" then return nil end
        local id = meshIdStr:match("id=(%d+)") or meshIdStr:match("(%d+)")
        return id
    end

    local function processPart(partData, parent)
        local className = partData.ClassName or "Part"
        local part
        local specialMesh = nil

        -- LocalScripts can't write MeshId on MeshPart. Use Part + SpecialMesh instead.
        if className == "MeshPart" and partData.MeshId and partData.MeshId ~= "" then
            part = Instance.new("Part")
            specialMesh = Instance.new("SpecialMesh")
            specialMesh.MeshType = Enum.MeshType.FileMesh
            local assetId = extractAssetId(partData.MeshId)
            if assetId then
                pcall(function() specialMesh.MeshId = "rbxassetid://" .. assetId end)
            else
                pcall(function() specialMesh.MeshId = partData.MeshId end)
            end
            if partData.TextureID and partData.TextureID ~= "" then
                pcall(function() specialMesh.TextureId = partData.TextureID end)
            end
            specialMesh.Parent = part
        else
            local ok, created = pcall(Instance.new, className)
            if ok and created then
                part = created
            else
                part = Instance.new("Part")
            end
        end

        -- Set properties (wrapped in pcall to ignore restricted properties)
        if partData.Reflectance ~= nil then pcall(function() part.Reflectance = partData.Reflectance end) end
        if partData.CanCollide ~= nil then pcall(function() part.CanCollide = partData.CanCollide end) end
        if partData.Color then
            pcall(function()
                part.Color = Color3.new(partData.Color[1], partData.Color[2], partData.Color[3])
            end)
        end
        if partData.Transparency ~= nil then pcall(function() part.Transparency = partData.Transparency end) end
        if partData.Name then pcall(function() part.Name = partData.Name end) end
        if partData.Material then
            pcall(function() part.Material = Enum.Material[partData.Material] or Enum.Material.SmoothPlastic end)
        end
        if partData.Size then
            local sz = Vector3.new(partData.Size[1], partData.Size[2], partData.Size[3])
            if specialMesh then
                -- For SpecialMesh+FileMesh, use small part size and put real size into Scale
                pcall(function() part.Size = Vector3.new(0.05, 0.05, 0.05) end)
                pcall(function() specialMesh.Scale = sz end)
            else
                pcall(function() part.Size = sz end)
            end
        end
        if partData.Shape and not specialMesh then pcall(function() part.Shape = Enum.PartType[partData.Shape] end) end

        -- Set CFrame (12 numbers: position + rotation matrix)
        if partData.CFrame and #partData.CFrame == 12 then
            local cf = CFrame.new(
                partData.CFrame[1], partData.CFrame[2], partData.CFrame[3],
                partData.CFrame[4], partData.CFrame[5], partData.CFrame[6],
                partData.CFrame[7], partData.CFrame[8], partData.CFrame[9],
                partData.CFrame[10], partData.CFrame[11], partData.CFrame[12]
            )
            part.CFrame = cf
        end

        part.Parent = parent

        -- Process children recursively
        if partData.Children then
            for _, childData in ipairs(partData.Children) do
                processPart(childData, part)
            end
        end

        -- Track bounds for centering
        if part:IsA("BasePart") then
            local pos = part.Position
            minX, minY, minZ = math.min(minX, pos.X), math.min(minY, pos.Y), math.min(minZ, pos.Z)
            maxX, maxY, maxZ = math.max(maxX, pos.X), math.max(maxY, pos.Y), math.max(maxZ, pos.Z)
        end
    end

    -- Process all children
    if data.Children then
        for _, childData in ipairs(data.Children) do
            processPart(childData, model)
        end
    end

    -- Calculate center offset and reposition model
    local centerX = (minX + maxX) / 2
    local centerY = (minY + maxY) / 2
    local centerZ = (minZ + maxZ) / 2
    local offset = Vector3.new(centerX, minY, centerZ)

    -- Move all parts to spawn position
    for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CFrame = part.CFrame - offset + spawnPos
            part.Anchored = true  -- Anchor spawned models
        end
    end

    model.Parent = Workspace
    return model
end

function toggleSpecialFeaturesMenu()
    if emptySpecialMenuPart and emptySpecialMenuPart.Parent then
        -- Empty menu is open, close it
        -- Remove from worldPanels
        for i, p in ipairs(worldPanels) do
            if p.part == emptySpecialMenuPart then
                table.remove(worldPanels, i)
                break
            end
        end
        emptySpecialMenuPart:Destroy()
        emptySpecialMenuPart = nil
        specialMenuOpen = false
    elseif specialMenuOpen then
        -- Password menu is open, close it
        -- Remove from worldPanels
        for i, p in ipairs(worldPanels) do
            if p.part == specialMenuPart then
                table.remove(worldPanels, i)
                break
            end
        end
        if specialMenuPart then
            specialMenuPart:Destroy()
            specialMenuPart = nil
        end
        specialMenuOpen = false
        passwordEntered = ""
        specialMenuAuthenticated = false
    else
        -- Open password keyboard menu
        createPasswordMenu()
        specialMenuOpen = true
    end
end

