function corner(p, r) local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 8); c.Parent = p; return c end
function stroke(p, col, th, tr) local s = Instance.new("UIStroke"); s.Color = col or Theme.dark; s.Thickness = th or 1; s.Transparency = tr or 0; s.Parent = p; return s end
function gradient(p, cs, rot, ts) local g = Instance.new("UIGradient"); g.Color = cs; if ts then g.Transparency = ts end; g.Rotation = rot or 0; g.Parent = p; return g end
function padd(p, t, r, b, l) local pad = Instance.new("UIPadding"); pad.PaddingTop = UDim.new(0, t or 0); pad.PaddingRight = UDim.new(0, r or 0); pad.PaddingBottom = UDim.new(0, b or 0); pad.PaddingLeft = UDim.new(0, l or 0); pad.Parent = p; return pad end
function tween(obj, t, props, style, dir) local tw = TweenService:Create(obj, TweenInfo.new(t, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props); tw:Play(); return tw end
-- Theme helpers (assigned to globals to reduce locals)
