        return string.format("%d  PLAYERS", #Players:GetPlayers())
    end},
    saved     = {title = "SAVED  ·  YOUR LIBRARY", info = function()
        return string.format("%d  SLOTS", #savedSkins)
    end},
    settings  = {title = "SETTINGS  ·  PREFERENCES", info = function() return "PERSONALIZE" end},
}

function moveIndicatorTo(page, animated)
    local btn = navButtons[page]
    if not btn then return end
    if btn.AbsoluteSize.X <= 0 then
        task.delay(0.05, function() moveIndicatorTo(page, animated) end)
        return
    end
    local relX = btn.AbsolutePosition.X - navBar.AbsolutePosition.X
    local target = {
        Position = UDim2.new(0, relX, 0, 4),
        Size     = UDim2.new(0, btn.AbsoluteSize.X, 1, -8),
    }
    if animated then
        tween(navIndicator, 0.35, target, Enum.EasingStyle.Quint)
    else
        navIndicator.Position = target.Position
        navIndicator.Size     = target.Size
    end
end

function switchPage(page)
    if currentPage == page then return end
    currentPage = page

    playersContainer.Visible  = (page == "players")
    savedContainer.Visible    = (page == "saved" and #savedSkins > 0)
    savedEmpty.Visible        = (page == "saved" and #savedSkins == 0)
    settingsPage.Visible      = (page == "settings")

    if page ~= "settings" and paletteOpen then togglePalette(false) end

    if page == "players" then updatePlayersList()
    elseif page == "saved" then updateSavedSkinsList()
    end

    moveIndicatorTo(page, true)

    for p, b in pairs(navButtons) do
        tween(b, 0.25, {TextColor3 = (p == page) and C.BLACK or C.TEXT_DIM})
    end

    local meta = pageMeta[page]
    if meta then
        sectionTitle.Text = meta.title
        sectionInfo.Text  = meta.info()
    end
end

playersBtn.MouseButton1Click  :Connect(function() switchPage("players")   end)
savedBtn.MouseButton1Click    :Connect(function() switchPage("saved")     end)

for p, b in pairs(navButtons) do
    b.MouseEnter:Connect(function()
        if currentPage ~= p then tween(b, 0.15, {TextColor3 = Theme.primary}) end
    end)
    b.MouseLeave:Connect(function()
        if currentPage ~= p then tween(b, 0.15, {TextColor3 = C.TEXT_DIM}) end
    end)
end

