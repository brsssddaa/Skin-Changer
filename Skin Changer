local dragging, dragStart, startPos = false, nil, nil

-- Проверка: находится ли точка над интерактивным элементом (navBar/closeButton)
local function isOverInteractable(pos)
    -- navBar
    local nbPos, nbSize = navBar.AbsolutePosition, navBar.AbsoluteSize
    if pos.X >= nbPos.X and pos.X <= nbPos.X + nbSize.X
       and pos.Y >= nbPos.Y and pos.Y <= nbPos.Y + nbSize.Y then
        return true
    end
    -- closeButton
    if closeButton then
        local cbPos, cbSize = closeButton.AbsolutePosition, closeButton.AbsoluteSize
        if pos.X >= cbPos.X and pos.X <= cbPos.X + cbSize.X
           and pos.Y >= cbPos.Y and pos.Y <= cbPos.Y + cbSize.Y then
            return true
        end
    end
    return false
end

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
       or input.UserInputType == Enum.UserInputType.Touch then
        -- Не начинаем drag если клик над кнопками навигации/закрытия
        if isOverInteractable(Vector2.new(input.Position.X, input.Position.Y)) then
            return
        end
        dragging = true; dragStart = input.Position; startPos = mainContainer.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                  or input.UserInputType == Enum.UserInputType.Touch) then
        local d = input.Position - dragStart
        mainContainer.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + d.X,
            startPos.Y.Scale, startPos.Y.Offset + d.Y
        )
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
       or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

