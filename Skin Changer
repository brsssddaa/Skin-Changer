-- Серый R6-манекен
function makeMannequin()
    local model = Instance.new("Model")
    model.Name = "CollectorMannequin"

    local skinColor = Color3.fromRGB(163, 162, 165)

    local function makePart(name, size, cf)
        local p = Instance.new("Part")
        p.Name = name
        p.Size = size
        p.CFrame = cf
        p.Anchored = true
        p.CanCollide = false
        p.Color = skinColor
        p.Material = Enum.Material.SmoothPlastic
        p.TopSurface = Enum.SurfaceType.Smooth
        p.BottomSurface = Enum.SurfaceType.Smooth
        p.Parent = model
        return p
    end

    local hrp = makePart("HumanoidRootPart", Vector3.new(2, 2, 1), CFrame.new(0, 3, 0))
    hrp.Transparency = 1

    local torso = makePart("Torso",     Vector3.new(2, 2, 1), CFrame.new(0,    3,   0))
    local head  = makePart("Head",      Vector3.new(2, 1, 1), CFrame.new(0,    4.5, 0))
    local hm = Instance.new("SpecialMesh")
    hm.MeshType = Enum.MeshType.Head
    hm.Scale    = Vector3.new(1.25, 1.25, 1.25)
    hm.Parent   = head

    local lArm = makePart("Left Arm",  Vector3.new(1, 2, 1), CFrame.new(-1.5, 3,   0))
    local rArm = makePart("Right Arm", Vector3.new(1, 2, 1), CFrame.new( 1.5, 3,   0))
    local lLeg = makePart("Left Leg",  Vector3.new(1, 2, 1), CFrame.new(-0.5, 1,   0))
    local rLeg = makePart("Right Leg", Vector3.new(1, 2, 1), CFrame.new( 0.5, 1,   0))

    -- Attachments для крепления accessories
    local function addAtt(part, name, pos)
        local a = Instance.new("Attachment")
        a.Name = name
        a.Position = pos or Vector3.new(0, 0, 0)
        a.Parent = part
        return a
    end
    -- Head
    addAtt(head, "HatAttachment",         Vector3.new(0,  0.6,  0))
    addAtt(head, "HairAttachment",        Vector3.new(0,  0.6,  0))
    addAtt(head, "FaceCenterAttachment",  Vector3.new(0,  0,    0))
    addAtt(head, "FaceFrontAttachment",   Vector3.new(0,  0,   -0.6))
    addAtt(head, "NeckAttachment",        Vector3.new(0, -0.5,  0))
    addAtt(head, "FaceAttachment",        Vector3.new(0,  0,   -0.6))
    addAtt(head, "HeadTopAttachment",     Vector3.new(0,  0.6,  0))
    addAtt(head, "FrontAttachment",       Vector3.new(0,  0,   -0.6))
    addAtt(head, "BackAttachment",        Vector3.new(0,  0,    0.6))
    addAtt(head, "TopAttachment",         Vector3.new(0,  0.6,  0))
    addAtt(head, "BottomAttachment",      Vector3.new(0, -0.6,  0))
    -- Torso
    addAtt(torso, "NeckAttachment",          Vector3.new(0,  1,   0))
    addAtt(torso, "BodyFrontAttachment",     Vector3.new(0,  0,  -0.5))
    addAtt(torso, "BodyBackAttachment",      Vector3.new(0,  0,   0.5))
    addAtt(torso, "LeftCollarAttachment",    Vector3.new(-1, 1,   0))
    addAtt(torso, "RightCollarAttachment",   Vector3.new( 1, 1,   0))
    addAtt(torso, "WaistFrontAttachment",    Vector3.new(0, -1,  -0.5))
    addAtt(torso, "WaistCenterAttachment",   Vector3.new(0, -1,   0))
    addAtt(torso, "WaistBackAttachment",     Vector3.new(0, -1,   0.5))
    addAtt(torso, "RootAttachment",          Vector3.new(0,  0,   0))
    addAtt(torso, "ChestAttachment",         Vector3.new(0,  0.5, -0.5))
    addAtt(torso, "UpperChestAttachment",    Vector3.new(0,  0.8, -0.5))
    -- Arms
    addAtt(lArm, "LeftShoulderAttachment",   Vector3.new(0, 1, 0))
    addAtt(lArm, "LeftGripAttachment",       Vector3.new(0, -1, 0))
    addAtt(lArm, "LeftElbowAttachment",      Vector3.new(0, -1, 0))
    addAtt(lArm, "LeftWristAttachment",     Vector3.new(0, -1, 0))
    addAtt(lArm, "LeftHandAttachment",       Vector3.new(0, -1, 0))
    addAtt(rArm, "RightShoulderAttachment",  Vector3.new(0, 1, 0))
    addAtt(rArm, "RightGripAttachment",      Vector3.new(0, -1, 0))
    addAtt(rArm, "RightElbowAttachment",     Vector3.new(0, -1, 0))
    addAtt(rArm, "RightWristAttachment",    Vector3.new(0, -1, 0))
    addAtt(rArm, "RightHandAttachment",      Vector3.new(0, -1, 0))
    -- Legs
    addAtt(lLeg, "LeftFootAttachment",       Vector3.new(0, -1, 0))
    addAtt(lLeg, "LeftLegAttachment",        Vector3.new(0, 1, 0))
    addAtt(lLeg, "LeftKneeAttachment",       Vector3.new(0, 0, 0))
    addAtt(rLeg, "RightFootAttachment",      Vector3.new(0, -1, 0))
    addAtt(rLeg, "RightLegAttachment",       Vector3.new(0, 1, 0))
    addAtt(rLeg, "RightKneeAttachment",      Vector3.new(0, 0, 0))
    -- HRP
    addAtt(hrp, "RootAttachment",           Vector3.new(0, 0, 0))

    -- Face decal placeholder
    local faceDecal = Instance.new("Decal")
    faceDecal.Name = "face"
    faceDecal.Texture = "rbxasset://textures/face.png"
    faceDecal.Face = Enum.NormalId.Front
    faceDecal.Parent = head

    local hum = Instance.new("Humanoid")
    hum.RigType = Enum.HumanoidRigType.R6
    hum.Parent = model

    model.PrimaryPart = hrp
    return model, {Head=head, Torso=torso, ["Left Arm"]=lArm, ["Right Arm"]=rArm, ["Left Leg"]=lLeg, ["Right Leg"]=rLeg}
end

-- Крепит Accessory к манекену - упрощённая версия для теста
function attachAccessoryToModel(accessory, model, parts)
    -- Просто парентим аксессуар к модели без сложного позиционирования
    accessory.Parent = model
    local handle = accessory:FindFirstChild("Handle")
    if handle then
        handle.Anchored = true
        handle.CanCollide = false
        handle.Massless = true
        for _, p in ipairs(accessory:GetDescendants()) do
            if p:IsA("BasePart") then
                p.Anchored = true
                p.CanCollide = false
                p.Massless = true
            end
        end
    end
end

-- Строит R6-модель из сохранённых данных skinData (для замороженных иконок saved-карточек).
-- Используется когда характер-клон отсутствует (после загрузки из файла).
function buildSkinModel(skinData)
    local model, parts = makeMannequin()

    -- Anchor all parts before attaching accessories
    for _, part in pairs(parts) do
        part.Anchored = true
        part.CanCollide = false
    end

    -- Body colors
    if skinData.bodyColors then
        local map = {
            Head        = "HeadColor3",
            Torso       = "TorsoColor3",
            ["Left Arm"]  = "LeftArmColor3",
            ["Right Arm"] = "RightArmColor3",
            ["Left Leg"]  = "LeftLegColor3",
            ["Right Leg"] = "RightLegColor3",
        }
        for partName, key in pairs(map) do
            local p = parts[partName]
            local col = skinData.bodyColors[key]
            if p and col then p.Color = col end
        end
    end

    -- Body part sizes НЕ применяем к манекену: у него фиксированные R6-CFrames,
    -- и при изменении Size части «отрываются» друг от друга.

    -- Head mesh (replace default SpecialMesh)
    if skinData.headMesh and parts.Head then
        local oldMesh = parts.Head:FindFirstChildOfClass("SpecialMesh")
        if oldMesh then oldMesh:Destroy() end
        local hm = skinData.headMesh
        if typeof(hm) == "Instance" then
            local clone = hm:Clone()
            if clone then
                clone.Parent = parts.Head
            end
        end
    end

    -- Face decal (replace existing) — supports Instance OR texture string
    if skinData.face and parts.Head then
        local oldFace = parts.Head:FindFirstChild("face")
        if oldFace then oldFace:Destroy() end
        if typeof(skinData.face) == "Instance" then
            local f = skinData.face:Clone()
            if f then
                f.Name = "face"
                f.Parent = parts.Head
            end
        elseif type(skinData.face) == "string" and skinData.face ~= "" then
            local f = Instance.new("Decal")
            f.Name = "face"
            f.Face = Enum.NormalId.Front
            f.Texture = skinData.face
            f.Parent = parts.Head
        end
    end

    -- Character meshes (нужен Humanoid в модели — он уже есть из makeMannequin)
    for _, cm in ipairs(skinData.characterMeshes or {}) do
        if typeof(cm) == "Instance" then
            local clone = cm:Clone()
            if clone then
                clone.Parent = model
            end
        end
    end

    -- Clothing
    for _, cl in ipairs(skinData.clothes or {}) do
        if typeof(cl) == "Instance" then
            local clone = cl:Clone()
            if clone then
                clone.Parent = model
            end
        end
    end

    -- Accessories (поддерживаем оба формата: живой Instance и табличный из файла)
    for _, acc in ipairs(skinData.accessories or {}) do
        if typeof(acc) == "Instance" and acc:IsA("Accessory") then
            local clone = acc:Clone()
            if clone then
                attachAccessoryToModel(clone, model, parts)
            end
        elseif type(acc) == "table" then
            pcall(function()
                if not acc.MeshId or acc.MeshId == "" then return end
                if not acc.AttachmentName or acc.AttachmentName == "" then return end

                -- Ищем совпадающий attachment на манекене
                local targetAtt
                for _, part in pairs(parts) do
                    local m = part:FindFirstChild(acc.AttachmentName)
                    if m and m:IsA("Attachment") then
                        targetAtt = m; break
                    end
                end
                if not targetAtt then return end

                local handle = Instance.new("Part")
                handle.Name = "ACC_" .. (acc.Name or "Accessory")
                if acc.IsMeshPart then
                    handle.Size = Vector3.new(0.2, 0.2, 0.2)
                else
                    handle.Size = Vector3.new(unpack(acc.HandleSize or {1, 1, 1}))
                end
                handle.Transparency = acc.HandleTransparency or 0
                handle.CanCollide = false
                handle.Massless   = true
                handle.Anchored   = true
                handle.TopSurface    = Enum.SurfaceType.Smooth
                handle.BottomSurface = Enum.SurfaceType.Smooth

                local mesh = Instance.new("SpecialMesh")
                mesh.MeshType  = Enum.MeshType.FileMesh
                mesh.MeshId    = acc.MeshId
                mesh.TextureId = acc.TextureId or ""
                mesh.Scale     = Vector3.new(unpack(acc.MeshScale or {1, 1, 1}))
                mesh.Parent    = handle

                local attCF = CFrame.new()
                if acc.AttachmentCFrame and #acc.AttachmentCFrame == 12 then
                    attCF = CFrame.new(unpack(acc.AttachmentCFrame))
                end
                handle.CFrame = targetAtt.Parent.CFrame * targetAtt.CFrame * attCF:Inverse()
                handle.Parent = model
            end)
        end
    end

    return model
end

