function updatePlayersList()
    for _, ch in ipairs(playersContainer:GetChildren()) do
        if ch:IsA("Frame") then ch:Destroy() end
    end
    local order = 1
    -- Self первой
    local selfCard = createPlayerCard(player, order)
    selfCard.Parent = playersContainer
    order += 1
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            local c = createPlayerCard(plr, order)
            c.Parent = playersContainer
            order += 1
        end
    end
end

function updateSavedSkinsList()
    for _, ch in ipairs(savedContainer:GetChildren()) do
        if ch:IsA("Frame") then ch:Destroy() end
    end
    for i, skin in ipairs(savedSkins) do
        local c = createSavedCard(skin, i)
        c.Parent = savedContainer
    end
    -- empty state когда saved открыт и список пуст
    if currentPage == "saved" then
        local hasAny = #savedSkins > 0
        savedContainer.Visible = hasAny
        savedEmpty.Visible = not hasAny
    else
        savedEmpty.Visible = false
    end
end

