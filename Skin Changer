function makeSaveStarButton(parent, initialSaved)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.fromOffset(28, 28)
    btn.Position = UDim2.new(1, -38, 0, 10)
    btn.BackgroundColor3 = C.BG_PANEL
    btn.BackgroundTransparency = 0.05
    btn.Text = "+"
    btn.TextColor3 = Theme.primary
    btn.TextSize = 22
    btn.Font = FONT_BOLD
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.ZIndex = 5
    btn.Parent = parent
    corner(btn, 8)
    local s = stroke(btn, Theme.primary, 1.4, 0.1)

    local state = initialSaved and "saved" or "idle"
    local hovered = false

    local function refresh()
        if state == "saved" then
            btn.BackgroundColor3 = Theme.primary
            btn.TextColor3 = C.BLACK
            btn.Text = "✓"
            btn.TextSize = 18
            s.Color = Theme.primary
            s.Transparency = 0
        elseif hovered then
            btn.BackgroundColor3 = Theme.primary
            btn.TextColor3 = C.BLACK
            btn.Text = "+"
            btn.TextSize = 22
            s.Color = Theme.primary
            s.Transparency = 0
        else
            btn.BackgroundColor3 = C.BG_PANEL
            btn.TextColor3 = Theme.primary
            btn.Text = "+"
            btn.TextSize = 22
            s.Color = Theme.primary
            s.Transparency = 0.1
        end
    end

    onTheme(function() refresh() end)

    btn.MouseEnter:Connect(function()
        hovered = true
        tween(btn, 0.15, {Size = UDim2.fromOffset(32, 32), Position = UDim2.new(1, -40, 0, 8)})
        refresh()
    end)
    btn.MouseLeave:Connect(function()
        hovered = false
        tween(btn, 0.15, {Size = UDim2.fromOffset(28, 28), Position = UDim2.new(1, -38, 0, 10)})
        refresh()
    end)

    refresh()

    return btn, function(newState) state = newState; refresh() end
end

