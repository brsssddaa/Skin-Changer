-- Pick a single best autoexec path: prefer existing folder, then "autoexec" default
function pickBestAutoexecPath()
    -- Priority 1: find first existing folder via isfolder
    if isfolder then
        for _, path in ipairs(AUTOEXEC_CANDIDATES) do
            local ok, exists = pcall(isfolder, path)
            if ok and exists then
                return path
            end
        end
    end
    -- Priority 2: just use "autoexec" — most executors map this to their real autoexec
    return "autoexec"
end

-- Create a SINGLE auto-inject script in the best detected autoexec path
function createAutoInjectScripts()
    if not writefile then
        return false, "writefile not supported by executor"
    end
    
    local content = createAutoInjectScriptContent()
    local path = pickBestAutoexecPath()
    local filePath = path .. "/SkinChanger_AutoInject.lua"
    
    local writeOk, writeErr = pcall(function()
        writefile(filePath, content)
    end)
    
    if not writeOk then
        return false, "writefile failed: " .. tostring(writeErr)
    end
    
    return true, { getExecutorNameFromPath(path) }
end

-- Remove auto-inject scripts from ALL candidate paths.
-- Defense in depth: overwrite with guarded version (checks flag and exits if disabled) THEN try delfile.
-- Even if delfile is sandboxed and silently fails, the guarded file won't load the script.
function removeAutoInjectScripts()
    local guardedContent = createAutoInjectScriptContent()
    -- Build union: all candidates + whatever pickBestAutoexecPath returns
    local targets = {}
    for _, folder in ipairs(AUTOEXEC_CANDIDATES) do
        targets[folder] = true
    end
    pcall(function() targets[pickBestAutoexecPath()] = true end)

    for folder, _ in pairs(targets) do
        local filePath = folder .. "/SkinChanger_AutoInject.lua"
        -- 1) Overwrite with guarded version (will check flag and exit if disabled)
        if writefile then
            pcall(function() writefile(filePath, guardedContent) end)
        end
        -- 2) Try to delete
        if delfile then
            pcall(function()
                if isfile and isfile(filePath) then delfile(filePath) end
            end)
        end
    end
    -- Also re-queue teleport with guarded code so any previously-queued
    -- unconditional loader gets replaced (best-effort; some executors don't
    -- support re-queueing, but the flag guard in the new queued code is safe).
    pcall(setupQueueOnTeleport)
end

-- Get status of auto-inject scripts (checks ALL candidate paths via isfile)
function getAutoInjectStatus()
    local status = {
        foundExecutors = {},
        configuredExecutors = {},
        totalFound = 0,
        totalConfigured = 0
    }
    
    local seenFound = {}
    local seenConfigured = {}
    
    for _, folder in ipairs(AUTOEXEC_CANDIDATES) do
        local execName = getExecutorNameFromPath(folder)
        local filePath = folder .. "/SkinChanger_AutoInject.lua"
        
        -- Check if folder exists via isfolder
        local folderExists = false
        pcall(function()
            if isfolder and isfolder(folder) then
                folderExists = true
            end
        end)
        
        -- Check if our inject file exists (means folder is writeable)
        local fileExists = false
        pcall(function()
            if isfile and isfile(filePath) then
                fileExists = true
            end
        end)
        
        if (folderExists or fileExists) and not seenFound[execName] then
            table.insert(status.foundExecutors, execName)
            status.totalFound = status.totalFound + 1
            seenFound[execName] = true
        end
        
        if fileExists and not seenConfigured[execName] then
            table.insert(status.configuredExecutors, execName)
            status.totalConfigured = status.totalConfigured + 1
            seenConfigured[execName] = true
        end
    end
    
    return status
end

