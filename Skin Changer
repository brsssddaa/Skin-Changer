local menuVisible = false

-- Блокируем Shift (ShiftLock — Roblox центрирует курсор) и RMB (поворот камеры),
-- пока меню открыто. Сами используем эти кнопки для drag модели.
local BLOCK_ACTION = "SkinChanger_BlockMenuKeys"
function blockMenuKeys()
    -- Приоритет выше дефолтного (2000) — иначе Roblox-камера ловит RMB первой
    ContextActionService:BindActionAtPriority(BLOCK_ACTION,
        function() return Enum.ContextActionResult.Sink end,
        false,
        3000,
        Enum.KeyCode.LeftShift, Enum.KeyCode.RightShift,
        Enum.UserInputType.MouseButton2)
end
function unblockMenuKeys()
    ContextActionService:UnbindAction(BLOCK_ACTION)
end

local savedWasFirstPerson = false

function openMenu()
    if menuVisible then return end
    menuVisible = true
    mainContainer.Visible = true
    backdrop.Visible = true
    blockMenuKeys()

    -- Если первое лицо — переключаем на третье
    pcall(function()
        local cam = workspace.CurrentCamera
        if cam and head and (cam.CFrame.Position - head.Position).Magnitude < 1.5 then
            savedWasFirstPerson = true
            humanoid.CameraMode = Enum.CameraMode.Classic
        else
            savedWasFirstPerson = false
        end
    end)

    -- Init анимация: стартует маленьким и сильно закруглённым ("капсула"), плавно раскрывается до прямоугольника
    mainContainer.Size = UDim2.fromOffset(W * 0.5, H * 0.35)
    mainContainer.BackgroundTransparency = 1
    backdrop.BackgroundTransparency = 1

    local mainCorner = mainContainer:FindFirstChildOfClass("UICorner")
    if mainCorner then
        mainCorner.CornerRadius = UDim.new(0, math.min(W * 0.25, H * 0.18, 120))
        tween(mainCorner, 0.6, {CornerRadius = UDim.new(0, 14)},
            Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    end

    tween(backdrop, 0.5, {BackgroundTransparency = 0.35})
    tween(mainContainer, 0.6,
        {Size = UDim2.fromOffset(W, H), BackgroundTransparency = 0},
        Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

    -- Force transparency to 0 after tween to ensure it's not transparent
    task.delay(0.6, function()
        if mainContainer and mainContainer.Parent then
            mainContainer.BackgroundTransparency = 0
        end
    end)

    -- Обновим списки на текущей вкладке
    if currentPage == "players" then updatePlayersList()
    elseif currentPage == "saved" then updateSavedSkinsList() end

    UserInputService.MouseIconEnabled = false

    task.delay(0.08, function()
        if not (screenGui and screenGui.Parent) then return end
        moveIndicatorTo(currentPage, false)
        if pageMeta[currentPage] then
            sectionInfo.Text = pageMeta[currentPage].info()
        end
    end)
end

function closeMenu()
    if not menuVisible then return end
    menuVisible = false
    unblockMenuKeys()

    -- Возвращаем первое лицо если было
    if savedWasFirstPerson then
        pcall(function()
            humanoid.CameraMode = Enum.CameraMode.LockFirstPerson
        end)
        savedWasFirstPerson = false
    end
    if paletteOpen then togglePalette(false) end
    tween(backdrop, 0.25, {BackgroundTransparency = 1})
    tween(mainContainer, 0.3,
        {Size = UDim2.fromOffset(W * 0.5, H * 0.35), BackgroundTransparency = 1},
        Enum.EasingStyle.Back, Enum.EasingDirection.In)
    local mainCorner = mainContainer:FindFirstChildOfClass("UICorner")
    if mainCorner then
        tween(mainCorner, 0.3, {CornerRadius = UDim.new(0, math.min(W * 0.25, H * 0.18, 120))},
            Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    end
    UserInputService.MouseIconEnabled = true
    task.delay(0.32, function()
        if not menuVisible then
            mainContainer.Visible = false
            backdrop.Visible = false
        end
    end)
end

function toggleMenu()
    if menuVisible then closeMenu() else openMenu() end
end

