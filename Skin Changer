function saveSavedSkinsToFile()
    if not writefile then return end

    local dataToSave = {}
    for i, skinData in ipairs(savedSkins) do
        local bodyColorsData = nil
        if skinData.bodyColors then
            bodyColorsData = {
                HeadColor3     = {skinData.bodyColors.HeadColor3.R,     skinData.bodyColors.HeadColor3.G,     skinData.bodyColors.HeadColor3.B},
                LeftArmColor3  = {skinData.bodyColors.LeftArmColor3.R,  skinData.bodyColors.LeftArmColor3.G,  skinData.bodyColors.LeftArmColor3.B},
                LeftLegColor3  = {skinData.bodyColors.LeftLegColor3.R,  skinData.bodyColors.LeftLegColor3.G,  skinData.bodyColors.LeftLegColor3.B},
                RightArmColor3 = {skinData.bodyColors.RightArmColor3.R, skinData.bodyColors.RightArmColor3.G, skinData.bodyColors.RightArmColor3.B},
                RightLegColor3 = {skinData.bodyColors.RightLegColor3.R, skinData.bodyColors.RightLegColor3.G, skinData.bodyColors.RightLegColor3.B},
                TorsoColor3    = {skinData.bodyColors.TorsoColor3.R,    skinData.bodyColors.TorsoColor3.G,    skinData.bodyColors.TorsoColor3.B},
            }
        end

        local entry = {
            playerName     = skinData.playerName,
            customLabel    = skinData.customLabel,
            userId         = skinData.userId,
            clothes        = {},
            bodyColors     = bodyColorsData,
            bodyScales     = skinData.bodyScales,
            bodyPartSizes  = skinData.bodyPartSizes,
            bodyPartMeshes = skinData.bodyPartMeshes,
            face           = skinData.face,
            headMesh       = nil,
            characterMeshes= {},
            accessories    = {},
        }

        if skinData.headMesh and type(skinData.headMesh) == "userdata" then
            entry.headMesh = {
                ClassName = skinData.headMesh.ClassName,
                MeshId    = skinData.headMesh.MeshId,
                TextureId = skinData.headMesh.TextureId,
                Scale     = {skinData.headMesh.Scale.X, skinData.headMesh.Scale.Y, skinData.headMesh.Scale.Z},
            }
        end

        for _, cloth in ipairs(skinData.clothes or {}) do
            if type(cloth) == "userdata" then
                local textureId = ""
                if cloth.ClassName == "ShirtGraphic" then
                    textureId = cloth.Graphic
                else
                    textureId = cloth[cloth.ClassName .. "Template"]
                end
                table.insert(entry.clothes, {ClassName = cloth.ClassName, TextureId = textureId})
            end
        end

        for _, mesh in ipairs(skinData.characterMeshes or {}) do
            if type(mesh) == "userdata" then
                local bodyPartName = tostring(mesh.BodyPart):match("%.(%w+)$") or tostring(mesh.BodyPart)
                table.insert(entry.characterMeshes, {
                    BodyPart         = bodyPartName,
                    MeshId           = tostring(mesh.MeshId),
                    OverlayTextureId = tostring(mesh.OverlayTextureId),
                })
            end
        end

        local convertedAccessories = {}
        for _, accData in ipairs(skinData.accessories or {}) do
            if type(accData) == "userdata" and accData.ClassName == "Accessory" then
                local handle = accData:FindFirstChild("Handle", true)
                if handle and handle:IsA("BasePart") then
                    local mesh = handle:FindFirstChildOfClass("SpecialMesh")
                    local att  = handle:FindFirstChildOfClass("Attachment")
                    local meshId, textureId = "", ""
                    local meshScale = {1, 1, 1}
                    if handle:IsA("MeshPart") then
                        meshId = handle.MeshId; textureId = handle.TextureID
                    elseif mesh then
                        meshId = mesh.MeshId; textureId = mesh.TextureId
                        meshScale = {mesh.Scale.X, mesh.Scale.Y, mesh.Scale.Z}
                    end
                    local accDataConverted = {
                        Name               = accData.Name,
                        MeshId             = meshId,
                        TextureId          = textureId,
                        MeshScale          = meshScale,
                        AttachmentName     = att and att.Name or "",
                        AttachmentCFrame   = {},
                        HandleSize         = {handle.Size.X, handle.Size.Y, handle.Size.Z},
                        HandleTransparency = handle.Transparency,
                        HandleMaterial     = tostring(handle.Material),
                        IsMeshPart         = handle:IsA("MeshPart"),
                    }
                    if att then
                        local x, y, z, r00, r01, r02, r10, r11, r12, r20, r21, r22 = att.CFrame:GetComponents()
                        accDataConverted.AttachmentCFrame = {x, y, z, r00, r01, r02, r10, r11, r12, r20, r21, r22}
                    end
                    table.insert(entry.accessories, accDataConverted)
                    table.insert(convertedAccessories, accDataConverted)
                end
            elseif type(accData) == "table" then
                table.insert(entry.accessories, accData)
                table.insert(convertedAccessories, accData)
            end
        end

        savedSkins[i].accessories = convertedAccessories
        table.insert(dataToSave, entry)
    end

    pcall(function()
        local bundle = scReadSkinsBundle()
        bundle.savedSkins = dataToSave
        scWriteSkinsBundle(bundle)
    end)
end

function loadSavedSkinsFromFile()
    if not readfile or not isfile then return end

    local ok, err = pcall(function()
        local bundle = scReadSkinsBundle()
        local dataLoaded = bundle.savedSkins
        if type(dataLoaded) ~= "table" then return end

        for _, skinData in ipairs(dataLoaded) do
            local bodyColorsRestored = nil
            if skinData.bodyColors then
                bodyColorsRestored = {
                    HeadColor3     = Color3.new(unpack(skinData.bodyColors.HeadColor3)),
                    LeftArmColor3  = Color3.new(unpack(skinData.bodyColors.LeftArmColor3)),
                    LeftLegColor3  = Color3.new(unpack(skinData.bodyColors.LeftLegColor3)),
                    RightArmColor3 = Color3.new(unpack(skinData.bodyColors.RightArmColor3)),
                    RightLegColor3 = Color3.new(unpack(skinData.bodyColors.RightLegColor3)),
                    TorsoColor3    = Color3.new(unpack(skinData.bodyColors.TorsoColor3)),
                }
            end

            local newSkin = {
                playerName      = skinData.playerName,
                customLabel     = skinData.customLabel,
                userId          = skinData.userId,
                clothes         = {},
                bodyColors      = bodyColorsRestored,
                bodyScales      = skinData.bodyScales,
                bodyPartSizes   = skinData.bodyPartSizes,
                bodyPartMeshes  = skinData.bodyPartMeshes,
                face            = skinData.face,
                headMesh        = nil,
                characterMeshes = {},
                accessories     = {},
                characterClone  = nil,
            }

            if skinData.headMesh then
                local mesh = Instance.new(skinData.headMesh.ClassName)
                mesh.MeshId    = skinData.headMesh.MeshId
                mesh.TextureId = skinData.headMesh.TextureId
                if skinData.headMesh.Scale then
                    mesh.Scale = Vector3.new(unpack(skinData.headMesh.Scale))
                end
                newSkin.headMesh = mesh
            end

            for _, clothData in ipairs(skinData.clothes or {}) do
                local cloth = Instance.new(clothData.ClassName)
                if clothData.ClassName == "ShirtGraphic" then
                    cloth.Graphic = clothData.TextureId
                else
                    cloth[clothData.ClassName .. "Template"] = clothData.TextureId
                end
                table.insert(newSkin.clothes, cloth)
            end

            for _, meshData in ipairs(skinData.characterMeshes or {}) do
                pcall(function()
                    local m = Instance.new("CharacterMesh")
                    local bodyPartMap = {
                        Torso=Enum.BodyPart.Torso, LeftArm=Enum.BodyPart.LeftArm, RightArm=Enum.BodyPart.RightArm,
                        LeftLeg=Enum.BodyPart.LeftLeg, RightLeg=Enum.BodyPart.RightLeg, Head=Enum.BodyPart.Head,
                    }
                    if bodyPartMap[meshData.BodyPart] then
                        m.BodyPart = bodyPartMap[meshData.BodyPart]
                        if type(meshData.MeshId) == "number" then
                            m.MeshId = "rbxassetid://" .. meshData.MeshId
                        else
                            m.MeshId = meshData.MeshId
                        end
                        m.OverlayTextureId = meshData.OverlayTextureId or ""
                        table.insert(newSkin.characterMeshes, m)
                    end
                end)
            end

            for _, accData in ipairs(skinData.accessories or {}) do
                table.insert(newSkin.accessories, accData)
            end

            table.insert(savedSkins, newSkin)
        end
    end)
    if not ok then
        warn("[SkinChanger] Failed to load saved skins:", err)
    end
end

local okLoad, errLoad = pcall(loadSavedSkinsFromFile)
