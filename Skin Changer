function applySavedSkin(skinData)
    if not player.Character then return end
    -- Set savedSkinData so HeadIcon can use characterClone from saved skin
    savedSkinData = skinData
    if setHeadIconAvatar and skinData and skinData.userId then
        lastAppliedSkinUserId = skinData.userId
        lastAppliedSkinClone = skinData.characterClone
        setHeadIconAvatar(skinData.userId)
    end
    
    -- Find and save the index of this skin in savedSkins
    for i, skin in ipairs(savedSkins) do
        if skin.playerName == skinData.playerName and skin.userId == skinData.userId then
            lastAppliedSkinIndex = i
            local snapshot = { index = i, userId = skin.userId, playerName = skin.playerName }
            -- Save to autoexec file ONLY if autoexec is enabled
            pcall(function() scSetLastSkinIfAutoexec(snapshot) end)
            -- Always persist to Settings (used for reference/display; does NOT auto-apply on manual launch)
            pcall(function() scUpdateSetting("lastSkin", snapshot) end)
            break
        end
    end

    -- Don't remove glasses from savedSkinData - let them show in saved skins
    -- Only remove from character when applying

    -- Remove glasses accessories from player character immediately
    for _, item in ipairs(player.Character:GetChildren()) do
        local nameLower = item.Name:lower()
        if item:IsA("Accessory") and (nameLower:find("glass") or nameLower:find("очк") or nameLower:find("thinround") or nameLower:find("slot20") or nameLower:find("eyewear") or nameLower:find("sunglasses") or nameLower:find("shades") or nameLower:find("specs") or nameLower:find("visor")) then
            item:Destroy()
        end
        -- Also remove ACC_ prefixed parts that are glasses
        if item:IsA("BasePart") and item.Name:find("ACC_") and (nameLower:find("glass") or nameLower:find("очк") or nameLower:find("thinround") or nameLower:find("slot20") or nameLower:find("eyewear") or nameLower:find("sunglasses") or nameLower:find("shades") or nameLower:find("specs") or nameLower:find("visor")) then
            item:Destroy()
        end
    end

    -- Полная чистка персонажа перед применением нового скина (фикс mixed-skin)
    for _, item in ipairs(player.Character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            item:Destroy()
        end
        if item:IsA("BasePart") and item.Name:sub(1, 4) == "ACC_" then
            item:Destroy()
        end
        if item:IsA("CharacterMesh") then
            item:Destroy()
        end
    end
    for _, part in ipairs(player.Character:GetChildren()) do
        if part:IsA("BasePart") then
            for _, child in ipairs(part:GetChildren()) do
                if (child:IsA("Weld") or child:IsA("Motor6D")) and child.Name:find("Accessory") then
                    child:Destroy()
                end
            end
        end
    end

    task.wait(1.5)

    if skinData.bodyPartSizes then
        for partName, sizeData in pairs(skinData.bodyPartSizes) do
            local part = player.Character:FindFirstChild(partName)
            if part and part:IsA("BasePart") then part.Size = Vector3.new(unpack(sizeData)) end
        end
        task.spawn(function()
            task.wait(0.5)
            for partName, sizeData in pairs(skinData.bodyPartSizes) do
                local part = player.Character:FindFirstChild(partName)
                if part and part:IsA("BasePart") then part.Size = Vector3.new(unpack(sizeData)) end
            end
        end)
        task.spawn(function()
            task.wait(1.5)
            for partName, sizeData in pairs(skinData.bodyPartSizes) do
                local part = player.Character:FindFirstChild(partName)
                if part and part:IsA("BasePart") then part.Size = Vector3.new(unpack(sizeData)) end
            end
        end)
    end

    local myHumanoid = player.Character:FindFirstChild("Humanoid")
    if myHumanoid and skinData.bodyScales then
        pcall(function()
            if skinData.bodyScales.BodyDepthScale  and myHumanoid:FindFirstChild("BodyDepthScale")  then myHumanoid.BodyDepthScale.Value  = skinData.bodyScales.BodyDepthScale end
            if skinData.bodyScales.BodyWidthScale  and myHumanoid:FindFirstChild("BodyWidthScale")  then myHumanoid.BodyWidthScale.Value  = skinData.bodyScales.BodyWidthScale end
            if skinData.bodyScales.BodyHeightScale and myHumanoid:FindFirstChild("BodyHeightScale") then myHumanoid.BodyHeightScale.Value = skinData.bodyScales.BodyHeightScale end
            if skinData.bodyScales.HeadScale       and myHumanoid:FindFirstChild("HeadScale")       then myHumanoid.HeadScale.Value       = skinData.bodyScales.HeadScale end
        end)
    end

    for _, clothItem in ipairs(skinData.clothes or {}) do
        local clone = clothItem:Clone()
        if clone then
            clone.Parent = player.Character
        end
    end

    if skinData.bodyColors then
        local myBC = player.Character:FindFirstChild("Body Colors")
        if not myBC then myBC = Instance.new("BodyColors"); myBC.Parent = player.Character end
        myBC.HeadColor3     = skinData.bodyColors.HeadColor3
        myBC.LeftArmColor3  = skinData.bodyColors.LeftArmColor3
        myBC.LeftLegColor3  = skinData.bodyColors.LeftLegColor3
        myBC.RightArmColor3 = skinData.bodyColors.RightArmColor3
        myBC.RightLegColor3 = skinData.bodyColors.RightLegColor3
        myBC.TorsoColor3    = skinData.bodyColors.TorsoColor3

        local bodyParts = {
            {name="Head",color=skinData.bodyColors.HeadColor3},
            {name="LeftUpperArm",color=skinData.bodyColors.LeftArmColor3},
            {name="LeftLowerArm",color=skinData.bodyColors.LeftArmColor3},
            {name="LeftHand",color=skinData.bodyColors.LeftArmColor3},
            {name="RightUpperArm",color=skinData.bodyColors.RightArmColor3},
            {name="RightLowerArm",color=skinData.bodyColors.RightArmColor3},
            {name="RightHand",color=skinData.bodyColors.RightArmColor3},
            {name="LeftUpperLeg",color=skinData.bodyColors.LeftLegColor3},
            {name="LeftLowerLeg",color=skinData.bodyColors.LeftLegColor3},
            {name="LeftFoot",color=skinData.bodyColors.LeftLegColor3},
            {name="RightUpperLeg",color=skinData.bodyColors.RightLegColor3},
            {name="RightLowerLeg",color=skinData.bodyColors.RightLegColor3},
            {name="RightFoot",color=skinData.bodyColors.RightLegColor3},
            {name="UpperTorso",color=skinData.bodyColors.TorsoColor3},
            {name="LowerTorso",color=skinData.bodyColors.TorsoColor3},
            {name="Torso",color=skinData.bodyColors.TorsoColor3},
            {name="Left Arm",color=skinData.bodyColors.LeftArmColor3},
            {name="Right Arm",color=skinData.bodyColors.RightArmColor3},
            {name="Left Leg",color=skinData.bodyColors.LeftLegColor3},
            {name="Right Leg",color=skinData.bodyColors.RightLegColor3},
        }
        for _, pd in ipairs(bodyParts) do
            local part = player.Character:FindFirstChild(pd.name)
            if part and part:IsA("BasePart") then part.Color = pd.color end
        end
    end

    local myHead = player.Character:FindFirstChild("Head")
    if myHead then
        local oldFace = myHead:FindFirstChild("face")
        if oldFace then oldFace:Destroy() end
        if skinData.face then
            local f = Instance.new("Decal")
            f.Name = "face"; f.Face = Enum.NormalId.Front; f.Texture = skinData.face
            f.Parent = myHead
        end
    end

    if skinData.headMesh then
        local mh = player.Character:FindFirstChild("Head")
        if mh then
            local oldMesh = mh:FindFirstChildOfClass("SpecialMesh")
            if oldMesh then oldMesh:Destroy() end
            if skinData.headMesh then
                local newMesh = skinData.headMesh:Clone()
                if newMesh then
                    newMesh.Parent = mh
                end
            end
        end
    end

    for _, item in ipairs(player.Character:GetChildren()) do
        if item:IsA("CharacterMesh") then item:Destroy() end
    end
    for _, meshItem in ipairs(skinData.characterMeshes or {}) do
        local clone = meshItem:Clone()
        if clone then
            clone.Parent = player.Character
        end
    end

    if skinData.bodyPartMeshes then
        for partName, meshData in pairs(skinData.bodyPartMeshes) do
            local part = player.Character:FindFirstChild(partName)
            if part then
                if meshData.Type == "MeshPart" and part:IsA("MeshPart") then
                    part.MeshId = meshData.MeshId
                    if meshData.TextureID then part.TextureID = meshData.TextureID end
                    if meshData.Size then part.Size = Vector3.new(unpack(meshData.Size)) end
                elseif meshData.Type == "SpecialMesh" and part:IsA("BasePart") then
                    local oldMesh = part:FindFirstChildOfClass("SpecialMesh")
                    if oldMesh then oldMesh:Destroy() end
                    local newMesh = Instance.new("SpecialMesh")
                    newMesh.MeshType  = Enum.MeshType.FileMesh
                    newMesh.MeshId    = meshData.MeshId
                    newMesh.TextureId = meshData.TextureId or ""
                    if meshData.Scale then newMesh.Scale = Vector3.new(unpack(meshData.Scale)) end
                    newMesh.Parent = part
                    if meshData.Size then part.Size = Vector3.new(unpack(meshData.Size)) end
                end
            end
        end
    end

    for _, accessory in ipairs(skinData.accessories or {}) do
        pcall(function()
            -- Skip glasses accessories
            local accName = (type(accessory) == "table" and accessory.Name) or (typeof(accessory) == "Instance" and accessory.Name) or ""
            local nameLower = accName:lower()
            if nameLower:find("glass") or nameLower:find("очк") or nameLower:find("thinround") or nameLower:find("slot20") or nameLower:find("eyewear") or nameLower:find("sunglasses") or nameLower:find("shades") or nameLower:find("specs") or nameLower:find("visor") then
                return
            end

            if type(accessory) == "table" then
                if not accessory.MeshId or accessory.MeshId == "" then return end
                if not accessory.AttachmentName or accessory.AttachmentName == "" then return end

                local visualHandle = Instance.new("Part")
                visualHandle.Name = "ACC_" .. (accessory.Name or "Accessory")
                if accessory.IsMeshPart then
                    visualHandle.Size = Vector3.new(0.2, 0.2, 0.2)
                else
                    visualHandle.Size = Vector3.new(unpack(accessory.HandleSize or {1, 1, 1}))
                end
                visualHandle.Transparency = accessory.HandleTransparency or 0
                visualHandle.CanCollide = false; visualHandle.Massless = true; visualHandle.Anchored = true

                local mesh = Instance.new("SpecialMesh")
                mesh.MeshType  = Enum.MeshType.FileMesh
                mesh.MeshId    = accessory.MeshId
                mesh.TextureId = accessory.TextureId or ""
                mesh.Scale     = Vector3.new(unpack(accessory.MeshScale or {1, 1, 1}))
                mesh.Parent    = visualHandle

                local myAttachment, myPart = nil, nil
                for _, part in ipairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        local att = part:FindFirstChild(accessory.AttachmentName)
                        if att then myAttachment = att; myPart = part; break end
                    end
                end
                if not myAttachment then return end

                visualHandle.Parent = player.Character

                local offset = CFrame.new(0, 0, 0)
                if accessory.AttachmentCFrame and #accessory.AttachmentCFrame == 12 then
                    offset = CFrame.new(unpack(accessory.AttachmentCFrame))
                end
                local _accConn
                _accConn = RunService.RenderStepped:Connect(function()
                    if not visualHandle.Parent or not myPart.Parent then
                        if _accConn then _accConn:Disconnect(); _accConn = nil end
                        return
                    end
                    local currentAtt = myPart:FindFirstChild(myAttachment.Name)
                    if currentAtt then visualHandle.CFrame = currentAtt.WorldCFrame * offset:Inverse() end
                end)
            else
                local handle = accessory:FindFirstChild("Handle", true)
                if not handle then return end
                local handleAttachment = handle:FindFirstChildOfClass("Attachment")
                if not handleAttachment then return end

                local myAttachment, myPart = nil, nil
                for _, part in ipairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        local att = part:FindFirstChild(handleAttachment.Name)
                        if att then myAttachment = att; myPart = part; break end
                    end
                end
                if not myAttachment then return end

                local visualHandle = handle:Clone()
                if not visualHandle then return end
                visualHandle.Name = "ACC_" .. accessory.Name
                visualHandle.CanCollide = false; visualHandle.Massless = true; visualHandle.Anchored = true
                for _, child in ipairs(visualHandle:GetChildren()) do
                    if not child:IsA("SpecialMesh") and not child:IsA("Decal")
                       and not child:IsA("Texture") and not child:IsA("SurfaceAppearance") then
                        child:Destroy()
                    end
                end
                visualHandle.Parent = player.Character

                local offset = handleAttachment.CFrame
                local _accConn
                _accConn = RunService.RenderStepped:Connect(function()
                    if not visualHandle.Parent or not myPart.Parent then
                        if _accConn then _accConn:Disconnect(); _accConn = nil end
                        return
                    end
                    local currentAtt = myPart:FindFirstChild(myAttachment.Name)
                    if currentAtt then visualHandle.CFrame = currentAtt.WorldCFrame * offset:Inverse() end
                end)
            end
        end)
    end
end

----------------------------------------------------------------
-- applySkin (живой target)
----------------------------------------------------------------
function applySkin(targetPlayer)
    if not player.Character then return end
    local targetChar = targetPlayer.Character
    if not targetChar then return end
    if not targetChar:FindFirstChild("Humanoid") or not targetChar:FindFirstChild("Head") then return end

    lastAppliedPlayer = targetPlayer
    lastAppliedSkinUserId = targetPlayer.UserId
    lastAppliedSkinClone = nil
    if setHeadIconAvatar then setHeadIconAvatar(targetPlayer.UserId) end

    savedSkinData = {
        playerName      = targetPlayer.Name,
        userId          = targetPlayer.UserId,
        clothes         = {},
        bodyColors      = nil,
        face            = nil,
        headMesh        = nil,
        characterMeshes = {},
        accessories     = {},
    }

    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            local clone = item:Clone()
            if clone then
                table.insert(savedSkinData.clothes, clone)
            end
        end
    end

    local targetBC = targetChar:FindFirstChild("Body Colors")
    if targetBC then
        savedSkinData.bodyColors = {
            HeadColor3=targetBC.HeadColor3, LeftArmColor3=targetBC.LeftArmColor3,
            LeftLegColor3=targetBC.LeftLegColor3, RightArmColor3=targetBC.RightArmColor3,
            RightLegColor3=targetBC.RightLegColor3, TorsoColor3=targetBC.TorsoColor3,
        }
    end

    local targetHead = targetChar:FindFirstChild("Head")
    if targetHead then
        local f = targetHead:FindFirstChild("face")
        if f then savedSkinData.face = f.Texture end
        local m = targetHead:FindFirstChildOfClass("SpecialMesh")
        if m then
            local clone = m:Clone()
            if clone then
                savedSkinData.headMesh = clone
            end
        end
    end

    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("CharacterMesh") then
            local clone = item:Clone()
            if clone then
                table.insert(savedSkinData.characterMeshes, clone)
            end
        end
    end
    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("Accessory") then
            local clone = item:Clone()
            if clone then
                table.insert(savedSkinData.accessories, clone)
            end
        end
    end

    -- Don't remove glasses from savedSkinData - let them show in saved skins
    -- Only remove from character when applying

    -- Remove glasses accessories from player character immediately
    for _, item in ipairs(player.Character:GetChildren()) do
        local nameLower = item.Name:lower()
        if item:IsA("Accessory") and (nameLower:find("glass") or nameLower:find("очк") or nameLower:find("thinround") or nameLower:find("slot20") or nameLower:find("eyewear") or nameLower:find("sunglasses") or nameLower:find("shades") or nameLower:find("specs") or nameLower:find("visor")) then
            item:Destroy()
        end
        -- Also remove ACC_ prefixed parts that are glasses
        if item:IsA("BasePart") and item.Name:find("ACC_") and (nameLower:find("glass") or nameLower:find("очк") or nameLower:find("thinround") or nameLower:find("slot20") or nameLower:find("eyewear") or nameLower:find("sunglasses") or nameLower:find("shades") or nameLower:find("specs") or nameLower:find("visor")) then
            item:Destroy()
        end
    end

    -- Remove all accessories, clothes, etc from player character
    for _, item in ipairs(player.Character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            item:Destroy()
        end
        if item:IsA("BasePart") and item.Name:sub(1, 4) == "ACC_" then
            item:Destroy()
        end
        if item:IsA("CharacterMesh") then
            item:Destroy()
        end
    end
    for _, part in ipairs(player.Character:GetChildren()) do
        if part:IsA("BasePart") then
            for _, child in ipairs(part:GetChildren()) do
                if (child:IsA("Weld") or child:IsA("Motor6D")) and child.Name:find("Accessory") then
                    child:Destroy()
                end
            end
        end
    end

    task.wait(1.5)

    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            local clone = item:Clone()
            if clone then
                clone.Parent = player.Character
            end
        end
    end

    targetBC = targetChar:FindFirstChild("Body Colors")
    if targetBC then
        local myBC = player.Character:FindFirstChild("Body Colors")
        if not myBC then myBC = Instance.new("BodyColors"); myBC.Parent = player.Character end
        myBC.HeadColor3=targetBC.HeadColor3; myBC.LeftArmColor3=targetBC.LeftArmColor3
        myBC.LeftLegColor3=targetBC.LeftLegColor3; myBC.RightArmColor3=targetBC.RightArmColor3
        myBC.RightLegColor3=targetBC.RightLegColor3; myBC.TorsoColor3=targetBC.TorsoColor3

        local bp = {
            {name="Head",color=targetBC.HeadColor3},
            {name="LeftUpperArm",color=targetBC.LeftArmColor3},{name="LeftLowerArm",color=targetBC.LeftArmColor3},
            {name="LeftHand",color=targetBC.LeftArmColor3},
            {name="RightUpperArm",color=targetBC.RightArmColor3},{name="RightLowerArm",color=targetBC.RightArmColor3},
            {name="RightHand",color=targetBC.RightArmColor3},
            {name="LeftUpperLeg",color=targetBC.LeftLegColor3},{name="LeftLowerLeg",color=targetBC.LeftLegColor3},
            {name="LeftFoot",color=targetBC.LeftLegColor3},
            {name="RightUpperLeg",color=targetBC.RightLegColor3},{name="RightLowerLeg",color=targetBC.RightLegColor3},
            {name="RightFoot",color=targetBC.RightLegColor3},
            {name="UpperTorso",color=targetBC.TorsoColor3},{name="LowerTorso",color=targetBC.TorsoColor3},
            {name="Torso",color=targetBC.TorsoColor3},
            {name="Left Arm",color=targetBC.LeftArmColor3},{name="Right Arm",color=targetBC.RightArmColor3},
            {name="Left Leg",color=targetBC.LeftLegColor3},{name="Right Leg",color=targetBC.RightLegColor3},
        }
        for _, pd in ipairs(bp) do
            local part = player.Character:FindFirstChild(pd.name)
            if part and part:IsA("BasePart") then part.Color = pd.color end
        end
    end

    local myHead = player.Character:FindFirstChild("Head")
    targetHead = targetChar:FindFirstChild("Head")
    if myHead and targetHead then
        local oldFace = myHead:FindFirstChild("face")
        if oldFace then oldFace:Destroy() end
        local tf = targetHead:FindFirstChild("face")
        if tf then
            local mf = Instance.new("Decal")
            mf.Name="face"; mf.Face=Enum.NormalId.Front; mf.Texture=tf.Texture
            mf.Parent = myHead
        end
        local tm = targetHead:FindFirstChildOfClass("SpecialMesh")
        if tm then
            local mm = myHead:FindFirstChildOfClass("SpecialMesh")
            if mm then mm:Destroy() end
            local cm = tm:Clone()
            if cm then
                cm.Parent = myHead
            end
        end
    end

    for _, item in ipairs(player.Character:GetChildren()) do
        if item:IsA("CharacterMesh") then item:Destroy() end
    end
    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("CharacterMesh") then
            local clone = item:Clone()
            if clone then
                clone.Parent = player.Character
            end
        end
    end

    if player.Character and savedSkinData and savedSkinData.accessories then
        for _, accessory in ipairs(savedSkinData.accessories) do
            pcall(function()
                -- Skip glasses accessories
                local accName = accessory.Name or ""
                local nameLower = accName:lower()
                if nameLower:find("glass") or nameLower:find("очк") or nameLower:find("thinround") or nameLower:find("slot20") or nameLower:find("eyewear") or nameLower:find("sunglasses") or nameLower:find("shades") or nameLower:find("specs") or nameLower:find("visor") then
                    return
                end

                local handle = accessory:FindFirstChild("Handle", true)
                if not handle then return end
                local ha = handle:FindFirstChildOfClass("Attachment")
                if not ha then return end

                local myAttachment, myPart = nil, nil
                for _, part in ipairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        local att = part:FindFirstChild(ha.Name)
                        if att then myAttachment=att; myPart=part; break end
                    end
                end
                if not myAttachment then return end

                local vh = handle:Clone()
                if not vh then return end
                vh.Name = "ACC_" .. accessory.Name
                vh.CanCollide=false; vh.Massless=true; vh.Anchored=true
                for _, child in ipairs(vh:GetChildren()) do
                    if not child:IsA("SpecialMesh") and not child:IsA("Decal")
                       and not child:IsA("Texture") and not child:IsA("SurfaceAppearance") then
                        child:Destroy()
                    end
                end
                vh.Parent = player.Character

                local offset = ha.CFrame
                local _accConn
                _accConn = RunService.RenderStepped:Connect(function()
                    if not vh.Parent or not myPart.Parent then
                        if _accConn then _accConn:Disconnect(); _accConn = nil end
                        return
                    end
                    local cur = myPart:FindFirstChild(myAttachment.Name)
                    if cur then vh.CFrame = cur.WorldCFrame * offset:Inverse() end
                end)
            end)
        end
    end

    local th = targetChar:FindFirstChild("Humanoid")
    local mh = player.Character:FindFirstChild("Humanoid")
    if mh and th then
        pcall(function()
            if th:FindFirstChild("BodyDepthScale")  and mh:FindFirstChild("BodyDepthScale")  then mh.BodyDepthScale.Value  = th.BodyDepthScale.Value end
            if th:FindFirstChild("BodyWidthScale")  and mh:FindFirstChild("BodyWidthScale")  then mh.BodyWidthScale.Value  = th.BodyWidthScale.Value end
            if th:FindFirstChild("BodyHeightScale") and mh:FindFirstChild("BodyHeightScale") then mh.BodyHeightScale.Value = th.BodyHeightScale.Value end
            if th:FindFirstChild("HeadScale")       and mh:FindFirstChild("HeadScale")       then mh.HeadScale.Value       = th.HeadScale.Value end
        end)
    end
end

----------------------------------------------------------------
-- restoreOriginalSkin
----------------------------------------------------------------
function restoreOriginalSkin()
    if not originalPlayerCharacter or not player.Character then return end
    lastAppliedSkinUserId = player.UserId
    lastAppliedSkinClone = nil
    if setHeadIconAvatar then setHeadIconAvatar(player.UserId) end

    -- Remove glasses accessories if glasses are open
    if g_glassesOpen then
        for _, item in ipairs(player.Character:GetChildren()) do
            if item:IsA("Accessory") and (item.Name:lower():find("glass") or item.Name:lower():find("очк") or item.Name:lower():find("thinround")) then
                item:Destroy()
            end
            -- Also remove ACC_ prefixed parts that are glasses
            if item:IsA("BasePart") and item.Name:find("ACC_") and (item.Name:lower():find("glass") or item.Name:lower():find("очк") or item.Name:lower():find("thinround")) then
                item:Destroy()
            end
        end
    end

    for _, item in ipairs(player.Character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            item:Destroy()
        end
        if item:IsA("BasePart") and item.Name:sub(1, 4) == "ACC_" then item:Destroy() end
        if item:IsA("CharacterMesh") then item:Destroy() end
    end
    for _, part in ipairs(player.Character:GetChildren()) do
        if part:IsA("BasePart") then
            for _, child in ipairs(part:GetChildren()) do
                if (child:IsA("Weld") or child:IsA("Motor6D")) and child.Name:find("Accessory") then
                    child:Destroy()
                end
            end
        end
    end

    task.wait(0.5)

    for _, item in ipairs(originalPlayerCharacter:GetChildren()) do
        if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            local clone = item:Clone()
            if clone then
                clone.Parent = player.Character
            end
        end
    end

    for _, accessory in ipairs(originalPlayerCharacter:GetChildren()) do
        if accessory:IsA("Accessory") then
            pcall(function()
                local handle = accessory:FindFirstChild("Handle", true)
                if not handle then return end
                local ha = handle:FindFirstChildOfClass("Attachment")
                if not ha then return end
                local myAttachment, myPart = nil, nil
                for _, part in ipairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        local att = part:FindFirstChild(ha.Name)
                        if att then myAttachment=att; myPart=part; break end
                    end
                end
                if not myAttachment then return end
                local vh = handle:Clone()
                if not vh then return end
                vh.Name = "ACC_" .. accessory.Name
                vh.CanCollide=false; vh.Massless=true; vh.Anchored=true
                for _, child in ipairs(vh:GetChildren()) do
                    if not child:IsA("SpecialMesh") and not child:IsA("Decal")
                       and not child:IsA("Texture") and not child:IsA("SurfaceAppearance") then
                        child:Destroy()
                    end
                end
                vh.Parent = player.Character
                local offset = ha.CFrame
                local _accConn
                _accConn = RunService.RenderStepped:Connect(function()
                    if not vh.Parent or not myPart.Parent then
                        if _accConn then _accConn:Disconnect(); _accConn = nil end
                        return
                    end
                    local cur = myPart:FindFirstChild(myAttachment.Name)
                    if cur then vh.CFrame = cur.WorldCFrame * offset:Inverse() end
                end)
            end)
        end
    end

    local oBC = originalPlayerCharacter:FindFirstChild("Body Colors")
    if oBC then
        local myBC = player.Character:FindFirstChild("Body Colors")
        if not myBC then myBC = Instance.new("BodyColors"); myBC.Parent = player.Character end
        myBC.HeadColor3=oBC.HeadColor3; myBC.LeftArmColor3=oBC.LeftArmColor3
        myBC.LeftLegColor3=oBC.LeftLegColor3; myBC.RightArmColor3=oBC.RightArmColor3
        myBC.RightLegColor3=oBC.RightLegColor3; myBC.TorsoColor3=oBC.TorsoColor3
    end

    local oH = originalPlayerCharacter:FindFirstChild("Head")
    local mH = player.Character:FindFirstChild("Head")
    if oH and mH then
        local of = mH:FindFirstChild("face")
        if of then of:Destroy() end
        local oF = oH:FindFirstChild("face")
        if oF then
            local mf = Instance.new("Decal")
            mf.Name="face"; mf.Face=Enum.NormalId.Front; mf.Texture=oF.Texture
            mf.Parent = mH
        end
        local oM = oH:FindFirstChildOfClass("SpecialMesh")
        if oM then
            local mM = mH:FindFirstChildOfClass("SpecialMesh")
            if mM then mM:Destroy() end
            local cm = oM:Clone()
            if cm then
                cm.Parent = mH
            end
        end
    end

    for _, item in ipairs(originalPlayerCharacter:GetChildren()) do
        if item:IsA("CharacterMesh") then
            local clone = item:Clone()
            if clone then
                clone.Parent = player.Character
            end
        end
    end

    savedSkinData = nil
    lastAppliedPlayer = nil
end

----------------------------------------------------------------
-- captureSkinSnapshot для SAVE кнопки
----------------------------------------------------------------
function captureSkinSnapshot(targetPlayer)
    local skinData = {
        playerName=targetPlayer.Name, customLabel=nil, userId=targetPlayer.UserId,
        clothes={}, bodyColors=nil, face=nil, headMesh=nil,
        characterMeshes={}, accessories={}, characterClone=nil,
        -- Removed live thumbnail URLs - they cause wrong icon display when player changes appearance
    }
    local targetChar = targetPlayer.Character
    if not targetChar then return nil end

    pcall(function() skinData.characterClone = targetChar:Clone() end)

    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            local clone = item:Clone()
            if clone then
                table.insert(skinData.clothes, clone)
            end
        end
    end

    local tBC = targetChar:FindFirstChild("Body Colors")
    if tBC then
        skinData.bodyColors = {
            HeadColor3=tBC.HeadColor3, LeftArmColor3=tBC.LeftArmColor3,
            LeftLegColor3=tBC.LeftLegColor3, RightArmColor3=tBC.RightArmColor3,
            RightLegColor3=tBC.RightLegColor3, TorsoColor3=tBC.TorsoColor3,
        }
    end

    for _, item in ipairs(targetChar:GetChildren()) do
        if item:IsA("CharacterMesh") then
            local clone = item:Clone()
            if clone then
                table.insert(skinData.characterMeshes, clone)
            end
        end
    end

    skinData.bodyPartMeshes = {}
    local bodyParts = {"Head","Torso","Left Arm","Right Arm","Left Leg","Right Leg",
        "LeftUpperArm","LeftLowerArm","LeftHand","RightUpperArm","RightLowerArm","RightHand",
        "LeftUpperLeg","LeftLowerLeg","LeftFoot","RightUpperLeg","RightLowerLeg","RightFoot",
        "UpperTorso","LowerTorso"}
    for _, partName in ipairs(bodyParts) do
        local part = targetChar:FindFirstChild(partName)
        if part then
            if part:IsA("MeshPart") then
                skinData.bodyPartMeshes[partName] = {
                    Type="MeshPart", MeshId=part.MeshId, TextureID=part.TextureID,
                    Size={part.Size.X,part.Size.Y,part.Size.Z},
                }
            elseif part:IsA("BasePart") then
                local mesh = part:FindFirstChildOfClass("SpecialMesh")
                if mesh then
                    skinData.bodyPartMeshes[partName] = {
                        Type="SpecialMesh", MeshId=mesh.MeshId, TextureId=mesh.TextureId,
                        Scale={mesh.Scale.X,mesh.Scale.Y,mesh.Scale.Z},
                        Size={part.Size.X,part.Size.Y,part.Size.Z},
                    }
                end
            end
        end
    end

    skinData.bodyPartSizes = {}
    for _, partName in ipairs(bodyParts) do
        local part = targetChar:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            skinData.bodyPartSizes[partName] = {part.Size.X, part.Size.Y, part.Size.Z}
        end
    end

    local tH = targetChar:FindFirstChild("Humanoid")
    if tH then
        skinData.bodyScales = {}
        if tH:FindFirstChild("BodyDepthScale")  then skinData.bodyScales.BodyDepthScale  = tH.BodyDepthScale.Value end
        if tH:FindFirstChild("BodyWidthScale")  then skinData.bodyScales.BodyWidthScale  = tH.BodyWidthScale.Value end
        if tH:FindFirstChild("BodyHeightScale") then skinData.bodyScales.BodyHeightScale = tH.BodyHeightScale.Value end
        if tH:FindFirstChild("HeadScale")       then skinData.bodyScales.HeadScale       = tH.HeadScale.Value end
    end

    local tHead = targetChar:FindFirstChild("Head")
    if tHead then
        local f = tHead:FindFirstChild("face")
        if f then skinData.face = f.Texture end
        local m = tHead:FindFirstChildOfClass("SpecialMesh")
        if m then
            local clone = m:Clone()
            if clone then
                skinData.headMesh = clone
            end
        end
    end

    -- If capturing from local player with applied skin, use savedSkinData accessories
    if targetPlayer == player and savedSkinData and savedSkinData.accessories and #savedSkinData.accessories > 0 then
        for _, acc in ipairs(savedSkinData.accessories) do
            if typeof(acc) == "Instance" then
                local clone = acc:Clone()
                if clone then
                    table.insert(skinData.accessories, clone)
                end
            elseif type(acc) == "table" then
                table.insert(skinData.accessories, acc)
            end
        end
    else
        -- Otherwise capture from character (both Accessory instances and ACC_ parts)
        for _, item in ipairs(targetChar:GetChildren()) do
            if item:IsA("Accessory") then
                local clone = item:Clone()
                if clone then
                    table.insert(skinData.accessories, clone)
                end
            end
        end
        -- Also capture ACC_ prefixed parts as accessories
        for _, item in ipairs(targetChar:GetChildren()) do
            if item:IsA("BasePart") and item.Name:sub(1, 4) == "ACC_" then
                local mesh = item:FindFirstChildOfClass("SpecialMesh")
                if mesh then
                    table.insert(skinData.accessories, {
                        Name = item.Name:sub(5),
                        MeshId = mesh.MeshId,
                        TextureId = mesh.TextureId or "",
                        MeshScale = {mesh.Scale.X, mesh.Scale.Y, mesh.Scale.Z},
                        HandleSize = {item.Size.X, item.Size.Y, item.Size.Z},
                        HandleTransparency = item.Transparency,
                        IsMeshPart = item:IsA("MeshPart"),
                        AttachmentName = "FaceFront",
                    })
                end
            end
        end
    end

    return skinData
end

