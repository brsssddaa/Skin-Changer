-- ============= FOLLOW + BOB (physics-based pet-like) =============
-- Вычисляем скорость игрока для idle sway
RunService.RenderStepped:Connect(function(dt)
    if scriptDisabled then return end
    if not glassesMenuVisible then return end
    if not g_character or not g_character.Parent then return end
    local hrp = g_character:FindFirstChild("HumanoidRootPart") or g_character:FindFirstChild("Torso")
    if not hrp then return end
    if not g_anchorForward then return end

    local now = tick()
    local center = hrp.Position + Vector3.new(0, 1.5, 0)
    local distance = 6

    -- Вычисляем скорость игрока (для star rate)
    if g_lastPlayerPos then
        local vel = (hrp.Position - g_lastPlayerPos) / math.max(dt, 0.001)
        g_playerVelocity = Vector3.new(vel.X, 0, vel.Z)
    end
    g_lastPlayerPos = hrp.Position
    local playerSpeed = math.min(g_playerVelocity.Magnitude, 50)
    local isIdle = playerSpeed < 0.5

    -- Привязка к ИГРОКУ: forward из направления игрока. В первом лице - фризим (не крутим по камере)
    do
        local cam = workspace.CurrentCamera
        local head = g_character:FindFirstChild("Head")
        local isFirstPerson = false
        if cam and head then
            isFirstPerson = (cam.CFrame.Position - head.Position).Magnitude < 1.2
        end
        if not isFirstPerson then
            local fwd = hrp.CFrame.LookVector
            fwd = Vector3.new(fwd.X, 0, fwd.Z)
            if fwd.Magnitude > 0.001 then
                fwd = fwd.Unit
                local alpha = 1 - math.exp(-dt * 4.0)
                local newFwd = g_anchorForward:Lerp(fwd, alpha)
                if newFwd.Magnitude > 0.01 then
                    g_anchorForward = newFwd.Unit
                end
            end
        end
        -- в первом лице g_anchorForward не меняется - панели стоят на месте
    end

    for _, p in ipairs(worldPanels) do
        if p.part and p.part.Parent then
            local effectiveAngle = p.baseAngle + (p.angleOffset or 0)
            local dir = CFrame.Angles(0, math.rad(effectiveAngle), 0) * g_anchorForward

            -- Target position с лёгким покачиванием + высота от drag
            local bob = math.sin(now * 1.8 + p.phase) * 0.18
            local sway = isIdle and (math.sin(now * 1.0 + p.phase * 2) * 0.12) or 0
            local heightOffset = p.heightOffset or 0
            local targetPos = center + dir * distance + Vector3.new(0, bob + sway + heightOffset, 0)

            -- Простой плавный lerp позиции (стабильно, без spring-нестабильности)
            if not p.currentPos then
                p.currentPos = targetPos
            end
            local posAlpha = 1 - math.exp(-dt * 5.0)  -- плавное полёт-следование
            p.currentPos = p.currentPos:Lerp(targetPos, posAlpha)

            -- Поворот к игроку (плавный)
            local targetCF = CFrame.lookAt(p.currentPos, center)
            -- Apply flip rotation from panel data
            if p.flipRotation and p.flipRotation ~= 0 then
                targetCF = targetCF * CFrame.Angles(0, p.flipRotation, 0)
            end
            p.part.CFrame = targetCF

            if p.starEmitter then p.starEmitter.Rate = math.min(60 + playerSpeed * 3, 150) end
        end
    end
end)

