function wmPanelRoot(sg, onDragStart, onDragInput, onDragEnd)
    local root = Instance.new("Frame")
    root.Size = UDim2.fromScale(1, 1)
    root.BackgroundColor3 = C.BLACK
    root.BackgroundTransparency = 0.1
    root.BorderSizePixel = 0
    root.Parent = sg
    wmCorner(root, 14)
    wmStroke(root, Theme.primary, 2.5, 0)

    -- Drag handle в верхней части панели
    local dragHandle = Instance.new("TextButton")
    dragHandle.Name = "DragHandle"
    dragHandle.Size = UDim2.new(1, -40, 0, 28)
    dragHandle.Position = UDim2.new(0, 20, 0, 4)
    dragHandle.BackgroundColor3 = C.BG_PANEL
    dragHandle.BackgroundTransparency = 1
    dragHandle.Text = "⋮⋮⋮"
    dragHandle.TextColor3 = C.TEXT_MUTE
    dragHandle.TextSize = 14
    dragHandle.Font = FONT_SEMI
    dragHandle.AutoButtonColor = false
    dragHandle.Parent = root
    wmCorner(dragHandle, 6)

    local dragHint = Instance.new("UIStroke")
    dragHint.Color = Theme.primary
    dragHint.Thickness = 1
    dragHint.Transparency = 1
    dragHint.Parent = dragHandle

    -- Hover effect
    dragHandle.MouseEnter:Connect(function()
        tween(dragHandle, 0.15, {BackgroundTransparency = 0.6})
        tween(dragHint, 0.15, {Transparency = 0.3})
    end)
    dragHandle.MouseLeave:Connect(function()
        tween(dragHandle, 0.15, {BackgroundTransparency = 1})
        tween(dragHint, 0.15, {Transparency = 1})
    end)

    -- Drag logic
    local dragging = false
    local startX, startY = 0, 0
    local startPos = UDim2.new()

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.MouseButton2
           or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startPos = UDim2.new()
            if onDragStart then onDragStart() end
        end
    end)

    local moveConn = UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local camera = workspace.CurrentCamera
            local screenSize = camera.ViewportSize
            local screenCenterX = screenSize.X / 2
            local screenCenterY = screenSize.Y / 2
            local mouseX = input.Position.X
            local mouseY = input.Position.Y
            if onDragInput then onDragInput(mouseX, mouseY, screenCenterX, screenCenterY) end
        end
    end)

    local endConn = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.MouseButton2
           or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            if onDragEnd then onDragEnd() end
        end
    end)

    -- Сохраняем коннекшены для очистки при удалении панели
    uiConnections[dragHandle] = {move = moveConn, endConn = endConn}

    -- Make entire panel draggable (SurfaceGui не имеет Position — просто помечаем dragging)
    root.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.MouseButton2
           or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startX = input.Position.X
            startY = input.Position.Y
            startPos = UDim2.new()
            if onDragStart then onDragStart() end
        end
    end)

    -- декоративные luxury-X в углах
    local function addCornerMark(ax, ay, ox, oy)
        local frame = Instance.new("Frame")
        frame.AnchorPoint = Vector2.new(ax, ay)
        frame.Size = UDim2.fromOffset(18, 18)
        frame.Position = UDim2.new(ax, ox, ay, oy)
        frame.BackgroundTransparency = 1
        frame.Parent = root
        local h = Instance.new("Frame")
        h.AnchorPoint = Vector2.new(0.5, 0.5)
        h.Position = UDim2.fromScale(0.5, 0.5)
        h.Size = UDim2.fromOffset(16, 1.5)
        h.BackgroundColor3 = Theme.primary
        h.BorderSizePixel = 0
        h.Rotation = 45
        h.Parent = frame
        local v = h:Clone()
        if v then
            v.Rotation = -45
            v.Parent = frame
        end
    end
    addCornerMark(0, 0, 12, 12)
    addCornerMark(1, 0, -12, 12)
    addCornerMark(0, 1, 12, -12)
    addCornerMark(1, 1, -12, -12)

    return root
end

