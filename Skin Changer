function g_resetJoints()
    local char = player.Character
    if not char then return end
    g_character = char
    g_humanoid  = char:FindFirstChildOfClass("Humanoid")
    g_torso     = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    g_rigType   = char:FindFirstChild("UpperTorso") and "R15" or "R6"

    if g_rigType == "R15" then
        -- Ждём загрузки Rig (иначе joints могут отсутствовать)
        local function waitFor(inst, name, deep)
            local max = 30
            local child
            for i = 1, max do
                if deep then
                    child = inst:FindFirstChild(name, true)
                else
                    child = inst:FindFirstChild(name)
                end
                if child then break end
                task.wait(0.05)
            end
            return child
        end
        g_rightShoulder = waitFor(char, "RightShoulder", true)
        g_rightElbow    = waitFor(char, "RightElbow", true)
        g_neck          = waitFor(char, "Neck", true)
    else
        local t = char:WaitForChild("Torso", 2)
        if t then
            g_rightShoulder = t:FindFirstChild("Right Shoulder")
            g_rightElbow    = nil
            g_neck          = t:FindFirstChild("Neck")
        end
    end

    if g_rightShoulder then g_origRSC0   = g_rightShoulder.C0 end
    if g_rightElbow    then g_origREC0   = g_rightElbow.C0    end
    if g_neck          then g_origNeckC0 = g_neck.C0          end
end

function g_getAdaptiveHandOffset(handPart)
    local baseOffset = G_POSES[g_rigType].glassesInHand
    if not handPart then return baseOffset end
    local hs = handPart.Size
    local rotationOnly = baseOffset - baseOffset.Position
    local grip = handPart:FindFirstChild("RightGripAttachment")
    if grip and grip:IsA("Attachment") then
        local gripDown    = math.clamp(hs.Y * 0.06, 0.0, 0.12)
        local gripForward = math.clamp(hs.Z * 0.38, 0.12, 0.35)
        return CFrame.new(grip.Position + Vector3.new(0, -gripDown, -gripForward)) * rotationOnly
    end
    if g_rigType == "R6" and handPart.Name == "Right Arm" then
        local isClassic = math.abs(hs.X - 1) < 0.12 and math.abs(hs.Y - 2) < 0.18 and math.abs(hs.Z - 1) < 0.12
        if isClassic then return baseOffset end
    end
    local wristToPalm, palmForward, sideShift
    if g_rigType == "R6" then
        wristToPalm = math.clamp(hs.Y * 0.46, 0.48, 1.15)
        palmForward = math.clamp(hs.Z * 0.68, 0.40, 0.95)
        sideShift   = math.clamp(hs.X * 0.10, 0.05, 0.20)
    else
        wristToPalm = math.clamp(hs.Y * 0.16, 0.08, 0.28)
        palmForward = math.clamp(hs.Z * 0.75, 0.28, 0.78)
        sideShift   = math.clamp(hs.X * 0.18, 0.07, 0.22)
    end
    return CFrame.new(sideShift, -wristToPalm, palmForward) * rotationOnly
end

function g_attachToHand()
    if not g_glasses or not g_character then return end
    local rightHand = g_character:FindFirstChild("RightHand") or g_character:FindFirstChild("Right Arm")
    if not rightHand then return end
    if g_headWeld then g_headWeld:Destroy(); g_headWeld = nil end
    if g_handWeld then g_handWeld:Destroy(); g_handWeld = nil end
    local offset = g_getAdaptiveHandOffset(rightHand)
    g_glasses:SetPrimaryPartCFrame(rightHand.CFrame * offset)
    g_glasses.Parent = g_character
    g_handWeld = Instance.new("Weld")
    g_handWeld.Name = "GlassesHandWeld"
    g_handWeld.Part0 = rightHand
    g_handWeld.Part1 = g_glasses.PrimaryPart
    g_handWeld.C0    = offset
    g_handWeld.Parent = g_glasses.PrimaryPart
    g_glassesBaseC0 = offset  -- Сохраняем базовый offset для анимации переворота
end

function g_attachToHead()
    if not g_glasses or not g_character then return end
    local head = g_character:FindFirstChild("Head")
    if not head then return end
    if g_handWeld then g_handWeld:Destroy(); g_handWeld = nil end
    if g_headWeld then g_headWeld:Destroy(); g_headWeld = nil end
    local headOffset = G_POSES[g_rigType].glassesOnHead
    g_headWeld = Instance.new("Weld")
    g_headWeld.Name = "GlassesHeadWeld"
    g_headWeld.Part0 = head
    g_headWeld.Part1 = g_glasses.PrimaryPart
    g_headWeld.C0    = headOffset
    g_headWeld.Parent = g_glasses.PrimaryPart
    g_glasses.Parent = g_character
end

function g_putOnGlasses()
    if g_isAnimating or g_glassesOpen then
        return
    end
    if not g_rightShoulder or not g_rigType then
        return
    end
    g_isAnimating = true
    -- Save glasses state
    pcall(function() scSetGlassesState("open") end)
    local P = G_POSES[g_rigType]

    -- Remove skin's glasses accessories
    if g_character then
        for _, item in ipairs(g_character:GetChildren()) do
            if item:IsA("Accessory") and (item.Name:lower():find("glass") or item.Name:lower():find("очк")) then
                item:Destroy()
            end
            -- Also remove ACC_ prefixed parts that are glasses
            if item:IsA("BasePart") and item.Name:find("ACC_") and (item.Name:lower():find("glass") or item.Name:lower():find("очк")) then
                item:Destroy()
            end
        end
    end

    -- 1) Рука в центр туловища
    if g_neck and P.center_Neck then
        TweenService:Create(g_neck, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0 * P.center_Neck}):Play()
    end
    local t1 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
        {C0 = g_origRSC0 * P.center_Shoulder}); t1:Play()
    if g_rightElbow and P.center_Elbow then
        TweenService:Create(g_rightElbow, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
            {C0 = g_origREC0 * P.center_Elbow}):Play()
    end
    t1.Completed:Wait()
    task.wait(0.1)

    -- 2) Рука в задний карман
    if g_neck then
        TweenService:Create(g_neck, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0 * P.reachNeck}):Play()
    end
    local t2 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
        {C0 = g_origRSC0 * P.reachR_Shoulder}); t2:Play()
    if g_rightElbow and P.reachR_Elbow then
        TweenService:Create(g_rightElbow, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origREC0 * P.reachR_Elbow}):Play()
    end
    t2.Completed:Wait()
    task.wait(POCKET_HOLD_TIME_G)

    -- Создаём очки в руке
    local headPart = g_character and g_character:FindFirstChild("Head")
    g_glasses = g_createGlasses(headPart and headPart.Size or nil)
    g_attachToHand()

    -- 3) Рука вперёд
    if g_neck then
        TweenService:Create(g_neck, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0 * P.takeNeck}):Play()
    end
    local t3 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
        {C0 = g_origRSC0 * P.takeR_Shoulder}); t3:Play()
    if g_rightElbow and P.takeR_Elbow then
        TweenService:Create(g_rightElbow, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origREC0 * P.takeR_Elbow}):Play()
    end
    t3.Completed:Wait()

    -- 4) Рука поворачивается и очки переворачиваются
    if g_neck then
        TweenService:Create(g_neck, TweenInfo.new(0.7, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0 * P.raiseNeck}):Play()
    end
    local t4 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.7, Enum.EasingStyle.Quad),
        {C0 = g_origRSC0 * P.raiseR_Shoulder}); t4:Play()
    if g_rightElbow and P.raiseR_Elbow then
        TweenService:Create(g_rightElbow, TweenInfo.new(0.7, Enum.EasingStyle.Quad),
            {C0 = g_origREC0 * P.raiseR_Elbow}):Play()
    end
    -- Переворачиваем очки во время движения
    if g_handWeld and g_glassesBaseC0 then
        TweenService:Create(g_handWeld, TweenInfo.new(0.7, Enum.EasingStyle.Quad),
            {C0 = g_glassesBaseC0 * CFrame.Angles(0, 0, math.rad(180))}):Play()
    end
    t4.Completed:Wait()

    -- 5) Рука из перевёрнутого положения прямо к глазам (не возвращаем ключицу)
    if g_neck then
        TweenService:Create(g_neck, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0 * P.putOnNeck}):Play()
    end
    -- Сохраняем текущий "базис" из raiseR_Shoulder и плавно переходим в putOn
    local currentRaiseC0 = g_origRSC0 * P.raiseR_Shoulder
    local targetPutOnC0 = g_origRSC0 * P.putOnR_Shoulder
    local t5 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
        {C0 = targetPutOnC0}); t5:Play()
    if g_rightElbow and P.putOnR_Elbow then
        local currentRaiseElbowC0 = g_origREC0 * P.raiseR_Elbow
        local targetPutOnElbowC0 = g_origREC0 * P.putOnR_Elbow
        TweenService:Create(g_rightElbow, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
            {C0 = targetPutOnElbowC0}):Play()
    end
    t5.Completed:Wait()

    g_attachToHead()

    -- 6) Возврат в idle
    local t6 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
        {C0 = g_origRSC0}); t6:Play()
    if g_rightElbow then
        TweenService:Create(g_rightElbow, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origREC0}):Play()
    end
    if g_neck then
        TweenService:Create(g_neck, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0 * CFrame.Angles(math.rad(3), 0, 0)}):Play()
    end
    t6.Completed:Wait()

    g_glassesOpen = true
    g_isAnimating = false
end

function g_takeOffGlasses()
    if g_isAnimating or not g_glassesOpen then return end
    if not g_rightShoulder then return end
    g_isAnimating = true
    -- Save glasses state
    pcall(function() scSetGlassesState("closed") end)
    local P = G_POSES[g_rigType]

    -- 1) Рука к лицу
    if g_neck then
        TweenService:Create(g_neck, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0 * P.putOnNeck}):Play()
    end
    local t1 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
        {C0 = g_origRSC0 * P.putOnR_Shoulder}); t1:Play()
    if g_rightElbow and P.putOnR_Elbow then
        TweenService:Create(g_rightElbow, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
            {C0 = g_origREC0 * P.putOnR_Elbow}):Play()
    end
    t1.Completed:Wait()

    g_attachToHand()

    -- 2) Убираем
    if g_neck then
        TweenService:Create(g_neck, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0 * P.takeNeck}):Play()
    end
    local t2 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
        {C0 = g_origRSC0 * P.takeR_Shoulder}); t2:Play()
    if g_rightElbow and P.takeR_Elbow then
        TweenService:Create(g_rightElbow, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origREC0 * P.takeR_Elbow}):Play()
    end
    t2.Completed:Wait()

    -- Удаляем очки
    if g_glasses    then g_glasses:Destroy();    g_glasses = nil    end
    if g_handWeld   then g_handWeld:Destroy();   g_handWeld = nil   end
    if g_headWeld   then g_headWeld:Destroy();   g_headWeld = nil   end
    g_glassesBaseC0 = nil

    -- 3) К карману
    if g_neck then
        TweenService:Create(g_neck, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0 * P.reachNeck}):Play()
    end
    local t3 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
        {C0 = g_origRSC0 * P.reachR_Shoulder}); t3:Play()
    if g_rightElbow and P.reachR_Elbow then
        TweenService:Create(g_rightElbow, TweenInfo.new(0.4, Enum.EasingStyle.Quad),
            {C0 = g_origREC0 * P.reachR_Elbow}):Play()
    end
    t3.Completed:Wait()
    task.wait(POCKET_HOLD_TIME_G)

    -- 4) Idle
    local t4 = TweenService:Create(g_rightShoulder, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
        {C0 = g_origRSC0}); t4:Play()
    if g_rightElbow then
        TweenService:Create(g_rightElbow, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origREC0}):Play()
    end
    if g_neck then
        TweenService:Create(g_neck, TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {C0 = g_origNeckC0}):Play()
    end
    t4.Completed:Wait()

    g_glassesOpen = false
    g_isAnimating = false
end

function g_onCharacterAdded()
    -- Сброс состояния (предыдущие очки исчезли с прошлым character'ом)
    g_glasses    = nil
    g_handWeld   = nil
    g_headWeld   = nil
    g_glassesBaseC0 = nil
    g_isAnimating = false
    g_glassesOpen = false
    task.wait(0.2)
    g_resetJoints()

    -- Восстанавливаем очки если они были надеты до смерти (но НЕ показываем меню)
    if g_shouldRestoreGlasses and not g_glassesOpen then
        g_shouldRestoreGlasses = false
        task.spawn(function()
            g_putOnGlasses()
            -- Set glassesHidden to true so Ins will show menu
            glassesHidden = true
        end)
    end
end

