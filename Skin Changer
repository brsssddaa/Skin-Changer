    subTitle.BackgroundTransparency = 1
    subTitle.TextColor3 = Theme.primary
    subTitle.Font = FONT_SEMI
    subTitle.TextSize = 11
    subTitle.TextXAlignment = Enum.TextXAlignment.Left
    subTitle.Text = "SELECT  ·  CARDS SHOW 3D MODELS"
    subTitle.Parent = root

    -- ===== Full Width: Tabs + Grid + Apply =====
    local mainWrap = Instance.new("Frame")
    mainWrap.Size = UDim2.new(1, -48, 1, -120)
    mainWrap.Position = UDim2.new(0, 24, 0, 76)
    mainWrap.BackgroundTransparency = 1
    mainWrap.Parent = root

    -- Tabs
    local tabBar = Instance.new("Frame")
    tabBar.Size = UDim2.new(1, 0, 0, 30)
    tabBar.BackgroundTransparency = 1
    tabBar.Parent = mainWrap
    local tabList = Instance.new("UIListLayout")
    tabList.FillDirection = Enum.FillDirection.Horizontal
    tabList.Padding = UDim.new(0, 6)
    tabList.HorizontalAlignment = Enum.HorizontalAlignment.Left
    tabList.SortOrder = Enum.SortOrder.LayoutOrder
    tabList.Parent = tabBar

    local activeTab = "players"
    local selected = nil
    local refreshList, refreshViewport
    local tabBtns = {}

    local function makeTab(name, key, order)
        local b = Instance.new("TextButton")
        b.LayoutOrder = order
        b.Size = UDim2.fromOffset(78, 26)
        b.BackgroundColor3 = C.BLACK
        b.BackgroundTransparency = 0.2
        b.Text = name
        b.TextColor3 = C.WHITE
        b.Font = FONT_SEMI
        b.TextSize = 12
        b.AutoButtonColor = false
        b.Parent = tabBar
        wmCorner(b, 6)
        local s = wmStroke(b, Theme.primary, 1, 0.3)
        tabBtns[key] = {btn = b, stroke = s}
        b.MouseButton1Click:Connect(function()
            activeTab = key
            title.Text = key == "players" and "PLAYERS" or "SAVED SKINS"
            for k, v in pairs(tabBtns) do
                v.btn.BackgroundTransparency = (k == key) and 0 or 0.2
                v.btn.BackgroundColor3       = (k == key) and Theme.primary or C.BLACK
                v.btn.TextColor3             = (k == key) and C.BLACK or C.WHITE
                v.stroke.Transparency        = (k == key) and 0 or 0.3
            end
            selected = nil
            task.spawn(function()
                if refreshList then refreshList() end
            end)
        end)
    end
    makeTab("PLAYERS", "players", 1)
    makeTab("SAVED",   "saved",   2)

    tabBtns.players.btn.BackgroundColor3 = Theme.primary
    tabBtns.players.btn.BackgroundTransparency = 0
    tabBtns.players.btn.TextColor3 = C.BLACK
    tabBtns.players.stroke.Transparency = 0

    -- Grid layout for cards
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, 0, 1, -82)
    scroll.Position = UDim2.new(0, 0, 0, 38)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = Theme.primary
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.Parent = mainWrap

    local gridLayout = Instance.new("UIGridLayout")
    gridLayout.CellSize = UDim2.fromOffset(180, 200)  -- Match createSavedCard
    gridLayout.CellPadding = UDim2.fromOffset(10, 10)
    gridLayout.SortOrder = Enum.SortOrder.LayoutOrder
    gridLayout.Parent = scroll

    -- Apply / Save buttons
    local btnRow = Instance.new("Frame")
    btnRow.AnchorPoint = Vector2.new(0, 1)
    btnRow.Size = UDim2.new(1, 0, 0, 36)
    btnRow.Position = UDim2.new(0, 0, 1, -2)
    btnRow.BackgroundTransparency = 1
    btnRow.Parent = mainWrap

    local applyBtn = Instance.new("TextButton")
    applyBtn.Size = UDim2.new(0.66, -4, 1, 0)
    applyBtn.Position = UDim2.new(0, 0, 0, 0)
    applyBtn.BackgroundColor3 = Theme.primary
    applyBtn.Text = "APPLY"
    applyBtn.TextColor3 = C.BLACK
    applyBtn.Font = FONT_BOLD
    applyBtn.TextSize = 14
    applyBtn.AutoButtonColor = false
    applyBtn.Parent = btnRow
    wmCorner(applyBtn, 6)
    wmStroke(applyBtn, Theme.primary, 1.4, 0)

    local saveBtn = Instance.new("TextButton")
    saveBtn.Size = UDim2.new(0.34, -4, 1, 0)
    saveBtn.Position = UDim2.new(0.66, 4, 0, 0)
    saveBtn.BackgroundColor3 = C.BLACK
    saveBtn.BackgroundTransparency = 0.15
    saveBtn.Text = "+ SAVE"
    saveBtn.TextColor3 = Theme.primary
    saveBtn.Font = FONT_BOLD
    saveBtn.TextSize = 13
    saveBtn.AutoButtonColor = false
    saveBtn.Parent = btnRow
    wmCorner(saveBtn, 6)
    wmStroke(saveBtn, Theme.primary, 1.4, 0.1)

    -- No viewport refresh needed since we removed the left preview

    -- ===== Apply / Save handlers =====
    applyBtn.MouseButton1Click:Connect(function()
        if not selected then return end
        local prevText = applyBtn.Text
        applyBtn.Text = "..."
        task.spawn(function()
            local ok = false
            if selected.kind == "player" then
                if selected.player == player then
                    ok = pcall(restoreOriginalSkin)
                else
                    ok = pcall(function() applySkin(selected.player) end)
                end
            elseif selected.kind == "saved" then
                ok = pcall(function()
                    savedSkinData = selected.skinData
                    applySavedSkin(selected.skinData)
                end)
            end
            applyBtn.Text = ok and "✓ APPLIED" or "✕ FAIL"
            task.wait(1)
            if applyBtn and applyBtn.Parent then applyBtn.Text = prevText end
        end)
    end)

    saveBtn.MouseButton1Click:Connect(function()
        if not selected or selected.kind ~= "player" then return end
        local plr = selected.player
        if not plr or not plr.Character then return end
        local prevText = saveBtn.Text
        saveBtn.Text = "..."
        task.spawn(function()
            local snap = nil
            local ok = pcall(function() snap = captureSkinSnapshot(plr) end)
            if ok and snap then
                table.insert(savedSkins, snap)
                if saveSavedSkinsToFile then pcall(saveSavedSkinsToFile) end
                if updateSavedSkinsList then pcall(updateSavedSkinsList) end
                saveBtn.Text = "✓"
            else
                saveBtn.Text = "✕"
            end
            task.wait(1)
            if saveBtn and saveBtn.Parent then saveBtn.Text = prevText end
        end)
    end)

    -- ===== Card rendering =====
    local cardRefs = {}  -- Store card references for refreshing selection

    refreshList = function()
        -- Clear existing cards
        for _, c in ipairs(scroll:GetChildren()) do
            if c:IsA("Frame") then c:Destroy() end
        end
        cardRefs = {}

        if activeTab == "players" then
            for i, plr in ipairs(Players:GetPlayers()) do
                if plr.Character then
                    local sel = {kind = "player", player = plr}
                    local card, cardStroke = wmCreateViewportCard(scroll, plr, false, i, function()
                        selected = sel
                        task.spawn(refreshList)
                    end)
                    cardRefs[sel] = {card = card, stroke = cardStroke}
                end
            end
        else
            if #savedSkins == 0 then
                local empty = Instance.new("TextLabel")
                empty.Size = UDim2.new(1, -4, 0, 42)
                empty.BackgroundTransparency = 1
                empty.Text = "NO SAVED SKINS"
                empty.TextColor3 = C.TEXT_MUTE
                empty.Font = FONT_SEMI
                empty.TextSize = 13
                empty.Parent = scroll
            else
                for i, sk in ipairs(savedSkins) do
                    local sel = {kind = "saved", skinData = sk}
                    local card, cardStroke = wmCreateViewportCard(scroll, sk, true, i, function()
                        selected = sel
                        task.spawn(refreshList)
                    end)
                    cardRefs[sel] = {card = card, stroke = cardStroke}
                end
            end
        end

        -- Highlight selected card
        for sel, ref in pairs(cardRefs) do
            if selected and selected.kind == sel.kind then
                if selected.kind == "player" and selected.player == sel.player then
                    ref.card.BackgroundColor3 = Theme.primary
                    ref.card.BackgroundTransparency = 0
                    ref.stroke.Transparency = 0
                    ref.stroke.Thickness = 1.5
                elseif selected.kind == "saved" and selected.skinData == sel.skinData then
                    ref.card.BackgroundColor3 = Theme.primary
                    ref.card.BackgroundTransparency = 0
                    ref.stroke.Transparency = 0
                    ref.stroke.Thickness = 1.5
                else
                    ref.card.BackgroundColor3 = C.BLACK
                    ref.card.BackgroundTransparency = 0.2
                    ref.stroke.Transparency = 0.5
                    ref.stroke.Thickness = 1
                end
            else
                ref.card.BackgroundColor3 = C.BLACK
                ref.card.BackgroundTransparency = 0.2
                ref.stroke.Transparency = 0.5
                ref.stroke.Thickness = 1
            end
        end
    end
    refreshList()

    -- Footer hint
    local hint = Instance.new("TextLabel")
    hint.AnchorPoint = Vector2.new(0, 1)
    hint.Size = UDim2.new(1, -32, 0, 16)
    hint.Position = UDim2.new(0, 24, 1, -8)
    hint.BackgroundTransparency = 1
    hint.Text = ""  -- Removed "PRESS INSERT TO CLOSE"
    hint.TextColor3 = Theme.primary
    hint.Font = FONT_SEMI
    hint.TextSize = 10
    hint.TextXAlignment = Enum.TextXAlignment.Left
    hint.Parent = root
    end -- close do block
end

-- ============= СОЗДАНИЕ И УПРАВЛЕНИЕ =============
function createWorldPanel(angleDeg, phase, contentBuilder, name, sizeStuds, canvasSize)
    do -- block to limit locals scope
    ensureWorldMenuFolder()
    sizeStuds  = sizeStuds  or Vector3.new(6, 4, 0.05)
    canvasSize = canvasSize or Vector2.new(480, 320)

    local part = Instance.new("Part")
    part.Name = "GlassesMenu_" .. name
    part.Size = sizeStuds
    part.Anchored = true
    part.CanCollide = false
    part.CastShadow = false
    part.Massless = true
    part.Transparency = 1
    part.Parent = worldMenuFolder

    -- Star particles
    local starAttach = Instance.new("Attachment")
    starAttach.Name = "Stars"
    starAttach.Position = Vector3.new(0, sizeStuds.Y * 0.5, 0)
    starAttach.Parent = part

    local starEmitter = Instance.new("ParticleEmitter")
    starEmitter.Name = "StarDust"
    starEmitter.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255))
    starEmitter.Size = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.08),
        NumberSequenceKeypoint.new(0.5, 0.15),
        NumberSequenceKeypoint.new(1, 0.05),
    })
    starEmitter.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.2),
        NumberSequenceKeypoint.new(0.5, 0.5),
        NumberSequenceKeypoint.new(1, 1),
    })
    starEmitter.Lifetime = NumberRange.new(1.5, 3)
    starEmitter.Rate = 60
    starEmitter.Speed = NumberRange.new(0.3, 1.2)
    starEmitter.SpreadAngle = Vector2.new(180, 180)
    starEmitter.Acceleration = Vector3.new(0, -0.3, 0)
    starEmitter.RotSpeed = NumberRange.new(-90, 90)
    starEmitter.LightEmission = 0.8
    starEmitter.LightInfluence = 0
    starEmitter.Parent = starAttach

    local dragAngleOffset = 0
    local dragHeightOffset = 0
    local panelData = nil
    local initialDragY = 0

    local function onDragStart()
        initialDragY = dragHeightOffset
        return dragAngleOffset, dragHeightOffset
    end
    local function onDragInput(mouseX, mouseY, screenCenterX, screenCenterY)
        -- Cursor-based drag: menu follows cursor position
        -- Calculate cursor offset from screen center
        local offsetX = mouseX - screenCenterX
        local offsetY = mouseY - screenCenterY
        
        -- Map X offset to rotation angle (more intuitive)
        -- Cursor to right = rotate clockwise, cursor to left = rotate counter-clockwise
        local maxAngle = 180  -- Maximum rotation in degrees
        dragAngleOffset = -(offsetX / (screenCenterX * 0.8)) * maxAngle  -- Inverted for correct direction
        dragAngleOffset = math.clamp(dragAngleOffset, -maxAngle, maxAngle)
        
        -- Map Y offset to height (cursor up = menu up, cursor down = menu down)
        -- Negative Y offset (cursor above center) = positive height
        local maxHeight = 3  -- Maximum height in studs
        dragHeightOffset = -(offsetY / (screenCenterY * 0.6)) * maxHeight
        dragHeightOffset = math.clamp(dragHeightOffset, 0, maxHeight)
        
        if panelData then
            panelData.angleOffset = dragAngleOffset
            panelData.heightOffset = dragHeightOffset
            -- Also update preserved offsets for persistence across glasses toggle
            preservedPanelOffsets.angleOffset = dragAngleOffset
            preservedPanelOffsets.heightOffset = dragHeightOffset
        end
    end
    local function onDragEnd()
        -- Запоминаем последний offset — panelData обновит через ссылку
    end

    local sg = Instance.new("SurfaceGui")
    sg.Name = "Content"
    sg.Adornee = part
    sg.Face = Enum.NormalId.Front
    sg.LightInfluence = 0
    sg.AlwaysOnTop = true
    sg.SizingMode = Enum.SurfaceGuiSizingMode.FixedSize
    sg.CanvasSize = canvasSize
    sg.Parent = part

    local ok, err = pcall(function() contentBuilder(sg, onDragStart, onDragInput, onDragEnd) end)
    -- Back SurfaceGui для отображения с обратной стороны
    local sgBack = Instance.new("SurfaceGui")
    sgBack.Name = "ContentBack"
    sgBack.Adornee = part
    sgBack.Face = Enum.NormalId.Back
    sgBack.LightInfluence = 0
    sgBack.AlwaysOnTop = true
    sgBack.SizingMode = Enum.SurfaceGuiSizingMode.FixedSize
    sgBack.CanvasSize = canvasSize
    sgBack.Parent = part

    local ok2, err2 = pcall(function() contentBuilder(sgBack, onDragStart, onDragInput, onDragEnd) end)
    panelData = {
        part = part,
        sg = sg,
        baseAngle = angleDeg,
        angleOffset = preservedPanelOffsets.angleOffset or 0,
        heightOffset = preservedPanelOffsets.heightOffset or 0,
        phase = phase,
        currentPos = nil,
        velocity = Vector3.new(0, 0, 0),
        starEmitter = starEmitter,
        flipRotation = preservedFlipRotation or 0,
    }
    table.insert(worldPanels, panelData)
    
    -- Apply preserved flip rotation to part immediately
    if panelData.flipRotation ~= 0 then
        part.CFrame = part.CFrame * CFrame.Angles(0, panelData.flipRotation, 0)
    end
    end -- close do block
end

function captureAnchorForward()
    if not g_character then return end
    local hrp = g_character:FindFirstChild("HumanoidRootPart") or g_character:FindFirstChild("Torso")
    if not hrp then
        -- Подождём загрузки HRP (до 1.5 сек)
        for i = 1, 30 do
            task.wait(0.05)
            hrp = g_character:FindFirstChild("HumanoidRootPart") or g_character:FindFirstChild("Torso")
            if hrp then break end
        end
    end
    if not hrp then
        return
    end
    local fwd = hrp.CFrame.LookVector
    fwd = Vector3.new(fwd.X, 0, fwd.Z)
    if fwd.Magnitude < 0.001 then fwd = Vector3.new(0, 0, -1) end
    g_anchorForward = fwd.Unit
end

function buildPanels()
    -- Cancel any active flip animation before destroying panels
    if flipAnimationConnection then
        flipAnimationConnection:Disconnect()
        flipAnimationConnection = nil
    end
    for _, p in ipairs(worldPanels) do if p.part then p.part:Destroy() end end
    worldPanels = {}
    -- Main: 6×4 студ, canvas 480×320
    createWorldPanel(-60, 0,    buildSettingsContent, "Main",
        Vector3.new(6, 4, 0.05), Vector2.new(480, 320))
end

showGlassesWorldMenus = function()
    if glassesMenuVisible then return end
    glassesMenuVisible = true
    glassesHidden = false
    captureAnchorForward()
    if not g_anchorForward then
        -- Fallback: используем направление камеры
        local cam = workspace.CurrentCamera
        if cam then
            local fwd = cam.CFrame.LookVector
            g_anchorForward = Vector3.new(fwd.X, 0, fwd.Z).Unit
        else
            g_anchorForward = Vector3.new(0, 0, -1)
        end
        
    end
    buildPanels()
    
    -- Shatter Reverse: shards fly in and assemble the panel
    task.spawn(function()
        if #worldPanels == 0 then return end
        local panel = worldPanels[1].part
        if not panel or not panel.Parent then return end

        local finalCFrame = panel.CFrame
        local finalSize = panel.Size
        local shardColor = Theme.primary or Color3.fromRGB(255, 255, 255)

        -- Hide panel & its SurfaceGuis during assembly
        local sgList = {}
        for _, ch in ipairs(panel:GetChildren()) do
            if ch:IsA("SurfaceGui") then
                table.insert(sgList, {sg = ch, was = ch.Enabled})
                ch.Enabled = false
            end
        end
        local origTransparency = panel.Transparency
        panel.Transparency = 1

        local shardCount = 14
        local shards = {}
        for i = 1, shardCount do
            local shard = Instance.new("Part")
            shard.Name = "MenuShard"
            shard.Size = Vector3.new(0.4, 0.4, 0.05)
            shard.Material = Enum.Material.Neon
            shard.Color = shardColor
            shard.Transparency = 0.2
            shard.Anchored = true
            shard.CanCollide = false
            shard.CanQuery = false
            shard.CanTouch = false
            shard.Massless = true
            shard.CastShadow = false

            local angle = math.random() * math.pi * 2
            local radius = 6 + math.random() * 4
            local heightOff = (math.random() - 0.5) * 6
            local offset = Vector3.new(math.cos(angle) * radius, heightOff, math.sin(angle) * radius)
            local randRot = CFrame.Angles(
                math.random() * math.pi * 2,
                math.random() * math.pi * 2,
                math.random() * math.pi * 2
            )
            shard.CFrame = CFrame.new(finalCFrame.Position + offset) * randRot
            shard.Parent = panel.Parent

            local a0 = Instance.new("Attachment"); a0.Name = "A0"; a0.Position = Vector3.new(-0.2, 0, 0); a0.Parent = shard
            local a1 = Instance.new("Attachment"); a1.Name = "A1"; a1.Position = Vector3.new(0.2, 0, 0); a1.Parent = shard
            local trail = Instance.new("Trail")
            trail.Attachment0 = a0
            trail.Attachment1 = a1
            trail.Lifetime = 0.2
            trail.MinLength = 0
            trail.LightEmission = 1
            trail.Color = ColorSequence.new(shardColor)
            trail.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 0.3),
                NumberSequenceKeypoint.new(1, 1),
            })
            trail.WidthScale = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 1),
                NumberSequenceKeypoint.new(1, 0),
            })
            trail.Parent = shard

            table.insert(shards, {part = shard, offset = offset, rot = randRot})
        end

        -- Per-frame lerp toward current panel position (follows panel motion)
        local startTime = tick()
        local duration = 0.45
        local animConn
        animConn = RunService.RenderStepped:Connect(function()
            if not panel.Parent then
                if animConn then animConn:Disconnect() end
                return
            end
            local progress = math.min((tick() - startTime) / duration, 1)
            local overshoot = 1.70158
            -- easeInBack
            local eased = progress * progress * ((overshoot + 1) * progress - overshoot)
            local invEased = 1 - eased
            local targetPos = panel.CFrame.Position
            local sizeScale = 1 - eased * 0.95
            for _, info in ipairs(shards) do
                if info.part.Parent then
                    local pos = targetPos + info.offset * invEased
                    info.part.CFrame = CFrame.new(pos) * info.rot
                    info.part.Size = Vector3.new(0.4 * sizeScale, 0.4 * sizeScale, 0.05)
                    info.part.Transparency = 0.2 + eased * 0.8
                end
            end
            if progress >= 1 then
                if animConn then animConn:Disconnect() end
            end
        end)

        -- Flash + reveal panel at assembly moment
        task.delay(0.4, function()
            if not panel.Parent then return end
            local flash = Instance.new("PointLight")
            flash.Brightness = 3
            flash.Range = 12
            flash.Color = shardColor
            flash.Parent = panel
            TweenService:Create(flash, TweenInfo.new(0.15), {Brightness = 0, Range = 0}):Play()
            task.delay(0.2, function() if flash.Parent then flash:Destroy() end end)

            TweenService:Create(panel, TweenInfo.new(0.2), {Transparency = origTransparency}):Play()
            for _, info in ipairs(sgList) do
                if info.sg.Parent then info.sg.Enabled = info.was end
            end
        end)

        task.delay(0.7, function()
            for _, info in ipairs(shards) do if info.part.Parent then info.part:Destroy() end end
        end)
    end)
end

hideGlassesWorldMenus = function(keepHiddenFlag, instant)
    glassesMenuVisible = false
    if not keepHiddenFlag then
        glassesHidden = false
    end
    
    -- Preserve current panel offsets before clearing
    if #worldPanels > 0 then
        local firstPanel = worldPanels[1]
        preservedPanelOffsets.angleOffset = firstPanel.angleOffset or 0
        preservedPanelOffsets.heightOffset = firstPanel.heightOffset or 0
    end
    
    local panelsToPop = worldPanels
    worldPanels = {}
    -- Если instant — просто удаляем без анимации (например при смерти)
    if instant then
        for _, p in ipairs(panelsToPop) do
            if p.part then p.part:Destroy() end
        end
        return
    end
    -- Эффект "красивого взрыва" - звёздочки разлетаются во все стороны
    for _, p in ipairs(panelsToPop) do
        if p.part and p.part.Parent then
            local part = p.part
            -- Сразу прячем весь UI панели чтобы не оставалось обводки/иконок/контента
            for _, ch in ipairs(part:GetChildren()) do
                if ch:IsA("SurfaceGui") then
                    ch.Enabled = false
                end
            end
            part.Transparency = 1  -- сам part тоже невидим
            task.spawn(function()
                -- Гасим существующий эмиттер
                local existingAttach = part:FindFirstChild("Stars")
                if existingAttach then
                    local em = existingAttach:FindFirstChildOfClass("ParticleEmitter")
                    if em then em.Rate = 0 end
                end

                -- BURST: 6 attachment'ов в разные стороны для радиального разлёта
                local burstCount = 6
                for i = 1, burstCount do
                    local angle = (i / burstCount) * math.pi * 2
                    local dir = Vector3.new(math.cos(angle), math.sin(angle) * 0.5 + 0.3, math.sin(angle) * 0.5)
                    local att = Instance.new("Attachment")
                    att.Position = Vector3.new(0, 0, 0)
                    att.Parent = part

                    local emitter = Instance.new("ParticleEmitter")
                    emitter.Texture = "rbxasset://textures/particles/sparkles_main.dds"
                    emitter.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255))
                    emitter.Size = NumberSequence.new({
                        NumberSequenceKeypoint.new(0, 0.3),
                        NumberSequenceKeypoint.new(0.5, 0.4),
                        NumberSequenceKeypoint.new(1, 0.05),
                    })
                    emitter.Transparency = NumberSequence.new({
                        NumberSequenceKeypoint.new(0, 0),
                        NumberSequenceKeypoint.new(0.7, 0.3),
                        NumberSequenceKeypoint.new(1, 1),
                    })
                    emitter.Lifetime = NumberRange.new(0.8, 1.4)
                    emitter.Speed = NumberRange.new(8, 14)
                    emitter.SpreadAngle = Vector2.new(20, 20)
                    emitter.Rotation = NumberRange.new(0, 360)
                    emitter.RotSpeed = NumberRange.new(-180, 180)
                    emitter.LightEmission = 1
                    emitter.LightInfluence = 0
                    emitter.Acceleration = Vector3.new(0, -8, 0)  -- небольшая гравитация
                    emitter.EmissionDirection = Enum.NormalId.Top  -- будем поворачивать part'ом
                    emitter.Rate = 0
                    emitter.Parent = att
                    -- Поворачиваем attachment к нужному направлению
                    att.CFrame = CFrame.lookAt(Vector3.new(0,0,0), dir)
                    emitter:Emit(25)
                end

                -- Ждём пока частицы долетят, потом удаляем part
                task.wait(1.4)
                if part and part.Parent then part:Destroy() end
            end)
        end
    end
end

