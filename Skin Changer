        local function refreshPresetButtons()
            for name, btn in pairs(presetButtons) do
                if not btn or not btn.Parent then return end
                local active = (activeShaderPreset == name)
                local preset = SHADER_PRESETS[name]
                btn.Text = (active and "✓  " or "      ") .. preset.displayName
                btn.BackgroundColor3 = active and Theme.primary or C.BLACK
                btn.TextColor3 = active and C.BLACK or C.WHITE
            end
        end
        refreshPresetButtonsGlobal = refreshPresetButtons
        -- Initial refresh in case shader was auto-applied before panel built
