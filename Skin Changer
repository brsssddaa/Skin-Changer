-- Сохранение скина после смерти
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    head = newChar:WaitForChild("Head")

    -- Переприменяем скин если был выбран
    if savedSkinData then

        task.spawn(function()
            -- Ждём загрузку только критичных частей
            local rootPart = newChar:WaitForChild("HumanoidRootPart", 5)
            if not rootPart then
                return
            end

            -- Ждём 1.5 секунды для полной загрузки персонажа
            task.wait(1.5)

            -- Проверяем что наш персонаж не изменился
            if player.Character ~= newChar then
                return
            end


            -- Применяем скин из сохранённых данных
            local success, err = pcall(function()
                applySavedSkin(savedSkinData)
            end)

            if not success then
            else
            end
        end)
    else
    end
end)


-- Обновляем список сохранённых скинов после загрузки
if #savedSkins > 0 then
    updateSavedSkinsList()
end
