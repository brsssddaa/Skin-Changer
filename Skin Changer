SC_DIR           = "SkinChanger"
SC_SKINS_FILE    = SC_DIR .. "/SkinChanger_SavedSkins"
SC_AUTOEXEC_FILE = SC_DIR .. "/SkinChanger_Autoexec"

function ensureSkinChangerDir()
    if makefolder and isfolder then
        pcall(function()
            if not isfolder(SC_DIR) then makefolder(SC_DIR) end
        end)
    end
end

function scReadJSON(path)
    if not (readfile and isfile) then return nil end
    local ok, result = pcall(function()
        if not isfile(path) then return nil end
        local raw = readfile(path)
        if not raw or raw == "" then return nil end
        return HttpService:JSONDecode(raw)
    end)
    if ok then return result end
    return nil
end

function scWriteJSON(path, tbl)
    if not writefile then return false end
    ensureSkinChangerDir()
    local ok = pcall(function()
        writefile(path, HttpService:JSONEncode(tbl or {}))
    end)
    return ok
end

function scReadSkinsBundle()
    local data = scReadJSON(SC_SKINS_FILE)
    if type(data) ~= "table" then
        data = { savedSkins = {}, glassesState = "closed" }
    end
    if type(data.savedSkins) ~= "table" then data.savedSkins = {} end
    if type(data.glassesState) ~= "string" then data.glassesState = "closed" end
    return data
end

function scWriteSkinsBundle(bundle)
    return scWriteJSON(SC_SKINS_FILE, bundle)
end

function scReadAutoexec()
    local data = scReadJSON(SC_AUTOEXEC_FILE)
    if type(data) ~= "table" then
        data = { enabled = false }
    end
    if type(data.enabled) ~= "boolean" then data.enabled = false end
    return data
end

function scWriteAutoexec(tbl)
    return scWriteJSON(SC_AUTOEXEC_FILE, tbl)
end

function scIsAutoexecEnabled()
    return scReadAutoexec().enabled == true
end

function scSetAutoexecEnabled(enabled)
    local data = scReadAutoexec()
    data.enabled = enabled and true or false
    -- Keep lastSkin across toggles: re-enabling should restore last state
    -- without requiring the user to re-apply a skin first.
    return scWriteAutoexec(data)
end

function scSetLastSkinIfAutoexec(skinEntry)
    -- Only write lastSkin when autoexec is enabled
    local data = scReadAutoexec()
    if not data.enabled then return end
    data.lastSkin = skinEntry
    scWriteAutoexec(data)
end

function scSetGlassesState(state)
    local bundle = scReadSkinsBundle()
    bundle.glassesState = state
    scWriteSkinsBundle(bundle)
end

-- Settings file: persistent preferences applied on EVERY launch (manual or autoexec)
SC_SETTINGS_FILE = SC_DIR .. "/SkinChanger_Settings"

function scReadSettings()
    local data = scReadJSON(SC_SETTINGS_FILE)
    if type(data) ~= "table" then data = {} end
    return data
end

function scWriteSettings(tbl)
    return scWriteJSON(SC_SETTINGS_FILE, tbl)
end

function scUpdateSetting(key, value)
    local s = scReadSettings()
    s[key] = value
    scWriteSettings(s)
end

-- One-shot migration from legacy files
function scMigrateLegacy()
    ensureSkinChangerDir()

    -- Migrate saved skins
    if isfile and isfile("SkinChanger_SavedSkins.json") then
        local ok, legacy = pcall(function()
            return HttpService:JSONDecode(readfile("SkinChanger_SavedSkins.json"))
        end)
        if ok and type(legacy) == "table" then
            local bundle = scReadSkinsBundle()
            bundle.savedSkins = legacy
            scWriteSkinsBundle(bundle)
        end
        pcall(function() if delfile then delfile("SkinChanger_SavedSkins.json") end end)
    end

    -- Migrate glasses state
    if isfile and isfile("SkinChanger_GlassesState.txt") then
        local ok, content = pcall(readfile, "SkinChanger_GlassesState.txt")
        if ok and content then
            local bundle = scReadSkinsBundle()
            bundle.glassesState = content
            scWriteSkinsBundle(bundle)
        end
        pcall(function() if delfile then delfile("SkinChanger_GlassesState.txt") end end)
    end

    -- Migrate autoexec flag + lastSkin index
    local legacyEnabled = nil
    if isfile and isfile("SkinChanger_Autoexec.txt") then
        local ok, content = pcall(readfile, "SkinChanger_Autoexec.txt")
        if ok and content == "true" then legacyEnabled = true else legacyEnabled = false end
        pcall(function() if delfile then delfile("SkinChanger_Autoexec.txt") end end)
    end
    if legacyEnabled ~= nil then
        local ae = scReadAutoexec()
        ae.enabled = legacyEnabled
        scWriteAutoexec(ae)
    end

    -- Cleanup unused legacy files
    if delfile then
        pcall(function() if isfile("SkinChanger_LastSkin.txt") then delfile("SkinChanger_LastSkin.txt") end end)
        pcall(function() if isfile("SkinChanger_ManualAutoexecPath.txt") then delfile("SkinChanger_ManualAutoexecPath.txt") end end)
    end
end

-- Run migration immediately
pcall(scMigrateLegacy)

