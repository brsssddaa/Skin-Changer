local AUTOEXEC_CANDIDATES = {
    "autoexec",
    "Autoexec",
    "AutoExec",
    "../autoexec",
    "../Autoexec",
    "scripts/autoexec",
    "autoexec/scripts",
    "workspace/autoexec",
