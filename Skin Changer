function gradPDP(t) return ColorSequence.new{ColorSequenceKeypoint.new(0.0, t.primary), ColorSequenceKeypoint.new(0.5, t.dark), ColorSequenceKeypoint.new(1.0, t.primary)} end
function gradDPD(t) return ColorSequence.new{ColorSequenceKeypoint.new(0.0, t.dark), ColorSequenceKeypoint.new(0.5, t.primary), ColorSequenceKeypoint.new(1.0, t.dark)} end
function gradDP(t) return ColorSequence.new(t.dark, t.primary) end

